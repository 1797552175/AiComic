tatus.COMPLETED\n\n\n@router.post(\"/panels\", response_model=ComicPanelResponse)\nasync def create_panel(background_tasks: BackgroundTasks, request: ComicPanelRequest):\n    \"\"\"Generate a single comic panel\"\"\"\n    panel_id = str(uuid.uuid4())\n    \n    panel_data = {\n        \"panel_id\": panel_id,\n        \"image_url\": \"\",  # Will be updated by background task\n        \"prompt\": request.prompt,\n        \"style\": request.style,\n        \"status\": TaskStatus.RUNNING,\n        \"created_at\": datetime.utcnow()\n    }\n    \n    panels_db[panel_id] = panel_data\n    \n    # Run generation in background\n    background_tasks.add_task(generate_panel_async, panel_id, request)\n    \n    return ComicPanelResponse(**panel_data)\n\n\n@router.get(\"/panels\", response_model=List[ComicPanelResponse])\nasync def list_panels():\n    \"\"\"List all generated panels\"\"\"\n    return [\n        ComicPanelResponse(\n            panel_id=p[\"panel_id\"],\n            image_url=p[\"image_url\"],\n            prompt=p[\"prompt\"],\n            style=p[\"style\"],\n            status=p[\"status\"],\n            created_at=p[\"created_at\"]\n        )\n        for p in panels_db.values()\n    ]\n\n\n@router.get(\"/panels/{panel_id}\", response_model=ComicPanelResponse)\nasync def get_panel(panel_id: str):\n    \"\"\"Get a panel by ID\"\"\"\n    if panel_id not in panels_db:\n        raise HTTPException(status_code=404, detail=\"Panel not found\")\n    p = panels_db[panel_id]\n    return ComicPanelResponse(\n        panel_id=p[\"panel_id\"],\n        image_url=p[\"image_url\"],\n        prompt=p[\"prompt\"],\n        style=p[\"style\"],\n        status=p[\"status\"],\n        created_at=p[\"created_at\"]\n    )\n\n\n@router.post(\"/strips\", response_model=ComicStripResponse)\nasync def create_strip(request: ComicStripRequest):\n    \"\"\"Create a comic strip from multiple panels\"\"\"\n    strip_id = str(uuid.uuid4())\n    comic_id = request.comic_id or str(uuid.uuid4())\n    \n    # Create panels for each request\n    panel_responses = []\n    for panel_req in request.panels:\n        panel_id = str(uuid.uuid4())\n        panel_data = {\n            \"panel_id\": panel_id,\n            \"image_url\": simulate_image_generation(panel_id, panel_req),\n            \"prompt\": panel_req.prompt,\n            \"style\": panel_req.style,\n            \"status\": TaskStatus.COMPLETED,\n            \"created_at\": datetime.utcnow()\n        }\n        panels_db[panel_id] = panel_data\n        panel_responses.append(ComicPanelResponse(**panel_data))\n    \n    strip_data = {\n        \"strip_id\": strip_id,\n        \"comic_id\": comic_id,\n        \"title\": request.title,\n        \"panels\": panel_responses,\n        \"status\": TaskStatus.COMPLETED,\n        \"created_at\": datetime.utcnow()\n    }\n    \n    strips_db[strip_id] = strip_data\n    return ComicStripResponse(**strip_data)\n\n\n@router.get(\"/strips\", response_model=List[ComicStripResponse])\nasync def list_strips():\n    \"\"\"List all comic strips\"\"\"\n    return [ComicStripResponse(**s) for s in strips_db.values()]\n\n\n@router.get(\"/strips/{strip_id}\", response_model=ComicStripResponse)\nasync def get_strip(strip_id: str):\n    \"\"\"Get a comic strip by ID\"\"\"\n    if strip_id not in strips_db:\n        raise HTTPException(status_code=404, detail=\"Strip not found\")\n    return ComicStripResponse(**strips_db[strip_id])\n\n\n# Project management schemas\nclass ProjectCreateRequest(BaseModel):\n    name: str\n    description: Optional[str] = None\n    genre: str = \"comic\"\n    style: str = \"manga\"\n\n\nclass ProjectResponse(BaseModel):\n    project_id: str\n    name: str\n    description: Optional[str]\n    genre: str\n    style: str\n    strips: List[str] = []\n    characters: List[str] = []\n    status: str\n    created_at: datetime\n\n\n@router.post(\"/projects\", response_model=ProjectResponse)\nasync def create_project(request: ProjectCreateRequest):\n    \"\"\"Create a new comic project\"\"\"\n    project_id = str(uuid.uuid4())\n    project_data = {\n        \"project_id\": project_id,\n        \"name\": request.name,\n        \"description\": request.description,\n        \"genre\": request.genre,\n        \"style\": request.style,\n        \"strips\": [],\n        \"characters\": [],\n        \"status\": \"active\",\n        \"created_at\": datetime.utcnow()\n    }\n    projects_db[project_id] = project_data\n    return ProjectResponse(**project_data)\n\n\n@router.get(\"/projects\", response_model=List[ProjectResponse])\nasync def list_projects():\n    \"\"\"List all projects\"\"\"\n    return [ProjectResponse(**p) for p in projects_db.values()]\n\n\n@router.get(\"/projects/{project_id}\", response_model=ProjectResponse)\nasync def get_project(project_id: str):\n    \"\"\"Get a project by ID\"\"\"\n    if project_id not in projects_db:\n        raise HTTPException(status_code=404, detail=\"Project not found\")\n    return ProjectResponse(**projects_db[project_id])\n\n\n@router.delete(\"/projects/{project_id}\")\nasync def delete_project(project_id: str):\n    \"\"\"Delete a project\"\"\"\n    if project_id not in projects_db:\n        raise HTTPException(status_code=404, detail=\"Project not found\")\n    del projects_db[project_id]\n    return {\"message\": \"Project deleted\"}\nEOF\necho \"Fixed comics.py\""]][0m