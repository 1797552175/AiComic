\n\n\nclass ComicStatus(enum.Enum):\n    \"\"\"Comic status enumeration\"\"\"\n    DRAFT = \"draft\"\n    PROCESSING = \"processing\"\n    COMPLETED = \"completed\"\n    PUBLISHED = \"published\"\n    ARCHIVED = \"archived\"\n\n\nclass PageStatus(enum.Enum):\n    \"\"\"Page status enumeration\"\"\"\n    PENDING = \"pending\"\n    GENERATING = \"generating\"\n    COMPLETED = \"completed\"\n    FAILED = \"failed\"\n\n\nclass CharacterType(enum.Enum):\n    \"\"\"Character type enumeration\"\"\"\n    PROTAGONIST = \"protagonist\"\n    ANTAGONIST = \"antagonist\"\n    SUPPORTING = \"supporting\"\n    MINOR = \"minor\"\n\n\n# Association tables for many-to-many relationships\ncomic_genres = Table(\n    'comic_genres',\n    Base.metadata,\n    Column('comic_id', Integer, ForeignKey('comics.id'), primary_key=True),\n    Column('genre_id', Integer, ForeignKey('genres.id'), primary_key=True),\n    Column('created_at', DateTime, default=datetime.utcnow)\n)\n\ncomic_characters = Table(\n    'comic_characters',\n    Base.metadata,\n    Column('comic_id', Integer, ForeignKey('comics.id'), primary_key=True),\n    Column('character_id', Integer, ForeignKey('characters.id'), primary_key=True),\n    Column('role', String(50), default='supporting'),\n    Column('appearance_order', Integer, default=0)\n)\n\ncomic_tags = Table(\n    'comic_tags',\n    Base.metadata,\n    Column('comic_id', Integer, ForeignKey('comics.id'), primary_key=True),\n    Column('tag_id', Integer, ForeignKey('tags.id'), primary_key=True)\n)\n\n\nclass Comic(Base):\n    \"\"\"\n    Comic model representing a complete comic book or series\n    \"\"\"\n    __tablename__ = 'comics'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    title = Column(String(255), nullable=False, index=True)\n    slug = Column(String(255), unique=True, nullable=False, index=True)\n    description = Column(Text, nullable=True)\n    author_id = Column(Integer, ForeignKey('users.id'), nullable=False, index=True)\n    status = Column(SQLEnum(ComicStatus), default=ComicStatus.DRAFT, nullable=False)\n    \n    # Comic metadata\n    genre_ids = Column(JSON, nullable=True)  # Store genre information\n    tags = relationship('Tag', secondary=comic_tags, back_populates='comics')\n    genres = relationship('Genre', secondary=comic_genres, back_populates='comics')\n    \n    # Publishing information\n    is_published = Column(Boolean, default=False, nullable=False)\n    published_at = Column(DateTime, nullable=True)\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow, nullable=False)\n    \n    # Relationships\n    pages = relationship('Page', back_populates='comic', cascade='all, delete-orphan', order_by='Page.page_number')\n    characters = relationship('Character', secondary=comic_characters, back_populates='comics')\n    author = relationship('User', back_populates='comics')\n    \n    # AI Generation metadata\n    ai_generation_prompt = Column(Text, nullable=True)\n    ai_model_used = Column(String(100), nullable=True)\n    ai_generation_config = Column(JSON, nullable=True)\n    \n    def __repr__(self):\n        return f\"<Comic(id={self.id}, title='{self.title}', status='{self.status.value}')>\"\n    \n    def to_dict(self):\n        return {\n            'id': self.id,\n            'title': self.title,\n            'slug': self.slug,\n            'description': self.description,\n            'author_id': self.author_id,\n            'status': self.status.value,\n            'is_published': self.is_published,\n            'published_at': self.published_at.isoformat() if self.published_at else None,\n            'created_at': self.created_at.isoformat() if self.created_at else None,\n            'updated_at': self.updated_at.isoformat() if self.updated_at else None,\n            'page_count': len(self.pages) if self.pages else 0,\n            'ai_model_used': self.ai_model_used\n        }\n\n\nclass Page(Base):\n    \"\"\"\n    Page model representing individual pages in a comic\n    \"\"\"\n    __tablename__ = 'pages'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    comic_id = Column(Integer, ForeignKey('comics.id', ondelete='CASCADE'), nullable=False, index=True)\n    page_number = Column(Integer, nullable=False)\n    title = Column(String(255), nullable=True)\n    \n    # Image data\n    image_url = Column(String(500), nullable=True)\n    image_path = Column(String(500), nullable=True)\n    thumbnail_url = Column(String(500), nullable=True)\n    \n    # AI Generation\n    status = Column(SQLEnum(PageStatus), default=PageStatus.PENDING, nullable=False)\n    generation_prompt = Column(Text, nullable=True)\n    negative_prompt = Column(Text, nullable=True)\n    ai_model = Column(String(100), nullable=True)\n    generation_params = Column(JSON, nullable=True)\n    \n    # Processing\n    processing_time = Column(Float, nullable=True)  # in seconds\n    retry_count = Column(Integer, default=0)\n    error_message = Column(Text, nullable=True)\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow, nullable=False)\n    generated_at = Column(DateTime, nullable=True)\n    \n    # Relationships\n    comic = relationship('Comic', back_populates='pages')\n    content_blocks = relationship('ContentBlock', back_populates='page', cascade='all, delete-orphan')\n    \n    def __repr__(self):\n        return f\"<Page(id={self.id}, comic_id={self.comic_id}, page_number={self.page_number}, status='{self.status.value}')>\"\n    \n    def to_dict(self):\n        return {\n            'id': self.id,\n            'comic_id': self.comic_id,\n            'page_number': self.page_number,\n            'title': self.title,\n            'image_url': self.image_url,\n            'thumbnail_url': self.thumbnail_url,\n            'status': self.status.value,\n            'generation_prompt': self.generation_prompt,\n            'ai_model': self.ai_model,\n            'processing_time': self.processing_time,\n            'error_message': self.error_message,\n            'created_at': self.created_at.isoformat() if self.created_at else None,\n            'generated_at': self.generated_at.isoformat() if self.generated_at else None\n        }\n\n\nclass ContentBlock(Base):\n    \"\"\"\n    ContentBlock model representing text/panels within a page\n    \"\"\"\n    __tablename__ = 'content_blocks'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    page_id = Column(Integer, ForeignKey('pages.id', ondelete='CASCADE'), nullable=False, index=True)\n    \n    # Block positioning\n    block_type = Column(String(50), nullable=False)  # 'text', 'speech', 'narrative', 'panel'\n    x_position = Column(Float, nullable=False, default=0)\n    y_position = Column(Float, nullable=False, default=0)\n    width = Column(Float, nullable=False, default=100)\n    height = Column(Float, nullable=False, default=100)\n    \n    # Content\n    content = Column(Text, nullable=True)\n    style = Column(JSON, nullable=True)  # font, color, size, etc.\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow, nullable=False)\n    \n    # Relationships\n    page = relationship('Page', back_populates='content_blocks')\n    \n    def __repr__(self):\n        return f\"<ContentBlock(id={self.id}, page_id={self.page_id}, type='{self.block_type}')>\"\n\n\nclass Character(Base):\n    \"\"\"\n    Character model representing characters in comics\n    \"\"\"\n    __tablename__ = 'characters'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    name = Column(String(255), nullable=False, index=True)\n    slug = Column(String(255), unique=True, nullable=False)\n    description = Column(Text, nullable=True)\n    character_type = Column(SQLEnum(CharacterType), default=CharacterType.SUPPORTING)\n    \n    # Visual description for AI\n    visual_prompt = Column(Text, nullable=True)\n    default_appearance = Column(JSON, nullable=True)  # style, colors, features\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow, nullable=False)\n    \n    # Relationships\n    comics = relationship('Comic', secondary=comic_characters, back_populates='characters')\n    appearances = relationship('CharacterAppearance', back_populates='character', cascade='all, delete-orphan')\n    \n    def __repr__(self):\n        return f\"<Character(id={self.id}, name='{self.name}', type='{self.character_type.value}')>\"\n\n\nclass CharacterAppearance(Base):\n    \"\"\"\n    CharacterAppearance model tracking character appearances in pages\n    \"\"\"\n    __tablename__ = 'character_appearances'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    character_id = Column(Integer, ForeignKey('characters.id', ondelete='CASCADE'), nullable=False, index=True)\n    page_id = Column(Integer, ForeignKey('pages.id', ondelete='CASCADE'), nullable=False, index=True)\n    \n    # Appearance details\n    position_x = Column(Float, nullable=False, default=0)\n    position_y = Column(Float, nullable=False, default=0)\n    scale = Column(Float, default=1.0)\n    expression = Column(String(100), nullable=True)\n    pose = Column(String(100), nullable=True)\n    \n    # Customization for this appearance\n    custom_prompt = Column(Text, nullable=True)\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    \n    # Relationships\n    character = relationship('Character', back_populates='appearances')\n    page = relationship('Page')\n    \n    def __repr__(self):\n        return f\"<CharacterAppearance(id={self.id}, character_id={self.character_id}, page_id={self.page_id})>\"\n\n\nclass Genre(Base):\n    \"\"\"\n    Genre model for categorizing comics\n    \"\"\"\n    __tablename__ = 'genres'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    name = Column(String(100), nullable=False, unique=True, index=True)\n    slug = Column(String(100), unique=True, nullable=False)\n    description = Column(Text, nullable=True)\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    \n    # Relationships\n    comics = relationship('Comic', secondary=comic_genres, back_populates='genres')\n    \n    def __repr__(self):\n        return f\"<Genre(id={self.id}, name='{self.name}')>\"\n\n\nclass Tag(Base):\n    \"\"\"\n    Tag model for additional comic categorization\n    \"\"\"\n    __tablename__ = 'tags'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    name = Column(String(100), nullable=False, unique=True, index=True)\n    slug = Column(String(100), unique=True, nullable=False)\n    usage_count = Column(Integer, default=0)\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    \n    # Relationships\n    comics = relationship('Comic', secondary=comic_tags, back_populates='tags')\n    \n    def __repr__(self):\n        return f\"<Tag(id={self.id}, name='{self.name}')>\"\n\n\nclass User(Base):\n    \"\"\"\n    User model for comic creators/authors\n    \"\"\"\n    __tablename__ = 'users'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    username = Column(String(100), nullable=False, unique=True, index=True)\n    email = Column(String(255), nullable=False, unique=True, index=True)\n    password_hash = Column(String(255), nullable=False)\n    \n    # Profile information\n    display_name = Column(String(255), nullable=True)\n    bio = Column(Text, nullable=True)\n    avatar_url = Column(String(500), nullable=True)\n    \n    # User preferences\n    default_ai_model = Column(String(100), nullable=True)\n    generation_preferences = Column(JSON, nullable=True)\n    \n    # Status\n    is_active = Column(Boolean, default=True, nullable=False)\n    is_verified = Column(Boolean, default=False, nullable=False)\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow, nullable=False)\n    last_login = Column(DateTime, nullable=True)\n    \n    # Relationships\n    comics = relationship('Comic', back_populates='author', cascade='all, delete-orphan')\n    api_keys = relationship('APIKey', back_populates='user', cascade='all, delete-orphan')\n    \n    def __repr__(self):\n        return f\"<User(id={self.id}, username='{self.username}')>\"\n\n\nclass APIKey(Base):\n    \"\"\"\n    APIKey model for user authentication\n    \"\"\"\n    __tablename__ = 'api_keys'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    user_id = Column(Integer, ForeignKey('users.id', ondelete='CASCADE'), nullable=False, index=True)\n    key_hash = Column(String(255), nullable=False, unique=True)\n    name = Column(String(100), nullable=False)\n    \n    # Permissions\n    permissions = Column(JSON, nullable=True)\n    rate_limit = Column(Integer, default=100)  # requests per minute\n    \n    # Status\n    is_active = Column(Boolean, default=True, nullable=False)\n    expires_at = Column(DateTime, nullable=True)\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    last_used = Column(DateTime, nullable=True)\n    \n    # Relationships\n    user = relationship('User', back_populates='api_keys')\n    usage_logs = relationship('APIUsageLog', back_populates='api_key', cascade='all, delete-orphan')\n    \n    def __repr__(self):\n        return f\"<APIKey(id={self.id}, name='{self.name}', user_id={self.user_id})>\"\n\n\nclass APIUsageLog(Base):\n    \"\"\"\n    APIUsageLog model for tracking API usage\n    \"\"\"\n    __tablename__ = 'api_usage_logs'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    api_key_id = Column(Integer, ForeignKey('api_keys.id', ondelete='CASCADE'), nullable=False, index=True)\n    \n    # Request details\n    endpoint = Column(String(255), nullable=False)\n    method = Column(String(10), nullable=False)\n    status_code = Column(Integer, nullable=False)\n    response_time = Column(Float, nullable=True)  # in milliseconds\n    \n    # Usage tracking\n    tokens_used = Column(Integer, nullable=True)\n    characters_processed = Column(Integer, nullable=True)\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    \n    # Relationships\n    api_key = relationship('APIKey', back_populates='usage_logs')\n    \n    def __repr__(self):\n        return f\"<APIUsageLog(id={self.id}, endpoint='{self.endpoint}', status_code={self.status_code})>\"\n\n\nclass GenerationJob(Base):\n    \"\"\"\n    GenerationJob model for tracking AI generation tasks\n    \"\"\"\n    __tablename__ = 'generation_jobs'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    job_type = Column(String(50), nullable=False)  # 'page', 'character', 'batch'\n    status = Column(String(50), nullable=False, default='pending')\n    \n    # Job parameters\n    comic_id = Column(Integer, ForeignKey('comics.id', ondelete='CASCADE'), nullable=True, index=True)\n    page_id = Column(Integer, ForeignKey('pages.id', ondelete='CASCADE'), nullable=True, index=True)\n    \n    # Generation parameters\n    prompt = Column(Text, nullable=True)\n    negative_prompt = Column(Text, nullable=True)\n    model = Column(String(100), nullable=True)\n    params = Column(JSON, nullable=True)\n    \n    # Progress tracking\n    progress = Column(Integer, default=0)  # 0-100\n    current_step = Column(String(100), nullable=True)\n    \n    # Results\n    result = Column(JSON, nullable=True)\n    error_message = Column(Text, nullable=True)\n    \n    # Timing\n    started_at = Column(DateTime, nullable=True)\n    completed_at = Column(DateTime, nullable=True)\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    \n    def __repr__(self):\n        return f\"<GenerationJob(id={self.id}, type='{self.job_type}', status='{self.status}')>\"\n\n\nclass ComicTemplate(Base):\n    \"\"\"\n    ComicTemplate model for reusable comic layouts\n    \"\"\"\n    __tablename__ = 'comic_templates'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    name = Column(String(255), nullable=False)\n    slug = Column(String(255), unique=True, nullable=False)\n    description = Column(Text, nullable=True)\n    \n    # Template structure\n    layout_config = Column(JSON, nullable=False)  # page layouts, panel arrangements\n    default_style = Column(JSON, nullable=True)  # default styling\n    \n    # Usage\n    usage_count = Column(Integer, default=0)\n    is_public = Column(Boolean, default=False)\n    \n    # Ownership\n    creator_id = Column(Integer, ForeignKey('users.id'), nullable=True)\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow, nullable=False)\n    \n    def __repr__(self):\n        return f\"<ComicTemplate(id={self.id}, name='{self.name}')>\"\n\n\nclass ImageAsset(Base):\n    \"\"\"\n    ImageAsset model for storing reusable image assets\n    \"\"\"\n    __tablename__ = 'image_assets'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    name = Column(String(255), nullable=False)\n    asset_type = Column(String(50), nullable=False)  # 'background', 'character_base', 'prop', 'effect'\n    \n    # Storage\n    file_path = Column(String(500), nullable=False)\n    file_url = Column(String(500), nullable=True)\n    thumbnail_url = Column(String(500), nullable=True)\n    \n    # Metadata\n    width = Column(Integer, nullable=True)\n    height = Column(Integer, nullable=True)\n    file_size = Column(Integer, nullable=True)  # in bytes\n    format = Column(String(20), nullable=True)\n    \n    # Organization\n    tags = Column(JSON, nullable=True)\n    category = Column(String(100), nullable=True)\n    \n    # Ownership\n    creator_id = Column(Integer, ForeignKey('users.id'), nullable=True)\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow, nullable=False)\n    \n    def __repr__(self):\n        return f\"<ImageAsset(id={self.id}, name='{self.name}', type='{self.asset_type}')>\"\n\n\n# Function to initialize database\ndef init_db(engine):\n    \"\"\"Initialize database tables\"\"\"\n    Base.metadata.create_all(bind=engine)\n\n\n# Function to drop all tables (use with caution)\ndef drop_db(engine):\n    \"\"\"Drop all database tables\"\"\"\n    Base.metadata.drop_all(bind=engine)\nEOF\necho \"Models created successfully\""}, {"cmd": "cat > /opt/AiComic/app/database.py << 'EOF'\n\"\"\"\nDatabase Configuration and Session Management\nProvides database connection setup and session factory for SQLAlchemy\n\"\"\"\n\nfrom sqlalchemy import create_engine\nfrom sqlalchemy.orm import sessionmaker, scoped_session\nfrom sqlalchemy.pool import StaticPool\nimport os\nfrom typing import Generator\n\nfrom .config import Config\nfrom .models import Base\n\n\nclass Database:\n    \"\"\"\n    Database class for managing database connections and sessions\n    \"\"\"\n    \n    def __init__(self, config: Config = None):\n        \"\"\"Initialize database with configuration\"\"\"\n        self.config = config or Config()\n        self.engine = None\n        self.session_factory = None\n        self.ScopedSession = None\n        self._initialize_engine()\n    \n    def _initialize_engine(self):\n        \"\"\"Create database engine based on configuration\"\"\"\n        database_url = self.config.DATABASE_URL\n        \n        # Create engine with appropriate settings\n        if database_url.startswith('sqlite'):\n            # SQLite specific configuration\n            self.engine = create_engine(\n                database_url,\n                connect_args={\"check_same_thread\": False},\n                poolclass=StaticPool,\n                echo=self.config.DEBUG\n            )\n        else:\n            # PostgreSQL/MySQL configuration\n            self.engine = create_engine(\n                database_url,\n                pool_size=10,\n                max_overflow=20,\n                pool_pre_ping=True,\n                echo=self.config.DEBUG\n            )\n        \n        # Create session factory\n        self.session_factory = sessionmaker(bind=self.engine)\n        self.ScopedSession = scoped_session(self.session_factory)\n    \n    def create_tables(self):\n        \"\"\"Create all database tables\"\"\"\n        Base.metadata.create_all(bind=self.engine)\n    \n    def drop_tables(self):\n        \"\"\"Drop all database tables\"\"\"\n        Base.metadata.drop_all(bind=self.engine)\n    \n    def get_session(self):\n        \"\"\"Get a new database session\"\"\"\n        return self.session_factory()\n    \n    def get_scoped_session(self):\n        \"\"\"Get a scoped session\"\"\"\n        return self.ScopedSession()\n    \n    def close_session(self):\n        \"\"\"Close the current scoped session\"\"\"\n        if self.ScopedSession:\n            self.ScopedSession.remove()\n    \n    def dispose_engine(self):\n        \"\"\"Dispose the engine and all connections\"\"\"\n        if self.engine:\n            self.engine.dispose()\n\n\n# Global database instance\ndb = Database()\n\n\ndef get_db() -> Generator:\n    \"\"\"\n    Dependency injection function for getting database session\n    Yields a database session and ensures it's closed after use\n    \"\"\"\n    session = db.get_session()\n    try:\n        yield session\n        session.commit()\n    except Exception:\n        session.rollback()\n        raise\n    finally:\n        session.close()\n\n\ndef get_db_session():\n    \"\"\"\n    Get a database session without dependency injection\n    Remember to close the session after use\n    \"\"\"\n    return db.get_session()\n\n\ndef init_database():\n    \"\"\"\n    Initialize the database - create all tables\n    \"\"\"\n    db.create_tables()\n    return db\n\n\ndef reset_database():\n    \"\"\"\n    Reset the database - drop and recreate all tables\n    WARNING: This will delete all data!\n    \"\"\"\n    db.drop_tables()\n    db.create_tables()\n    return db\nEOF\necho \"Database module created successfully\""}, {"cmd": "cat > /opt/AiComic/app/config.py << 'EOF'\n\"\"\"\nConfiguration Module\nHandles application configuration and environment variables\n\"\"\"\n\nimport os\nfrom typing import Optional\nfrom dataclasses import dataclass\n\n\n@dataclass\nclass Config:\n    \"\"\"\n    Application configuration class\n    Loads configuration from environment variables with sensible defaults\n    \"\"\"\n    \n    # Database Configuration\n    DATABASE_URL: str = os.getenv(\n        'DATABASE_URL', \n        'sqlite:///./aicomic.db'\n    )\n    \n    # Application Settings\n    DEBUG: bool = os.getenv('DEBUG', 'False').lower() == 'true'\n    ENVIRONMENT: str = os.getenv('ENVIRONMENT', 'development')\n    SECRET_KEY: str = os.getenv('SECRET_KEY', 'your-secret-key-change-in-production')\n    \n    # API Settings\n    API_VERSION: str = 'v1'\n    API_PREFIX: str = f'/api/{API_VERSION}'\n    \n    # AI Model Settings\n    DEFAULT_AI_MODEL: str = os.getenv('DEFAULT_AI_MODEL', 'stable-diffusion-xl')\n    MAX_IMAGE_SIZE: int = int(os.getenv('MAX_IMAGE_SIZE', '2048'))\n    \n    # Rate Limiting\n    RATE_LIMIT_ENABLED: bool = True\n    DEFAULT_RATE_LIMIT: int = 100  # requests per minute\n    \n    # File Storage\n    UPLOAD_FOLDER: str = os.getenv('UPLOAD_FOLDER', './uploads')\n    MAX_CONTENT_LENGTH: int = 16 * 1024 * 1024  # 16MB max file size\n    ALLOWED_EXTENSIONS: set = {'png', 'jpg', 'jpeg', 'gif', 'webp'}\n    \n    # Pagination\n    DEFAULT_PAGE_SIZE: int = 20\n    MAX_PAGE_SIZE: int = 100\n    \n    # CORS Settings\n    CORS_ORIGINS: list = ['*']\n    \n    # Session Settings\n    SESSION_LIFETIME: int = 3600  # 1 hour in seconds\n    \n    # Redis (optional, for caching and job queues)\n    REDIS_URL: Optional[str] = os.getenv('REDIS_URL', None)\n    \n    # Email Settings (for notifications)\n    SMTP_HOST: Optional[str] = os.getenv('SMTP_HOST', None)\n    SMTP_PORT: int = int(os.getenv('SMTP_PORT', '587'))\n    SMTP_USER: Optional[str] = os.getenv('SMTP_USER', None)\n    SMTP_PASSWORD: Optional[str] = os.getenv('SMTP_PASSWORD', None)\n    \n    # Logging\n    LOG_LEVEL: str = os.getenv('LOG_LEVEL', 'INFO')\n    LOG_FORMAT: str = '%(asctime)s - %(name)s - %(levelname)s - %(message)s'\n    \n    def __post_init__(self):\n        \"\"\"Post-initialization processing\"\"\"\n        # Ensure upload folder exists\n        if not os.path.exists(self.UPLOAD_FOLDER):\n            os.makedirs(self.UPLOAD_FOLDER, exist_ok=True)\n    \n    def is_production(self) -> bool:\n        \"\"\"Check if running in production environment\"\"\"\n        return self.ENVIRONMENT == 'production'\n    \n    def is_development(self) -> bool:\n        \"\"\"Check if running in development environment\"\"\"\n        return self.ENVIRONMENT == 'development'\n    \n    def is_testing(self) -> bool:\n        \"\"\"Check if running in testing environment\"\"\"\n        return self.ENVIRONMENT == 'testing'\n\n\n# Create default config instance\nconfig = Config()\nEOF\necho \"Config module created successfully\""}, {"cmd": "ls -la /opt/AiComic/app/ && echo '---' && wc -l /opt/AiComic/app/models.py && echo '---' && head -50 /opt/AiComic/app/models.py"}, {"cmd": "cat > /opt/AiComic/app/__init__.py << 'EOF'\n\"\"\"\nAiComic Application Package\n\"\"\"\n\n__version__ = '1.0.0'\n__author__ = 'AiComic Team'\n\nfrom .config import config, Config\nfrom .database import db, get_db, init_database, reset_database\nfrom .models import (\n    Base,\n    Comic,\n    Page,\n    ContentBlock,\n    Character,\n    CharacterAppearance,\n    Genre,\n    Tag,\n    User,\n    APIKey,\n    APIUsageLog,\n    GenerationJob,\n    ComicTemplate,\n    ImageAsset,\n    ComicStatus,\n    PageStatus,\n    CharacterType,\n    init_db,\n    drop_db\n)\n\n__all__ = [\n    'config',\n    'Config',\n    'db',\n    'get_db',\n    'init_database',\n    'reset_database',\n    'Base',\n    'Comic',\n    'Page',\n    'ContentBlock',\n    'Character',\n    'CharacterAppearance',\n    'Genre',\n    'Tag',\n    'User',\n    'APIKey',\n    'APIUsageLog',\n    'GenerationJob',\n    'ComicTemplate',\n    'ImageAsset',\n    'ComicStatus',\n    'PageStatus',\n    'CharacterType',\n    'init_db',\n    'drop_db'\n]\nEOF\necho \"__init__.py created successfully\""}, {"cmd": "cd /opt/AiComic && python3 -c \"from app.models import *; print('Models imported successfully'); from app.models import Comic, Page, User; print(f'Comic table: {Comic.__tablename__}'); print(f'Page table: {Page.__tablename__}'); print(f'User table: {User.__tablename__}')\""}, {"cmd": "cat > /opt/AiComic/main.py << 'EOF'\n\"\"\"\nMain Application Entry Point\nDemonstrates database initialization and usage\n\"\"\"\n\nfrom app import init_database, config\nfrom app.models import Comic, Page, User, Genre, Tag, Character\nfrom app.database import get_db_session\nfrom datetime import datetime\nimport os\n\n\ndef main():\n    \"\"\"Main application function\"\"\"\n    print(f\"Initializing database in {config.ENVIRONMENT} mode...\")\n    \n    # Initialize database\n    db = init_database()\n    \n    # Create a session to test the models\n    session = get_db_session()\n    \n    try:\n        # Create a test user\n        test_user = User(\n            username='test_author',\n            email='test@example.com',\n            password_hash='hashed_password_here',\n            display_name='Test Author',\n            is_active=True\n        )\n        session.add(test_user)\n        session.flush()\n        \n        # Create a test comic\n        test_comic = Comic(\n            title='My First AI Comic',\n            slug='my-first-ai-comic',\n            description='A test comic created with AI',\n            author_id=test_user.id,\n            status='draft',\n            is_published=False\n        )\n        session.add(test_comic)\n        session.flush()\n        \n        # Create some pages\n        for i in range(1, 4):\n            page = Page(\n                comic_id=test_comic.id,\n                page_number=i,\n                title=f'Page {i}',\n                status='pending'\n            )\n            session.add(page)\n        \n        # Create genres\n        genre1 = Genre(name='Action', slug='action')\n        genre2 = Genre(name='Sci-Fi', slug='sci-fi')\n        session.add_all([genre1, genre2])\n        \n        # Create tags\n        tag1 = Tag(name='adventure', slug='adventure')\n        tag2 = Tag(name='robots', slug='robots')\n        session.add_all([tag1, tag2])\n        \n        # Create characters\n        character = Character(\n            name='Hero Bot',\n            slug='hero-bot',\n            description='A friendly robot hero',\n            character_type='protagonist'\n        )\n        session.add(character)\n        \n        # Commit all changes\n        session.commit()\n        \n        print(\"Database initialized successfully!\")\n        print(f\"Created user: {test_user.username}\")\n        print(f\"Created comic: {test_comic.title}\")\n        print(f\"Created {len(test_comic.pages)} pages\")\n        print(f\"Created genres: {genre1.name}, {genre2.name}\")\n        print(f\"Created tags: {tag1.name}, {tag2.name}\")\n        print(f\"Created character: {character.name}\")\n        \n    except Exception as e:\n        session.rollback()\n        print(f\"Error during initialization: {e}\")\n        raise\n    finally:\n        session.close()\n\n\nif __name__ == '__main__':\n    main()\nEOF\necho \"Main application created successfully\""}, {"cmd": "echo \"=== Project Structure ===\" && tree /opt/AiComic -L 3 -I '__pycache__|*.pyc' 2>/dev/null || find /opt/AiComic -type f -name \"*.py\" -o -name \"*.txt\" -o -name \"*.md\" | grep -v __pycache__ | sort"}, {"cmd": "cd /opt/AiComic && python3 -m py_compile app/models.py && python3 -m py_compile app/database.py && python3 -m py_compile app/config.py && python3 -m py_compile app/__init__.py && echo \"All Python files compiled successfully - no syntax errors\""}, {"cmd": "cat /opt/AiComic/app/models.py"}, {"cmd": "cat > /opt/AiComic/requirements.txt << 'EOF'\n# Core Dependencies\nSQLAlchemy>=2.0.0\nFlask>=2.3.0\nFlask-SQLAlchemy>=3.0.0\nFlask-Migrate>=4.0.0\n\n# Database Drivers\npsycopg2-binary>=2.9.0  # PostgreSQL\npymysql>=1.1.0\n\n# Server\ngunicorn>=21.0.0\n\n# API & Serialization\nmarshmallow>=3.20.0\nflask-restful>=0.3.10\n\n# Authentication\nFlask-JWT-Extended>=4.5.0\nbcrypt>=4.0.0\n\n# Configuration\npython-dotenv>=1.0.0\n\n# Utilities\npython-dateutil>=2.8.0\nPillow>=10.0.0\nrequests>=2.31.0\n\n# Testing\npytest>=7.4.0\npytest-cov>=4.1.0\nfactory-boy>=3.3.0\n\n# Development\nblack>=23.0.0\nflake8>=6.0.0\nmypy>=1.4.0\n\n# AI/ML (optional, for image generation)\n# torch>=2.0.0\n# diffusers>=0.18.0\n# transformers>=4.30.0\n\n# Redis (optional, for caching)\n# redis>=4.5.0\n# rq>=1.13.0\nEOF\necho \"Requirements file created successfully\""}, {"cmd": "cat > /opt/AiComic/README.md << 'EOF'\n# AiComic Database Models\n\n## Overview\nThis document describes the SQLAlchemy database models implemented for the AiComic application.\n\n## Models\n\n### Core Models\n\n#### Comic\nThe main entity representing a comic book or series.\n- **Fields**: id, title, slug, description, author_id, status, genre_ids, is_published, published_at, created_at, updated_at, ai_generation_prompt, ai_model_used, ai_generation_config\n- **Relationships**: pages, characters, author, genres, tags\n\n#### Page\nIndividual pages within a comic.\n- **Fields**: id, comic_id, page_number, title, image_url, image_path, thumbnail_url, status, generation_prompt, negative_prompt, ai_model, generation_params, processing_time, retry_count, error_message, created_at, updated_at, generated_at\n- **Relationships**: comic, content_blocks\n\n#### ContentBlock\nText/panels within a page.\n- **Fields**: id, page_id, block_type, x_position, y_position, width, height, content, style, created_at, updated_at\n- **Relationships**: page\n\n### Character Models\n\n#### Character\nCharacters appearing in comics.\n- **Fields**: id, name, slug, description, character_type, visual_prompt, default_appearance, created_at, updated_at\n- **Relationships**: comics, appearances\n\n#### CharacterAppearance\nTracks character appearances in specific pages.\n- **Fields**: id, character_id, page_id, position_x, position_y, scale, expression, pose, custom_prompt, created_at\n- **Relationships**: character, page\n\n### Categorization Models\n\n#### Genre\nComic genres for categorization.\n- **Fields**: id, name, slug, description, created_at\n- **Relationships**: comics\n\n#### Tag\nAdditional tags for comic categorization.\n- **Fields**: id, name, slug, usage_count, created_at\n- **Relationships**: comics\n\n### User & Authentication Models\n\n#### User\nComic creators/authors.\n- **Fields**: id, username, email, password_hash, display_name, bio, avatar_url, default_ai_model, generation_preferences, is_active, is_verified, created_at, updated_at, last_login\n- **Relationships**: comics, api_keys\n\n#### APIKey\nAPI authentication keys.\n- **Fields**: id, user_id, key_hash, name, permissions, rate_limit, is_active, expires_at, created_at, last_used\n- **Relationships**: user, usage_logs\n\n#### APIUsageLog\nTracks API usage.\n- **Fields**: id, api_key_id, endpoint, method, status_code, response_time, tokens_used, characters_processed, created_at\n- **Relationships**: api_key\n\n### Utility Models\n\n#### GenerationJob\nTracks AI generation tasks.\n- **Fields**: id, job_type, status, comic_id, page_id, prompt, negative_prompt, model, params, progress, current_step, result, error_message, started_at, completed_at, created_at\n\n#### ComicTemplate\nReusable comic layouts.\n- **Fields**: id, name, slug, description, layout_config, default_style, usage_count, is_public, creator_id, created_at, updated_at\n\n#### ImageAsset\nReusable image assets.\n- **Fields**: id, name, asset_type, file_path, file_url, thumbnail_url, width, height, file_size, format, tags, category, creator_id, created_at, updated_at\n\n## Usage\n\n### Initialize Database\n```python\nfrom app import init_database\ndb = init_database()\n```\n\n### Create a Session\n```python\nfrom app.database import get_db_session\nsession = get_db_session()\ntry:\n    # Use session\n    session.commit()\nexcept:\n    session.rollback()\nfinally:\n    session.close()\n```\n\n### Query Examples\n```python\n# Get all published comics\ncomics = session.query(Comic).filter_by(is_published=True).all()\n\n# Get user's comics\nuser_comics = session.query(Comic).filter_by(author_id=user_id).all()\n\n# Get comic with all related data\ncomic = session.query(Comic).filter_by(slug='my-comic').first()\nprint(f\"Pages: {len(comic.pages)}\")\nprint(f\"Characters: {len(comic.characters)}\")\nprint(f\"Genres: {[g.name for g in comic.genres]}\")\n```\n\n## Enumerations\n\n- **ComicStatus**: DRAFT, PROCESSING, COMPLETED, PUBLISHED, ARCHIVED\n- **PageStatus**: PENDING, GENERATING, COMPLETED, FAILED\n- **CharacterType**: PROTAGONIST, ANTAGONIST, SUPPORTING, MINOR\n\n## Database Initialization\n\nRun the application to automatically create all tables:\n```bash\npython main.py\n```\n\nThis will create the SQLite database file and populate it with test data.\nEOF\necho \"README created successfully\""}, {"cmd": "cd /opt/AiComic && python3 -c \"\nfrom app import (\n    Comic, Page, ContentBlock, Character, CharacterAppearance,\n    Genre, Tag, User, APIKey, APIUsageLog, GenerationJob,\n    ComicTemplate, ImageAsset, ComicStatus, PageStatus, CharacterType,\n    Base\n)\n\n# Verify all models are properly configured\nmodels = [\n    ('Comic', Comic),\n    ('Page', Page),\n    ('ContentBlock', ContentBlock),\n    ('Character', Character),\n    ('CharacterAppearance', CharacterAppearance),\n    ('Genre', Genre),\n    ('Tag', Tag),\n    ('User', User),\n    ('APIKey', APIKey),\n    ('APIUsageLog', APIUsageLog),\n    ('GenerationJob', GenerationJob),\n    ('ComicTemplate', ComicTemplate),\n    ('ImageAsset', ImageAsset)\n]\n\nprint('Database Models Verification:')\nprint('=' * 50)\nfor name, model in models:\n    table_name = model.__tablename__\n    columns = [c.name for c in model.__table__.columns]\n    print(f'{name:25} -> {table_name:20} ({len(columns)} columns)')\n\nprint('=' * 50)\nprint(f'Total models: {len(models)}')\nprint('All models imported and verified successfully!')\n\""}, {"cmd": "cat > /opt/AiComic/DATABASE_SCHEMA.md << 'EOF'\n# AiComic Database Schema\n\n## Entity Relationship Overview\n\n```\nUser (1) u2500u2500u2500u2500u2500u2500< Comic (M)\n  u2502                u2502\n  u2502                u251cu2500u2500u2500u2500< Page (M)\n  u2502                u2502       u2502\n  u2502                u2502       u2514u2500u2500u2500u2500< ContentBlock (M)\n  u2502                u2502\n  u2502                u251cu2500u2500u2500u2500< ComicGenre (M-M)\n  u2502                u2502       u2502\n  u2502                u2502       u2514u2500u2500u2500u2500 Genre (1)\n  u2502                u2502\n  u2502                u251cu2500u2500u2500u2500< ComicTag (M-M)\n  u2502                u2502       u2502\n  u2502                u2502       u2514u2500u2500u2500u2500 Tag (1)\n  u2502                u2502\n  u2502                u2514u2500u2500u2500u2500< ComicCharacter (M-M)\nu2502                        u2502\nu2502                        u2514u2500u2500u2500u2500 Character (1)\nu2502                                u2502\nu2502                                u2514u2500u2500u2500u2500< CharacterAppearance (M)\nu2502                                        u2502\nu2502                                        u2514u2500u2500u2500u2500 Page (1)\nu2502\nu2514u2500u2500u2500u2500< APIKey (M)\n        u2502\n        u2514u2500u2500u2500u2500< APIUsageLog (M)\n```\n\n## Tables\n\n### 1. users\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| username | VARCHAR(100) | NOT NULL, UNIQUE, INDEX |\n| email | VARCHAR(255) | NOT NULL, UNIQUE, INDEX |\n| password_hash | VARCHAR(255) | NOT NULL |\n| display_name | VARCHAR(255) | NULLABLE |\n| bio | TEXT | NULLABLE |\n| avatar_url | VARCHAR(500) | NULLABLE |\n| default_ai_model | VARCHAR(100) | NULLABLE |\n| generation_preferences | JSON | NULLABLE |\n| is_active | BOOLEAN | NOT NULL, DEFAULT TRUE |\n| is_verified | BOOLEAN | NOT NULL, DEFAULT FALSE |\n| created_at | DATETIME | NOT NULL |\n| updated_at | DATETIME | NOT NULL |\n| last_login | DATETIME | NULLABLE |\n\n### 2. comics\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| title | VARCHAR(255) | NOT NULL, INDEX |\n| slug | VARCHAR(255) | NOT NULL, UNIQUE, INDEX |\n| description | TEXT | NULLABLE |\n| author_id | INTEGER | FOREIGN KEY -> users.id, NOT NULL, INDEX |\n| status | ENUM | NOT NULL, DEFAULT 'draft' |\n| genre_ids | JSON | NULLABLE |\n| is_published | BOOLEAN | NOT NULL, DEFAULT FALSE |\n| published_at | DATETIME | NULLABLE |\n| created_at | DATETIME | NOT NULL |\n| updated_at | DATETIME | NOT NULL |\n| ai_generation_prompt | TEXT | NULLABLE |\n| ai_model_used | VARCHAR(100) | NULLABLE |\n| ai_generation_config | JSON | NULLABLE |\n\n### 3. pages\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| comic_id | INTEGER | FOREIGN KEY -> comics.id (CASCADE), NOT NULL, INDEX |\n| page_number | INTEGER | NOT NULL |\n| title | VARCHAR(255) | NULLABLE |\n| image_url | VARCHAR(500) | NULLABLE |\n| image_path | VARCHAR(500) | NULLABLE |\n| thumbnail_url | VARCHAR(500) | NULLABLE |\n| status | ENUM | NOT NULL, DEFAULT 'pending' |\n| generation_prompt | TEXT | NULLABLE |\n| negative_prompt | TEXT | NULLABLE |\n| ai_model | VARCHAR(100) | NULLABLE |\n| generation_params | JSON | NULLABLE |\n| processing_time | FLOAT | NULLABLE |\n| retry_count | INTEGER | DEFAULT 0 |\n| error_message | TEXT | NULLABLE |\n| created_at | DATETIME | NOT NULL |\n| updated_at | DATETIME | NOT NULL |\n| generated_at | DATETIME | NULLABLE |\n\n### 4. content_blocks\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| page_id | INTEGER | FOREIGN KEY -> pages.id (CASCADE), NOT NULL, INDEX |\n| block_type | VARCHAR(50) | NOT NULL |\n| x_position | FLOAT | NOT NULL |\n| y_position | FLOAT | NOT NULL |\n| width | FLOAT | NOT NULL |\n| height | FLOAT | NOT NULL |\n| content | TEXT | NULLABLE |\n| style | JSON | NULLABLE |\n| created_at | DATETIME | NOT NULL |\n| updated_at | DATETIME | NOT NULL |\n\n### 5. characters\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| name | VARCHAR(255) | NOT NULL, INDEX |\n| slug | VARCHAR(255) | NOT NULL, UNIQUE |\n| description | TEXT | NULLABLE |\n| character_type | ENUM | DEFAULT 'supporting' |\n| visual_prompt | TEXT | NULLABLE |\n| default_appearance | JSON | NULLABLE |\n| created_at | DATETIME | NOT NULL |\n| updated_at | DATETIME | NOT NULL |\n\n### 6. character_appearances\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| character_id | INTEGER | FOREIGN KEY -> characters.id (CASCADE), NOT NULL, INDEX |\n| page_id | INTEGER | FOREIGN KEY -> pages.id (CASCADE), NOT NULL, INDEX |\n| position_x | FLOAT | NOT NULL |\n| position_y | FLOAT | NOT NULL |\n| scale | FLOAT | DEFAULT 1.0 |\n| expression | VARCHAR(100) | NULLABLE |\n| pose | VARCHAR(100) | NULLABLE |\n| custom_prompt | TEXT | NULLABLE |\n| created_at | DATETIME | NOT NULL |\n\n### 7. genres\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| name | VARCHAR(100) | NOT NULL, UNIQUE, INDEX |\n| slug | VARCHAR(100) | NOT NULL, UNIQUE |\n| description | TEXT | NULLABLE |\n| created_at | DATETIME | NOT NULL |\n\n### 8. tags\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| name | VARCHAR(100) | NOT NULL, UNIQUE, INDEX |\n| slug | VARCHAR(100) | NOT NULL, UNIQUE |\n| usage_count | INTEGER | DEFAULT 0 |\n| created_at | DATETIME | NOT NULL |\n\n### 9. comic_genres (Association Table)\n| Column | Type | Constraints |\n|--------|------|-------------|\n| comic_id | INTEGER | FOREIGN KEY -> comics.id, PRIMARY KEY |\n| genre_id | INTEGER | FOREIGN KEY -> genres.id, PRIMARY KEY |\n| created_at | DATETIME | DEFAULT NOW |\n\n### 10. comic_tags (Association Table)\n| Column | Type | Constraints |\n|--------|------|-------------|\n| comic_id | INTEGER | FOREIGN KEY -> comics.id, PRIMARY KEY |\n| tag_id | INTEGER | FOREIGN KEY -> tags.id, PRIMARY KEY |\n\n### 11. comic_characters (Association Table)\n| Column | Type | Constraints |\n|--------|------|-------------|\n| comic_id | INTEGER | FOREIGN KEY -> comics.id, PRIMARY KEY |\n| character_id | INTEGER | FOREIGN KEY -> characters.id, PRIMARY KEY |\n| role | VARCHAR(50) | DEFAULT 'supporting' |\n| appearance_order | INTEGER | DEFAULT 0 |\n\n### 12. api_keys\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| user_id | INTEGER | FOREIGN KEY -> users.id (CASCADE), NOT NULL, INDEX |\n| key_hash | VARCHAR(255) | NOT NULL, UNIQUE |\n| name | VARCHAR(100) | NOT NULL |\n| permissions | JSON | NULLABLE |\n| rate_limit | INTEGER | DEFAULT 100 |\n| is_active | BOOLEAN | NOT NULL, DEFAULT TRUE |\n| expires_at | DATETIME | NULLABLE |\n| created_at | DATETIME | NOT NULL |\n| last_used | DATETIME | NULLABLE |\n\n### 13. api_usage_logs\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| api_key_id | INTEGER | FOREIGN KEY -> api_keys.id (CASCADE), NOT NULL, INDEX |\n| endpoint | VARCHAR(255) | NOT NULL |\n| method | VARCHAR(10) | NOT NULL |\n| status_code | INTEGER | NOT NULL |\n| response_time | FLOAT | NULLABLE |\n| tokens_used | INTEGER | NULLABLE |\n| characters_processed | INTEGER | NULLABLE |\n| created_at | DATETIME | NOT NULL |\n\n### 14. generation_jobs\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| job_type | VARCHAR(50) | NOT NULL |\n| status | VARCHAR(50) | NOT NULL, DEFAULT 'pending' |\n| comic_id | INTEGER | FOREIGN KEY -> comics.id (CASCADE), INDEX |\n| page_id | INTEGER | FOREIGN KEY -> pages.id (CASCADE), INDEX |\n| prompt | TEXT | NULLABLE |\n| negative_prompt | TEXT | NULLABLE |\n| model | VARCHAR(100) | NULLABLE |\n| params | JSON | NULLABLE |\n| progress | INTEGER | DEFAULT 0 |\n| current_step | VARCHAR(100) | NULLABLE |\n| result | JSON | NULLABLE |\n| error_message | TEXT | NULLABLE |\n| started_at | DATETIME | NULLABLE |\n| completed_at | DATETIME | NULLABLE |\n| created_at | DATETIME | NOT NULL |\n\n### 15. comic_templates\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| name | VARCHAR(255) | NOT NULL |\n| slug | VARCHAR(255) | NOT NULL, UNIQUE |\n| description | TEXT | NULLABLE |\n| layout_config | JSON | NOT NULL |\n| default_style | JSON | NULLABLE |\n| usage_count | INTEGER | DEFAULT 0 |\n| is_public | BOOLEAN | DEFAULT FALSE |\n| creator_id | INTEGER | FOREIGN KEY -> users.id |\n| created_at | DATETIME | NOT NULL |\n| updated_at | DATETIME | NOT NULL |\n\n### 16. image_assets\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| name | VARCHAR(255) | NOT NULL |\n| asset_type | VARCHAR(50) | NOT NULL |\n| file_path | VARCHAR(500) | NOT NULL |\n| file_url | VARCHAR(500) | NULLABLE |\n| thumbnail_url | VARCHAR(500) | NULLABLE |\n| width | INTEGER | NULLABLE |\n| height | INTEGER | NULLABLE |\n| file_size | INTEGER | NULLABLE |\n| format | VARCHAR(20) | NULLABLE |\n| tags | JSON | NULLABLE |\n| category | VARCHAR(100) | NULLABLE |\n| creator_id | INTEGER | FOREIGN KEY -> users.id |\n| created_at | DATETIME | NOT NULL |\n| updated_at | DATETIME | NOT NULL |\n\n## Indexes\n\n### Automatic Indexes (Primary Keys)\n- All tables have primary key indexes on `id`\n\n### Additional Indexes\n- `users.username` - UNIQUE INDEX\n- `users.email` - UNIQUE INDEX\n- `comics.title` - INDEX\n- `comics.slug` - UNIQUE INDEX\n- `comics.author_id` - INDEX\n- `pages.comic_id` - INDEX\n- `content_blocks.page_id` - INDEX\n- `characters.name` - INDEX\n- `characters.slug` - UNIQUE INDEX\n- `character_appearances.character_id` - INDEX\n- `character_appearances.page_id` - INDEX\n- `genres.name` - UNIQUE INDEX\n- `genres.slug` - UNIQUE INDEX\n- `tags.name` - UNIQUE INDEX\n- `tags.slug` - UNIQUE INDEX\n- `api_keys.user_id` - INDEX\n- `api_usage_logs.api_key_id` - INDEX\n- `generation_jobs.comic_id` - INDEX\n- `generation_jobs.page_id` - INDEX\n\n## Enumerations\n\n### ComicStatus\n- `draft` - Comic is being created\n- `processing` - AI generation in progress\n- `completed` - All pages generated\n- `published` - Publicly available\n- `archived` - No longer active\n\n### PageStatus\n- `pending` - Not yet generated\n- `generating` - AI generation in progress\n- `completed` - Successfully generated\n- `failed` - Generation failed\n\n### CharacterType\n- `protagonist` - Main hero\n- `antagonist` - Main villain\n- `supporting` - Supporting character\n- `minor` - Background/minor character\n\n## Relationships Summary\n\n1. **User -> Comic**: One-to-Many (author can have many comics)\n2. **Comic -> Page**: One-to-Many (comic has many pages)\n3. **Page -> ContentBlock**: One-to-Many (page has many content blocks)\n4. **Comic <-> Genre**: Many-to-Many (comic can have multiple genres)\n5. **Comic <-> Tag**: Many-to-Many (comic can have multiple tags)\n6. **Comic <-> Character**: Many-to-Many (comic can have multiple characters)\n7. **Character -> CharacterAppearance**: One-to-Many (character appears in many pages)\n8. **Page -> CharacterAppearance**: One-to-Many (page has many character appearances)\n9. **User -> APIKey**: One-to-Many (user can have many API keys)\n10. **APIKey -> APIUsageLog**: One-to-Many (API key usage history)\nEOF\necho \"Database schema documentation created successfully\""}, {"cmd": "echo \"========================================\" && echo \"DATABASE MODELS IMPLEMENTATION COMPLETE\" && echo \"========================================\" && echo \"\" && echo \"Files Created:\" && ls -lh /opt/AiComic/app/*.py /opt/AiComic/*.txt /opt/AiComic/*.md 2>/dev/null | grep -v \"^d\" && echo \"\" && echo \"Model Summary:\" && cd /opt/AiComic && python3 << 'PYEOF'\nfrom app.models import (\n    Comic, Page, ContentBlock, Character, CharacterAppearance,\n    Genre, Tag, User, APIKey, APIUsageLog, GenerationJob,\n    ComicTemplate, ImageAsset, ComicStatus, PageStatus, CharacterType\n)\n\nmodels_info = [\n    (\"Comic\", Comic, \"Main comic entity with AI generation support\"),\n    (\"Page\", Page, \"Individual comic pages with generation status\"),\n    (\"ContentBlock\", ContentBlock, \"Text/panels within pages\"),\n    (\"Character\", Character, \"Comic characters with visual prompts\"),\n    (\"CharacterAppearance\", CharacterAppearance, \"Character placements in pages\"),\n    (\"Genre\", Genre, \"Comic categorization\"),\n    (\"Tag\", Tag, \"Additional comic tags\"),\n    (\"User\", User, \"Comic authors/creators\"),\n    (\"APIKey\", APIKey, \"User authentication keys\"),\n    (\"APIUsageLog\", APIUsageLog, \"API usage tracking\"),\n    (\"GenerationJob\", GenerationJob, \"AI generation job queue\"),\n    (\"ComicTemplate\", ComicTemplate, \"Reusable comic layouts\"),\n    (\"ImageAsset\", ImageAsset, \"Reusable image assets\")\n]\n\nfor i, (name, model, description) in enumerate(models_info, 1):\n    columns = len(model.__table__.columns)\n    print(f\"{i:2}. {name:25} ({columns:2} columns) - {description}\")\n\nprint(\"\\nAssociation Tables:\")\nprint(\"  14. comic_genres    - Many-to-Many Comic<->Genre\")\nprint(\"  15. comic_tags      - Many-to-Many Comic<->Tag\")\nprint(\"  16. comic_characters - Many-to-Many Comic<->Character\")\n\nprint(\"\\nEnumerations:\")\nprint(f\"  - ComicStatus: {[s.value for s in ComicStatus]}\")\nprint(f\"  - PageStatus: {[s.value for s in PageStatus]}\")\nprint(f\"  - CharacterType: {[s.value for s in CharacterType]}\")\n\nprint(\"\\nTotal: 13 models + 3 association tables + 3 enumerations\")\nPYEOF"}][0m
[94mRepaired JSON: [{"cmd": "find /opt/AiComic -type f -name \"*.py\" | head -30 && echo '---' && ls -la /opt/AiComic"}, {"cmd": "ls -la /opt/AiComic && echo '---' && ls -la /opt/AiComic/app 2>/dev/null || echo 'No app directory'"}, {"cmd": "find /opt/AiComic -type d -name \"*model*\" -o -type d -name \"*database*\" 2>/dev/null && echo '---' && cat /opt/AiComic/app/models.py 2>/dev/null || cat /opt/AiComic/app/models/*.py 2>/dev/null || echo 'No models found'"}, {"cmd": "cat /opt/AiComic/requirements.txt 2>/dev/null && echo '---' && cat /opt/AiComic/app/__init__.py 2>/dev/null"}, {"cmd": "tree /opt/AiComic -L 3 -I '__pycache__|*.pyc' 2>/dev/null || find /opt/AiComic -type f -name \"*.py\" | grep -E \"(model|db|database|config)\" | head -20"}, {"cmd": "grep -r \"SQLAlchemy\\|declarative_base\\|Column\\|Integer\\|String\" /opt/AiComic --include=\"*.py\" 2>/dev/null | head -30"}, {"cmd": "cat /opt/AiComic/config.py 2>/dev/null || cat /opt/AiComic/app/config.py 2>/dev/null || cat /opt/AiComic/settings.py 2>/dev/null || find /opt/AiComic -name \"config*.py\" -o -name \"settings*.py\" | xargs cat 2>/dev/null"}, {"cmd": "ls -laR /opt/AiComic/app/ 2>/dev/null | head -50"}, {"cmd": "cat /opt/AiComic/app/database.py 2>/dev/null || cat /opt/AiComic/app/db.py 2>/dev/null || find /opt/AiComic -name \"database.py\" -o -name \"db.py\" | xargs cat 2>/dev/null"}, {"cmd": "cat /opt/AiComic/main.py 2>/dev/null || cat /opt/AiComic/app/main.py 2>/dev/null || find /opt/AiComic -name \"main.py\" | xargs cat 2>/dev/null"}, {"cmd": "cat > /opt/AiComic/app/models.py << 'EOF'\n\"\"\"\nDatabase Models for AiComic Application\nImplements SQLAlchemy ORM models for the comic management system\n\"\"\"\n\nfrom datetime import datetime\nfrom typing import Optional\nfrom sqlalchemy import (\n    Column, Integer, String, Text, DateTime, Boolean, \n    ForeignKey, Float, Enum as SQLEnum, Table, JSON\n)\nfrom sqlalchemy.orm import relationship, declarative_base\nimport enum\n\nBase = declarative_base()\n\n\nclass ComicStatus(enum.Enum):\n    \"\"\"Comic status enumeration\"\"\"\n    DRAFT = \"draft\"\n    PROCESSING = \"processing\"\n    COMPLETED = \"completed\"\n    PUBLISHED = \"published\"\n    ARCHIVED = \"archived\"\n\n\nclass PageStatus(enum.Enum):\n    \"\"\"Page status enumeration\"\"\"\n    PENDING = \"pending\"\n    GENERATING = \"generating\"\n    COMPLETED = \"completed\"\n    FAILED = \"failed\"\n\n\nclass CharacterType(enum.Enum):\n    \"\"\"Character type enumeration\"\"\"\n    PROTAGONIST = \"protagonist\"\n    ANTAGONIST = \"antagonist\"\n    SUPPORTING = \"supporting\"\n    MINOR = \"minor\"\n\n\n# Association tables for many-to-many relationships\ncomic_genres = Table(\n    'comic_genres',\n    Base.metadata,\n    Column('comic_id', Integer, ForeignKey('comics.id'), primary_key=True),\n    Column('genre_id', Integer, ForeignKey('genres.id'), primary_key=True),\n    Column('created_at', DateTime, default=datetime.utcnow)\n)\n\ncomic_characters = Table(\n    'comic_characters',\n    Base.metadata,\n    Column('comic_id', Integer, ForeignKey('comics.id'), primary_key=True),\n    Column('character_id', Integer, ForeignKey('characters.id'), primary_key=True),\n    Column('role', String(50), default='supporting'),\n    Column('appearance_order', Integer, default=0)\n)\n\ncomic_tags = Table(\n    'comic_tags',\n    Base.metadata,\n    Column('comic_id', Integer, ForeignKey('comics.id'), primary_key=True),\n    Column('tag_id', Integer, ForeignKey('tags.id'), primary_key=True)\n)\n\n\nclass Comic(Base):\n    \"\"\"\n    Comic model representing a complete comic book or series\n    \"\"\"\n    __tablename__ = 'comics'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    title = Column(String(255), nullable=False, index=True)\n    slug = Column(String(255), unique=True, nullable=False, index=True)\n    description = Column(Text, nullable=True)\n    author_id = Column(Integer, ForeignKey('users.id'), nullable=False, index=True)\n    status = Column(SQLEnum(ComicStatus), default=ComicStatus.DRAFT, nullable=False)\n    \n    # Comic metadata\n    genre_ids = Column(JSON, nullable=True)  # Store genre information\n    tags = relationship('Tag', secondary=comic_tags, back_populates='comics')\n    genres = relationship('Genre', secondary=comic_genres, back_populates='comics')\n    \n    # Publishing information\n    is_published = Column(Boolean, default=False, nullable=False)\n    published_at = Column(DateTime, nullable=True)\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow, nullable=False)\n    \n    # Relationships\n    pages = relationship('Page', back_populates='comic', cascade='all, delete-orphan', order_by='Page.page_number')\n    characters = relationship('Character', secondary=comic_characters, back_populates='comics')\n    author = relationship('User', back_populates='comics')\n    \n    # AI Generation metadata\n    ai_generation_prompt = Column(Text, nullable=True)\n    ai_model_used = Column(String(100), nullable=True)\n    ai_generation_config = Column(JSON, nullable=True)\n    \n    def __repr__(self):\n        return f\"<Comic(id={self.id}, title='{self.title}', status='{self.status.value}')>\"\n    \n    def to_dict(self):\n        return {\n            'id': self.id,\n            'title': self.title,\n            'slug': self.slug,\n            'description': self.description,\n            'author_id': self.author_id,\n            'status': self.status.value,\n            'is_published': self.is_published,\n            'published_at': self.published_at.isoformat() if self.published_at else None,\n            'created_at': self.created_at.isoformat() if self.created_at else None,\n            'updated_at': self.updated_at.isoformat() if self.updated_at else None,\n            'page_count': len(self.pages) if self.pages else 0,\n            'ai_model_used': self.ai_model_used\n        }\n\n\nclass Page(Base):\n    \"\"\"\n    Page model representing individual pages in a comic\n    \"\"\"\n    __tablename__ = 'pages'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    comic_id = Column(Integer, ForeignKey('comics.id', ondelete='CASCADE'), nullable=False, index=True)\n    page_number = Column(Integer, nullable=False)\n    title = Column(String(255), nullable=True)\n    \n    # Image data\n    image_url = Column(String(500), nullable=True)\n    image_path = Column(String(500), nullable=True)\n    thumbnail_url = Column(String(500), nullable=True)\n    \n    # AI Generation\n    status = Column(SQLEnum(PageStatus), default=PageStatus.PENDING, nullable=False)\n    generation_prompt = Column(Text, nullable=True)\n    negative_prompt = Column(Text, nullable=True)\n    ai_model = Column(String(100), nullable=True)\n    generation_params = Column(JSON, nullable=True)\n    \n    # Processing\n    processing_time = Column(Float, nullable=True)  # in seconds\n    retry_count = Column(Integer, default=0)\n    error_message = Column(Text, nullable=True)\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow, nullable=False)\n    generated_at = Column(DateTime, nullable=True)\n    \n    # Relationships\n    comic = relationship('Comic', back_populates='pages')\n    content_blocks = relationship('ContentBlock', back_populates='page', cascade='all, delete-orphan')\n    \n    def __repr__(self):\n        return f\"<Page(id={self.id}, comic_id={self.comic_id}, page_number={self.page_number}, status='{self.status.value}')>\"\n    \n    def to_dict(self):\n        return {\n            'id': self.id,\n            'comic_id': self.comic_id,\n            'page_number': self.page_number,\n            'title': self.title,\n            'image_url': self.image_url,\n            'thumbnail_url': self.thumbnail_url,\n            'status': self.status.value,\n            'generation_prompt': self.generation_prompt,\n            'ai_model': self.ai_model,\n            'processing_time': self.processing_time,\n            'error_message': self.error_message,\n            'created_at': self.created_at.isoformat() if self.created_at else None,\n            'generated_at': self.generated_at.isoformat() if self.generated_at else None\n        }\n\n\nclass ContentBlock(Base):\n    \"\"\"\n    ContentBlock model representing text/panels within a page\n    \"\"\"\n    __tablename__ = 'content_blocks'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    page_id = Column(Integer, ForeignKey('pages.id', ondelete='CASCADE'), nullable=False, index=True)\n    \n    # Block positioning\n    block_type = Column(String(50), nullable=False)  # 'text', 'speech', 'narrative', 'panel'\n    x_position = Column(Float, nullable=False, default=0)\n    y_position = Column(Float, nullable=False, default=0)\n    width = Column(Float, nullable=False, default=100)\n    height = Column(Float, nullable=False, default=100)\n    \n    # Content\n    content = Column(Text, nullable=True)\n    style = Column(JSON, nullable=True)  # font, color, size, etc.\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow, nullable=False)\n    \n    # Relationships\n    page = relationship('Page', back_populates='content_blocks')\n    \n    def __repr__(self):\n        return f\"<ContentBlock(id={self.id}, page_id={self.page_id}, type='{self.block_type}')>\"\n\n\nclass Character(Base):\n    \"\"\"\n    Character model representing characters in comics\n    \"\"\"\n    __tablename__ = 'characters'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    name = Column(String(255), nullable=False, index=True)\n    slug = Column(String(255), unique=True, nullable=False)\n    description = Column(Text, nullable=True)\n    character_type = Column(SQLEnum(CharacterType), default=CharacterType.SUPPORTING)\n    \n    # Visual description for AI\n    visual_prompt = Column(Text, nullable=True)\n    default_appearance = Column(JSON, nullable=True)  # style, colors, features\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow, nullable=False)\n    \n    # Relationships\n    comics = relationship('Comic', secondary=comic_characters, back_populates='characters')\n    appearances = relationship('CharacterAppearance', back_populates='character', cascade='all, delete-orphan')\n    \n    def __repr__(self):\n        return f\"<Character(id={self.id}, name='{self.name}', type='{self.character_type.value}')>\"\n\n\nclass CharacterAppearance(Base):\n    \"\"\"\n    CharacterAppearance model tracking character appearances in pages\n    \"\"\"\n    __tablename__ = 'character_appearances'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    character_id = Column(Integer, ForeignKey('characters.id', ondelete='CASCADE'), nullable=False, index=True)\n    page_id = Column(Integer, ForeignKey('pages.id', ondelete='CASCADE'), nullable=False, index=True)\n    \n    # Appearance details\n    position_x = Column(Float, nullable=False, default=0)\n    position_y = Column(Float, nullable=False, default=0)\n    scale = Column(Float, default=1.0)\n    expression = Column(String(100), nullable=True)\n    pose = Column(String(100), nullable=True)\n    \n    # Customization for this appearance\n    custom_prompt = Column(Text, nullable=True)\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    \n    # Relationships\n    character = relationship('Character', back_populates='appearances')\n    page = relationship('Page')\n    \n    def __repr__(self):\n        return f\"<CharacterAppearance(id={self.id}, character_id={self.character_id}, page_id={self.page_id})>\"\n\n\nclass Genre(Base):\n    \"\"\"\n    Genre model for categorizing comics\n    \"\"\"\n    __tablename__ = 'genres'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    name = Column(String(100), nullable=False, unique=True, index=True)\n    slug = Column(String(100), unique=True, nullable=False)\n    description = Column(Text, nullable=True)\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    \n    # Relationships\n    comics = relationship('Comic', secondary=comic_genres, back_populates='genres')\n    \n    def __repr__(self):\n        return f\"<Genre(id={self.id}, name='{self.name}')>\"\n\n\nclass Tag(Base):\n    \"\"\"\n    Tag model for additional comic categorization\n    \"\"\"\n    __tablename__ = 'tags'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    name = Column(String(100), nullable=False, unique=True, index=True)\n    slug = Column(String(100), unique=True, nullable=False)\n    usage_count = Column(Integer, default=0)\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    \n    # Relationships\n    comics = relationship('Comic', secondary=comic_tags, back_populates='tags')\n    \n    def __repr__(self):\n        return f\"<Tag(id={self.id}, name='{self.name}')>\"\n\n\nclass User(Base):\n    \"\"\"\n    User model for comic creators/authors\n    \"\"\"\n    __tablename__ = 'users'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    username = Column(String(100), nullable=False, unique=True, index=True)\n    email = Column(String(255), nullable=False, unique=True, index=True)\n    password_hash = Column(String(255), nullable=False)\n    \n    # Profile information\n    display_name = Column(String(255), nullable=True)\n    bio = Column(Text, nullable=True)\n    avatar_url = Column(String(500), nullable=True)\n    \n    # User preferences\n    default_ai_model = Column(String(100), nullable=True)\n    generation_preferences = Column(JSON, nullable=True)\n    \n    # Status\n    is_active = Column(Boolean, default=True, nullable=False)\n    is_verified = Column(Boolean, default=False, nullable=False)\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow, nullable=False)\n    last_login = Column(DateTime, nullable=True)\n    \n    # Relationships\n    comics = relationship('Comic', back_populates='author', cascade='all, delete-orphan')\n    api_keys = relationship('APIKey', back_populates='user', cascade='all, delete-orphan')\n    \n    def __repr__(self):\n        return f\"<User(id={self.id}, username='{self.username}')>\"\n\n\nclass APIKey(Base):\n    \"\"\"\n    APIKey model for user authentication\n    \"\"\"\n    __tablename__ = 'api_keys'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    user_id = Column(Integer, ForeignKey('users.id', ondelete='CASCADE'), nullable=False, index=True)\n    key_hash = Column(String(255), nullable=False, unique=True)\n    name = Column(String(100), nullable=False)\n    \n    # Permissions\n    permissions = Column(JSON, nullable=True)\n    rate_limit = Column(Integer, default=100)  # requests per minute\n    \n    # Status\n    is_active = Column(Boolean, default=True, nullable=False)\n    expires_at = Column(DateTime, nullable=True)\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    last_used = Column(DateTime, nullable=True)\n    \n    # Relationships\n    user = relationship('User', back_populates='api_keys')\n    usage_logs = relationship('APIUsageLog', back_populates='api_key', cascade='all, delete-orphan')\n    \n    def __repr__(self):\n        return f\"<APIKey(id={self.id}, name='{self.name}', user_id={self.user_id})>\"\n\n\nclass APIUsageLog(Base):\n    \"\"\"\n    APIUsageLog model for tracking API usage\n    \"\"\"\n    __tablename__ = 'api_usage_logs'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    api_key_id = Column(Integer, ForeignKey('api_keys.id', ondelete='CASCADE'), nullable=False, index=True)\n    \n    # Request details\n    endpoint = Column(String(255), nullable=False)\n    method = Column(String(10), nullable=False)\n    status_code = Column(Integer, nullable=False)\n    response_time = Column(Float, nullable=True)  # in milliseconds\n    \n    # Usage tracking\n    tokens_used = Column(Integer, nullable=True)\n    characters_processed = Column(Integer, nullable=True)\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    \n    # Relationships\n    api_key = relationship('APIKey', back_populates='usage_logs')\n    \n    def __repr__(self):\n        return f\"<APIUsageLog(id={self.id}, endpoint='{self.endpoint}', status_code={self.status_code})>\"\n\n\nclass GenerationJob(Base):\n    \"\"\"\n    GenerationJob model for tracking AI generation tasks\n    \"\"\"\n    __tablename__ = 'generation_jobs'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    job_type = Column(String(50), nullable=False)  # 'page', 'character', 'batch'\n    status = Column(String(50), nullable=False, default='pending')\n    \n    # Job parameters\n    comic_id = Column(Integer, ForeignKey('comics.id', ondelete='CASCADE'), nullable=True, index=True)\n    page_id = Column(Integer, ForeignKey('pages.id', ondelete='CASCADE'), nullable=True, index=True)\n    \n    # Generation parameters\n    prompt = Column(Text, nullable=True)\n    negative_prompt = Column(Text, nullable=True)\n    model = Column(String(100), nullable=True)\n    params = Column(JSON, nullable=True)\n    \n    # Progress tracking\n    progress = Column(Integer, default=0)  # 0-100\n    current_step = Column(String(100), nullable=True)\n    \n    # Results\n    result = Column(JSON, nullable=True)\n    error_message = Column(Text, nullable=True)\n    \n    # Timing\n    started_at = Column(DateTime, nullable=True)\n    completed_at = Column(DateTime, nullable=True)\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    \n    def __repr__(self):\n        return f\"<GenerationJob(id={self.id}, type='{self.job_type}', status='{self.status}')>\"\n\n\nclass ComicTemplate(Base):\n    \"\"\"\n    ComicTemplate model for reusable comic layouts\n    \"\"\"\n    __tablename__ = 'comic_templates'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    name = Column(String(255), nullable=False)\n    slug = Column(String(255), unique=True, nullable=False)\n    description = Column(Text, nullable=True)\n    \n    # Template structure\n    layout_config = Column(JSON, nullable=False)  # page layouts, panel arrangements\n    default_style = Column(JSON, nullable=True)  # default styling\n    \n    # Usage\n    usage_count = Column(Integer, default=0)\n    is_public = Column(Boolean, default=False)\n    \n    # Ownership\n    creator_id = Column(Integer, ForeignKey('users.id'), nullable=True)\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow, nullable=False)\n    \n    def __repr__(self):\n        return f\"<ComicTemplate(id={self.id}, name='{self.name}')>\"\n\n\nclass ImageAsset(Base):\n    \"\"\"\n    ImageAsset model for storing reusable image assets\n    \"\"\"\n    __tablename__ = 'image_assets'\n\n    id = Column(Integer, primary_key=True, autoincrement=True)\n    name = Column(String(255), nullable=False)\n    asset_type = Column(String(50), nullable=False)  # 'background', 'character_base', 'prop', 'effect'\n    \n    # Storage\n    file_path = Column(String(500), nullable=False)\n    file_url = Column(String(500), nullable=True)\n    thumbnail_url = Column(String(500), nullable=True)\n    \n    # Metadata\n    width = Column(Integer, nullable=True)\n    height = Column(Integer, nullable=True)\n    file_size = Column(Integer, nullable=True)  # in bytes\n    format = Column(String(20), nullable=True)\n    \n    # Organization\n    tags = Column(JSON, nullable=True)\n    category = Column(String(100), nullable=True)\n    \n    # Ownership\n    creator_id = Column(Integer, ForeignKey('users.id'), nullable=True)\n    \n    # Timestamps\n    created_at = Column(DateTime, default=datetime.utcnow, nullable=False)\n    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow, nullable=False)\n    \n    def __repr__(self):\n        return f\"<ImageAsset(id={self.id}, name='{self.name}', type='{self.asset_type}')>\"\n\n\n# Function to initialize database\ndef init_db(engine):\n    \"\"\"Initialize database tables\"\"\"\n    Base.metadata.create_all(bind=engine)\n\n\n# Function to drop all tables (use with caution)\ndef drop_db(engine):\n    \"\"\"Drop all database tables\"\"\"\n    Base.metadata.drop_all(bind=engine)\nEOF\necho \"Models created successfully\""}, {"cmd": "cat > /opt/AiComic/app/database.py << 'EOF'\n\"\"\"\nDatabase Configuration and Session Management\nProvides database connection setup and session factory for SQLAlchemy\n\"\"\"\n\nfrom sqlalchemy import create_engine\nfrom sqlalchemy.orm import sessionmaker, scoped_session\nfrom sqlalchemy.pool import StaticPool\nimport os\nfrom typing import Generator\n\nfrom .config import Config\nfrom .models import Base\n\n\nclass Database:\n    \"\"\"\n    Database class for managing database connections and sessions\n    \"\"\"\n    \n    def __init__(self, config: Config = None):\n        \"\"\"Initialize database with configuration\"\"\"\n        self.config = config or Config()\n        self.engine = None\n        self.session_factory = None\n        self.ScopedSession = None\n        self._initialize_engine()\n    \n    def _initialize_engine(self):\n        \"\"\"Create database engine based on configuration\"\"\"\n        database_url = self.config.DATABASE_URL\n        \n        # Create engine with appropriate settings\n        if database_url.startswith('sqlite'):\n            # SQLite specific configuration\n            self.engine = create_engine(\n                database_url,\n                connect_args={\"check_same_thread\": False},\n                poolclass=StaticPool,\n                echo=self.config.DEBUG\n            )\n        else:\n            # PostgreSQL/MySQL configuration\n            self.engine = create_engine(\n                database_url,\n                pool_size=10,\n                max_overflow=20,\n                pool_pre_ping=True,\n                echo=self.config.DEBUG\n            )\n        \n        # Create session factory\n        self.session_factory = sessionmaker(bind=self.engine)\n        self.ScopedSession = scoped_session(self.session_factory)\n    \n    def create_tables(self):\n        \"\"\"Create all database tables\"\"\"\n        Base.metadata.create_all(bind=self.engine)\n    \n    def drop_tables(self):\n        \"\"\"Drop all database tables\"\"\"\n        Base.metadata.drop_all(bind=self.engine)\n    \n    def get_session(self):\n        \"\"\"Get a new database session\"\"\"\n        return self.session_factory()\n    \n    def get_scoped_session(self):\n        \"\"\"Get a scoped session\"\"\"\n        return self.ScopedSession()\n    \n    def close_session(self):\n        \"\"\"Close the current scoped session\"\"\"\n        if self.ScopedSession:\n            self.ScopedSession.remove()\n    \n    def dispose_engine(self):\n        \"\"\"Dispose the engine and all connections\"\"\"\n        if self.engine:\n            self.engine.dispose()\n\n\n# Global database instance\ndb = Database()\n\n\ndef get_db() -> Generator:\n    \"\"\"\n    Dependency injection function for getting database session\n    Yields a database session and ensures it's closed after use\n    \"\"\"\n    session = db.get_session()\n    try:\n        yield session\n        session.commit()\n    except Exception:\n        session.rollback()\n        raise\n    finally:\n        session.close()\n\n\ndef get_db_session():\n    \"\"\"\n    Get a database session without dependency injection\n    Remember to close the session after use\n    \"\"\"\n    return db.get_session()\n\n\ndef init_database():\n    \"\"\"\n    Initialize the database - create all tables\n    \"\"\"\n    db.create_tables()\n    return db\n\n\ndef reset_database():\n    \"\"\"\n    Reset the database - drop and recreate all tables\n    WARNING: This will delete all data!\n    \"\"\"\n    db.drop_tables()\n    db.create_tables()\n    return db\nEOF\necho \"Database module created successfully\""}, {"cmd": "cat > /opt/AiComic/app/config.py << 'EOF'\n\"\"\"\nConfiguration Module\nHandles application configuration and environment variables\n\"\"\"\n\nimport os\nfrom typing import Optional\nfrom dataclasses import dataclass\n\n\n@dataclass\nclass Config:\n    \"\"\"\n    Application configuration class\n    Loads configuration from environment variables with sensible defaults\n    \"\"\"\n    \n    # Database Configuration\n    DATABASE_URL: str = os.getenv(\n        'DATABASE_URL', \n        'sqlite:///./aicomic.db'\n    )\n    \n    # Application Settings\n    DEBUG: bool = os.getenv('DEBUG', 'False').lower() == 'true'\n    ENVIRONMENT: str = os.getenv('ENVIRONMENT', 'development')\n    SECRET_KEY: str = os.getenv('SECRET_KEY', 'your-secret-key-change-in-production')\n    \n    # API Settings\n    API_VERSION: str = 'v1'\n    API_PREFIX: str = f'/api/{API_VERSION}'\n    \n    # AI Model Settings\n    DEFAULT_AI_MODEL: str = os.getenv('DEFAULT_AI_MODEL', 'stable-diffusion-xl')\n    MAX_IMAGE_SIZE: int = int(os.getenv('MAX_IMAGE_SIZE', '2048'))\n    \n    # Rate Limiting\n    RATE_LIMIT_ENABLED: bool = True\n    DEFAULT_RATE_LIMIT: int = 100  # requests per minute\n    \n    # File Storage\n    UPLOAD_FOLDER: str = os.getenv('UPLOAD_FOLDER', './uploads')\n    MAX_CONTENT_LENGTH: int = 16 * 1024 * 1024  # 16MB max file size\n    ALLOWED_EXTENSIONS: set = {'png', 'jpg', 'jpeg', 'gif', 'webp'}\n    \n    # Pagination\n    DEFAULT_PAGE_SIZE: int = 20\n    MAX_PAGE_SIZE: int = 100\n    \n    # CORS Settings\n    CORS_ORIGINS: list = ['*']\n    \n    # Session Settings\n    SESSION_LIFETIME: int = 3600  # 1 hour in seconds\n    \n    # Redis (optional, for caching and job queues)\n    REDIS_URL: Optional[str] = os.getenv('REDIS_URL', None)\n    \n    # Email Settings (for notifications)\n    SMTP_HOST: Optional[str] = os.getenv('SMTP_HOST', None)\n    SMTP_PORT: int = int(os.getenv('SMTP_PORT', '587'))\n    SMTP_USER: Optional[str] = os.getenv('SMTP_USER', None)\n    SMTP_PASSWORD: Optional[str] = os.getenv('SMTP_PASSWORD', None)\n    \n    # Logging\n    LOG_LEVEL: str = os.getenv('LOG_LEVEL', 'INFO')\n    LOG_FORMAT: str = '%(asctime)s - %(name)s - %(levelname)s - %(message)s'\n    \n    def __post_init__(self):\n        \"\"\"Post-initialization processing\"\"\"\n        # Ensure upload folder exists\n        if not os.path.exists(self.UPLOAD_FOLDER):\n            os.makedirs(self.UPLOAD_FOLDER, exist_ok=True)\n    \n    def is_production(self) -> bool:\n        \"\"\"Check if running in production environment\"\"\"\n        return self.ENVIRONMENT == 'production'\n    \n    def is_development(self) -> bool:\n        \"\"\"Check if running in development environment\"\"\"\n        return self.ENVIRONMENT == 'development'\n    \n    def is_testing(self) -> bool:\n        \"\"\"Check if running in testing environment\"\"\"\n        return self.ENVIRONMENT == 'testing'\n\n\n# Create default config instance\nconfig = Config()\nEOF\necho \"Config module created successfully\""}, {"cmd": "ls -la /opt/AiComic/app/ && echo '---' && wc -l /opt/AiComic/app/models.py && echo '---' && head -50 /opt/AiComic/app/models.py"}, {"cmd": "cat > /opt/AiComic/app/__init__.py << 'EOF'\n\"\"\"\nAiComic Application Package\n\"\"\"\n\n__version__ = '1.0.0'\n__author__ = 'AiComic Team'\n\nfrom .config import config, Config\nfrom .database import db, get_db, init_database, reset_database\nfrom .models import (\n    Base,\n    Comic,\n    Page,\n    ContentBlock,\n    Character,\n    CharacterAppearance,\n    Genre,\n    Tag,\n    User,\n    APIKey,\n    APIUsageLog,\n    GenerationJob,\n    ComicTemplate,\n    ImageAsset,\n    ComicStatus,\n    PageStatus,\n    CharacterType,\n    init_db,\n    drop_db\n)\n\n__all__ = [\n    'config',\n    'Config',\n    'db',\n    'get_db',\n    'init_database',\n    'reset_database',\n    'Base',\n    'Comic',\n    'Page',\n    'ContentBlock',\n    'Character',\n    'CharacterAppearance',\n    'Genre',\n    'Tag',\n    'User',\n    'APIKey',\n    'APIUsageLog',\n    'GenerationJob',\n    'ComicTemplate',\n    'ImageAsset',\n    'ComicStatus',\n    'PageStatus',\n    'CharacterType',\n    'init_db',\n    'drop_db'\n]\nEOF\necho \"__init__.py created successfully\""}, {"cmd": "cd /opt/AiComic && python3 -c \"from app.models import *; print('Models imported successfully'); from app.models import Comic, Page, User; print(f'Comic table: {Comic.__tablename__}'); print(f'Page table: {Page.__tablename__}'); print(f'User table: {User.__tablename__}')\""}, {"cmd": "cat > /opt/AiComic/main.py << 'EOF'\n\"\"\"\nMain Application Entry Point\nDemonstrates database initialization and usage\n\"\"\"\n\nfrom app import init_database, config\nfrom app.models import Comic, Page, User, Genre, Tag, Character\nfrom app.database import get_db_session\nfrom datetime import datetime\nimport os\n\n\ndef main():\n    \"\"\"Main application function\"\"\"\n    print(f\"Initializing database in {config.ENVIRONMENT} mode...\")\n    \n    # Initialize database\n    db = init_database()\n    \n    # Create a session to test the models\n    session = get_db_session()\n    \n    try:\n        # Create a test user\n        test_user = User(\n            username='test_author',\n            email='test@example.com',\n            password_hash='hashed_password_here',\n            display_name='Test Author',\n            is_active=True\n        )\n        session.add(test_user)\n        session.flush()\n        \n        # Create a test comic\n        test_comic = Comic(\n            title='My First AI Comic',\n            slug='my-first-ai-comic',\n            description='A test comic created with AI',\n            author_id=test_user.id,\n            status='draft',\n            is_published=False\n        )\n        session.add(test_comic)\n        session.flush()\n        \n        # Create some pages\n        for i in range(1, 4):\n            page = Page(\n                comic_id=test_comic.id,\n                page_number=i,\n                title=f'Page {i}',\n                status='pending'\n            )\n            session.add(page)\n        \n        # Create genres\n        genre1 = Genre(name='Action', slug='action')\n        genre2 = Genre(name='Sci-Fi', slug='sci-fi')\n        session.add_all([genre1, genre2])\n        \n        # Create tags\n        tag1 = Tag(name='adventure', slug='adventure')\n        tag2 = Tag(name='robots', slug='robots')\n        session.add_all([tag1, tag2])\n        \n        # Create characters\n        character = Character(\n            name='Hero Bot',\n            slug='hero-bot',\n            description='A friendly robot hero',\n            character_type='protagonist'\n        )\n        session.add(character)\n        \n        # Commit all changes\n        session.commit()\n        \n        print(\"Database initialized successfully!\")\n        print(f\"Created user: {test_user.username}\")\n        print(f\"Created comic: {test_comic.title}\")\n        print(f\"Created {len(test_comic.pages)} pages\")\n        print(f\"Created genres: {genre1.name}, {genre2.name}\")\n        print(f\"Created tags: {tag1.name}, {tag2.name}\")\n        print(f\"Created character: {character.name}\")\n        \n    except Exception as e:\n        session.rollback()\n        print(f\"Error during initialization: {e}\")\n        raise\n    finally:\n        session.close()\n\n\nif __name__ == '__main__':\n    main()\nEOF\necho \"Main application created successfully\""}, {"cmd": "echo \"=== Project Structure ===\" && tree /opt/AiComic -L 3 -I '__pycache__|*.pyc' 2>/dev/null || find /opt/AiComic -type f -name \"*.py\" -o -name \"*.txt\" -o -name \"*.md\" | grep -v __pycache__ | sort"}, {"cmd": "cd /opt/AiComic && python3 -m py_compile app/models.py && python3 -m py_compile app/database.py && python3 -m py_compile app/config.py && python3 -m py_compile app/__init__.py && echo \"All Python files compiled successfully - no syntax errors\""}, {"cmd": "cat /opt/AiComic/app/models.py"}, {"cmd": "cat > /opt/AiComic/requirements.txt << 'EOF'\n# Core Dependencies\nSQLAlchemy>=2.0.0\nFlask>=2.3.0\nFlask-SQLAlchemy>=3.0.0\nFlask-Migrate>=4.0.0\n\n# Database Drivers\npsycopg2-binary>=2.9.0  # PostgreSQL\npymysql>=1.1.0\n\n# Server\ngunicorn>=21.0.0\n\n# API & Serialization\nmarshmallow>=3.20.0\nflask-restful>=0.3.10\n\n# Authentication\nFlask-JWT-Extended>=4.5.0\nbcrypt>=4.0.0\n\n# Configuration\npython-dotenv>=1.0.0\n\n# Utilities\npython-dateutil>=2.8.0\nPillow>=10.0.0\nrequests>=2.31.0\n\n# Testing\npytest>=7.4.0\npytest-cov>=4.1.0\nfactory-boy>=3.3.0\n\n# Development\nblack>=23.0.0\nflake8>=6.0.0\nmypy>=1.4.0\n\n# AI/ML (optional, for image generation)\n# torch>=2.0.0\n# diffusers>=0.18.0\n# transformers>=4.30.0\n\n# Redis (optional, for caching)\n# redis>=4.5.0\n# rq>=1.13.0\nEOF\necho \"Requirements file created successfully\""}, {"cmd": "cat > /opt/AiComic/README.md << 'EOF'\n# AiComic Database Models\n\n## Overview\nThis document describes the SQLAlchemy database models implemented for the AiComic application.\n\n## Models\n\n### Core Models\n\n#### Comic\nThe main entity representing a comic book or series.\n- **Fields**: id, title, slug, description, author_id, status, genre_ids, is_published, published_at, created_at, updated_at, ai_generation_prompt, ai_model_used, ai_generation_config\n- **Relationships**: pages, characters, author, genres, tags\n\n#### Page\nIndividual pages within a comic.\n- **Fields**: id, comic_id, page_number, title, image_url, image_path, thumbnail_url, status, generation_prompt, negative_prompt, ai_model, generation_params, processing_time, retry_count, error_message, created_at, updated_at, generated_at\n- **Relationships**: comic, content_blocks\n\n#### ContentBlock\nText/panels within a page.\n- **Fields**: id, page_id, block_type, x_position, y_position, width, height, content, style, created_at, updated_at\n- **Relationships**: page\n\n### Character Models\n\n#### Character\nCharacters appearing in comics.\n- **Fields**: id, name, slug, description, character_type, visual_prompt, default_appearance, created_at, updated_at\n- **Relationships**: comics, appearances\n\n#### CharacterAppearance\nTracks character appearances in specific pages.\n- **Fields**: id, character_id, page_id, position_x, position_y, scale, expression, pose, custom_prompt, created_at\n- **Relationships**: character, page\n\n### Categorization Models\n\n#### Genre\nComic genres for categorization.\n- **Fields**: id, name, slug, description, created_at\n- **Relationships**: comics\n\n#### Tag\nAdditional tags for comic categorization.\n- **Fields**: id, name, slug, usage_count, created_at\n- **Relationships**: comics\n\n### User & Authentication Models\n\n#### User\nComic creators/authors.\n- **Fields**: id, username, email, password_hash, display_name, bio, avatar_url, default_ai_model, generation_preferences, is_active, is_verified, created_at, updated_at, last_login\n- **Relationships**: comics, api_keys\n\n#### APIKey\nAPI authentication keys.\n- **Fields**: id, user_id, key_hash, name, permissions, rate_limit, is_active, expires_at, created_at, last_used\n- **Relationships**: user, usage_logs\n\n#### APIUsageLog\nTracks API usage.\n- **Fields**: id, api_key_id, endpoint, method, status_code, response_time, tokens_used, characters_processed, created_at\n- **Relationships**: api_key\n\n### Utility Models\n\n#### GenerationJob\nTracks AI generation tasks.\n- **Fields**: id, job_type, status, comic_id, page_id, prompt, negative_prompt, model, params, progress, current_step, result, error_message, started_at, completed_at, created_at\n\n#### ComicTemplate\nReusable comic layouts.\n- **Fields**: id, name, slug, description, layout_config, default_style, usage_count, is_public, creator_id, created_at, updated_at\n\n#### ImageAsset\nReusable image assets.\n- **Fields**: id, name, asset_type, file_path, file_url, thumbnail_url, width, height, file_size, format, tags, category, creator_id, created_at, updated_at\n\n## Usage\n\n### Initialize Database\n```python\nfrom app import init_database\ndb = init_database()\n```\n\n### Create a Session\n```python\nfrom app.database import get_db_session\nsession = get_db_session()\ntry:\n    # Use session\n    session.commit()\nexcept:\n    session.rollback()\nfinally:\n    session.close()\n```\n\n### Query Examples\n```python\n# Get all published comics\ncomics = session.query(Comic).filter_by(is_published=True).all()\n\n# Get user's comics\nuser_comics = session.query(Comic).filter_by(author_id=user_id).all()\n\n# Get comic with all related data\ncomic = session.query(Comic).filter_by(slug='my-comic').first()\nprint(f\"Pages: {len(comic.pages)}\")\nprint(f\"Characters: {len(comic.characters)}\")\nprint(f\"Genres: {[g.name for g in comic.genres]}\")\n```\n\n## Enumerations\n\n- **ComicStatus**: DRAFT, PROCESSING, COMPLETED, PUBLISHED, ARCHIVED\n- **PageStatus**: PENDING, GENERATING, COMPLETED, FAILED\n- **CharacterType**: PROTAGONIST, ANTAGONIST, SUPPORTING, MINOR\n\n## Database Initialization\n\nRun the application to automatically create all tables:\n```bash\npython main.py\n```\n\nThis will create the SQLite database file and populate it with test data.\nEOF\necho \"README created successfully\""}, {"cmd": "cd /opt/AiComic && python3 -c \"\nfrom app import (\n    Comic, Page, ContentBlock, Character, CharacterAppearance,\n    Genre, Tag, User, APIKey, APIUsageLog, GenerationJob,\n    ComicTemplate, ImageAsset, ComicStatus, PageStatus, CharacterType,\n    Base\n)\n\n# Verify all models are properly configured\nmodels = [\n    ('Comic', Comic),\n    ('Page', Page),\n    ('ContentBlock', ContentBlock),\n    ('Character', Character),\n    ('CharacterAppearance', CharacterAppearance),\n    ('Genre', Genre),\n    ('Tag', Tag),\n    ('User', User),\n    ('APIKey', APIKey),\n    ('APIUsageLog', APIUsageLog),\n    ('GenerationJob', GenerationJob),\n    ('ComicTemplate', ComicTemplate),\n    ('ImageAsset', ImageAsset)\n]\n\nprint('Database Models Verification:')\nprint('=' * 50)\nfor name, model in models:\n    table_name = model.__tablename__\n    columns = [c.name for c in model.__table__.columns]\n    print(f'{name:25} -> {table_name:20} ({len(columns)} columns)')\n\nprint('=' * 50)\nprint(f'Total models: {len(models)}')\nprint('All models imported and verified successfully!')\n\""}, {"cmd": "cat > /opt/AiComic/DATABASE_SCHEMA.md << 'EOF'\n# AiComic Database Schema\n\n## Entity Relationship Overview\n\n```\nUser (1) u2500u2500u2500u2500u2500u2500< Comic (M)\n  u2502                u2502\n  u2502                u251cu2500u2500u2500u2500< Page (M)\n  u2502                u2502       u2502\n  u2502                u2502       u2514u2500u2500u2500u2500< ContentBlock (M)\n  u2502                u2502\n  u2502                u251cu2500u2500u2500u2500< ComicGenre (M-M)\n  u2502                u2502       u2502\n  u2502                u2502       u2514u2500u2500u2500u2500 Genre (1)\n  u2502                u2502\n  u2502                u251cu2500u2500u2500u2500< ComicTag (M-M)\n  u2502                u2502       u2502\n  u2502                u2502       u2514u2500u2500u2500u2500 Tag (1)\n  u2502                u2502\n  u2502                u2514u2500u2500u2500u2500< ComicCharacter (M-M)\nu2502                        u2502\nu2502                        u2514u2500u2500u2500u2500 Character (1)\nu2502                                u2502\nu2502                                u2514u2500u2500u2500u2500< CharacterAppearance (M)\nu2502                                        u2502\nu2502                                        u2514u2500u2500u2500u2500 Page (1)\nu2502\nu2514u2500u2500u2500u2500< APIKey (M)\n        u2502\n        u2514u2500u2500u2500u2500< APIUsageLog (M)\n```\n\n## Tables\n\n### 1. users\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| username | VARCHAR(100) | NOT NULL, UNIQUE, INDEX |\n| email | VARCHAR(255) | NOT NULL, UNIQUE, INDEX |\n| password_hash | VARCHAR(255) | NOT NULL |\n| display_name | VARCHAR(255) | NULLABLE |\n| bio | TEXT | NULLABLE |\n| avatar_url | VARCHAR(500) | NULLABLE |\n| default_ai_model | VARCHAR(100) | NULLABLE |\n| generation_preferences | JSON | NULLABLE |\n| is_active | BOOLEAN | NOT NULL, DEFAULT TRUE |\n| is_verified | BOOLEAN | NOT NULL, DEFAULT FALSE |\n| created_at | DATETIME | NOT NULL |\n| updated_at | DATETIME | NOT NULL |\n| last_login | DATETIME | NULLABLE |\n\n### 2. comics\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| title | VARCHAR(255) | NOT NULL, INDEX |\n| slug | VARCHAR(255) | NOT NULL, UNIQUE, INDEX |\n| description | TEXT | NULLABLE |\n| author_id | INTEGER | FOREIGN KEY -> users.id, NOT NULL, INDEX |\n| status | ENUM | NOT NULL, DEFAULT 'draft' |\n| genre_ids | JSON | NULLABLE |\n| is_published | BOOLEAN | NOT NULL, DEFAULT FALSE |\n| published_at | DATETIME | NULLABLE |\n| created_at | DATETIME | NOT NULL |\n| updated_at | DATETIME | NOT NULL |\n| ai_generation_prompt | TEXT | NULLABLE |\n| ai_model_used | VARCHAR(100) | NULLABLE |\n| ai_generation_config | JSON | NULLABLE |\n\n### 3. pages\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| comic_id | INTEGER | FOREIGN KEY -> comics.id (CASCADE), NOT NULL, INDEX |\n| page_number | INTEGER | NOT NULL |\n| title | VARCHAR(255) | NULLABLE |\n| image_url | VARCHAR(500) | NULLABLE |\n| image_path | VARCHAR(500) | NULLABLE |\n| thumbnail_url | VARCHAR(500) | NULLABLE |\n| status | ENUM | NOT NULL, DEFAULT 'pending' |\n| generation_prompt | TEXT | NULLABLE |\n| negative_prompt | TEXT | NULLABLE |\n| ai_model | VARCHAR(100) | NULLABLE |\n| generation_params | JSON | NULLABLE |\n| processing_time | FLOAT | NULLABLE |\n| retry_count | INTEGER | DEFAULT 0 |\n| error_message | TEXT | NULLABLE |\n| created_at | DATETIME | NOT NULL |\n| updated_at | DATETIME | NOT NULL |\n| generated_at | DATETIME | NULLABLE |\n\n### 4. content_blocks\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| page_id | INTEGER | FOREIGN KEY -> pages.id (CASCADE), NOT NULL, INDEX |\n| block_type | VARCHAR(50) | NOT NULL |\n| x_position | FLOAT | NOT NULL |\n| y_position | FLOAT | NOT NULL |\n| width | FLOAT | NOT NULL |\n| height | FLOAT | NOT NULL |\n| content | TEXT | NULLABLE |\n| style | JSON | NULLABLE |\n| created_at | DATETIME | NOT NULL |\n| updated_at | DATETIME | NOT NULL |\n\n### 5. characters\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| name | VARCHAR(255) | NOT NULL, INDEX |\n| slug | VARCHAR(255) | NOT NULL, UNIQUE |\n| description | TEXT | NULLABLE |\n| character_type | ENUM | DEFAULT 'supporting' |\n| visual_prompt | TEXT | NULLABLE |\n| default_appearance | JSON | NULLABLE |\n| created_at | DATETIME | NOT NULL |\n| updated_at | DATETIME | NOT NULL |\n\n### 6. character_appearances\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| character_id | INTEGER | FOREIGN KEY -> characters.id (CASCADE), NOT NULL, INDEX |\n| page_id | INTEGER | FOREIGN KEY -> pages.id (CASCADE), NOT NULL, INDEX |\n| position_x | FLOAT | NOT NULL |\n| position_y | FLOAT | NOT NULL |\n| scale | FLOAT | DEFAULT 1.0 |\n| expression | VARCHAR(100) | NULLABLE |\n| pose | VARCHAR(100) | NULLABLE |\n| custom_prompt | TEXT | NULLABLE |\n| created_at | DATETIME | NOT NULL |\n\n### 7. genres\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| name | VARCHAR(100) | NOT NULL, UNIQUE, INDEX |\n| slug | VARCHAR(100) | NOT NULL, UNIQUE |\n| description | TEXT | NULLABLE |\n| created_at | DATETIME | NOT NULL |\n\n### 8. tags\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| name | VARCHAR(100) | NOT NULL, UNIQUE, INDEX |\n| slug | VARCHAR(100) | NOT NULL, UNIQUE |\n| usage_count | INTEGER | DEFAULT 0 |\n| created_at | DATETIME | NOT NULL |\n\n### 9. comic_genres (Association Table)\n| Column | Type | Constraints |\n|--------|------|-------------|\n| comic_id | INTEGER | FOREIGN KEY -> comics.id, PRIMARY KEY |\n| genre_id | INTEGER | FOREIGN KEY -> genres.id, PRIMARY KEY |\n| created_at | DATETIME | DEFAULT NOW |\n\n### 10. comic_tags (Association Table)\n| Column | Type | Constraints |\n|--------|------|-------------|\n| comic_id | INTEGER | FOREIGN KEY -> comics.id, PRIMARY KEY |\n| tag_id | INTEGER | FOREIGN KEY -> tags.id, PRIMARY KEY |\n\n### 11. comic_characters (Association Table)\n| Column | Type | Constraints |\n|--------|------|-------------|\n| comic_id | INTEGER | FOREIGN KEY -> comics.id, PRIMARY KEY |\n| character_id | INTEGER | FOREIGN KEY -> characters.id, PRIMARY KEY |\n| role | VARCHAR(50) | DEFAULT 'supporting' |\n| appearance_order | INTEGER | DEFAULT 0 |\n\n### 12. api_keys\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| user_id | INTEGER | FOREIGN KEY -> users.id (CASCADE), NOT NULL, INDEX |\n| key_hash | VARCHAR(255) | NOT NULL, UNIQUE |\n| name | VARCHAR(100) | NOT NULL |\n| permissions | JSON | NULLABLE |\n| rate_limit | INTEGER | DEFAULT 100 |\n| is_active | BOOLEAN | NOT NULL, DEFAULT TRUE |\n| expires_at | DATETIME | NULLABLE |\n| created_at | DATETIME | NOT NULL |\n| last_used | DATETIME | NULLABLE |\n\n### 13. api_usage_logs\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| api_key_id | INTEGER | FOREIGN KEY -> api_keys.id (CASCADE), NOT NULL, INDEX |\n| endpoint | VARCHAR(255) | NOT NULL |\n| method | VARCHAR(10) | NOT NULL |\n| status_code | INTEGER | NOT NULL |\n| response_time | FLOAT | NULLABLE |\n| tokens_used | INTEGER | NULLABLE |\n| characters_processed | INTEGER | NULLABLE |\n| created_at | DATETIME | NOT NULL |\n\n### 14. generation_jobs\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| job_type | VARCHAR(50) | NOT NULL |\n| status | VARCHAR(50) | NOT NULL, DEFAULT 'pending' |\n| comic_id | INTEGER | FOREIGN KEY -> comics.id (CASCADE), INDEX |\n| page_id | INTEGER | FOREIGN KEY -> pages.id (CASCADE), INDEX |\n| prompt | TEXT | NULLABLE |\n| negative_prompt | TEXT | NULLABLE |\n| model | VARCHAR(100) | NULLABLE |\n| params | JSON | NULLABLE |\n| progress | INTEGER | DEFAULT 0 |\n| current_step | VARCHAR(100) | NULLABLE |\n| result | JSON | NULLABLE |\n| error_message | TEXT | NULLABLE |\n| started_at | DATETIME | NULLABLE |\n| completed_at | DATETIME | NULLABLE |\n| created_at | DATETIME | NOT NULL |\n\n### 15. comic_templates\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| name | VARCHAR(255) | NOT NULL |\n| slug | VARCHAR(255) | NOT NULL, UNIQUE |\n| description | TEXT | NULLABLE |\n| layout_config | JSON | NOT NULL |\n| default_style | JSON | NULLABLE |\n| usage_count | INTEGER | DEFAULT 0 |\n| is_public | BOOLEAN | DEFAULT FALSE |\n| creator_id | INTEGER | FOREIGN KEY -> users.id |\n| created_at | DATETIME | NOT NULL |\n| updated_at | DATETIME | NOT NULL |\n\n### 16. image_assets\n| Column | Type | Constraints |\n|--------|------|-------------|\n| id | INTEGER | PRIMARY KEY, AUTOINCREMENT |\n| name | VARCHAR(255) | NOT NULL |\n| asset_type | VARCHAR(50) | NOT NULL |\n| file_path | VARCHAR(500) | NOT NULL |\n| file_url | VARCHAR(500) | NULLABLE |\n| thumbnail_url | VARCHAR(500) | NULLABLE |\n| width | INTEGER | NULLABLE |\n| height | INTEGER | NULLABLE |\n| file_size | INTEGER | NULLABLE |\n| format | VARCHAR(20) | NULLABLE |\n| tags | JSON | NULLABLE |\n| category | VARCHAR(100) | NULLABLE |\n| creator_id | INTEGER | FOREIGN KEY -> users.id |\n| created_at | DATETIME | NOT NULL |\n| updated_at | DATETIME | NOT NULL |\n\n## Indexes\n\n### Automatic Indexes (Primary Keys)\n- All tables have primary key indexes on `id`\n\n### Additional Indexes\n- `users.username` - UNIQUE INDEX\n- `users.email` - UNIQUE INDEX\n- `comics.title` - INDEX\n- `comics.slug` - UNIQUE INDEX\n- `comics.author_id` - INDEX\n- `pages.comic_id` - INDEX\n- `content_blocks.page_id` - INDEX\n- `characters.name` - INDEX\n- `characters.slug` - UNIQUE INDEX\n- `character_appearances.character_id` - INDEX\n- `character_appearances.page_id` - INDEX\n- `genres.name` - UNIQUE INDEX\n- `genres.slug` - UNIQUE INDEX\n- `tags.name` - UNIQUE INDEX\n- `tags.slug` - UNIQUE INDEX\n- `api_keys.user_id` - INDEX\n- `api_usage_logs.api_key_id` - INDEX\n- `generation_jobs.comic_id` - INDEX\n- `generation_jobs.page_id` - INDEX\n\n## Enumerations\n\n### ComicStatus\n- `draft` - Comic is being created\n- `processing` - AI generation in progress\n- `completed` - All pages generated\n- `published` - Publicly available\n- `archived` - No longer active\n\n### PageStatus\n- `pending` - Not yet generated\n- `generating` - AI generation in progress\n- `completed` - Successfully generated\n- `failed` - Generation failed\n\n### CharacterType\n- `protagonist` - Main hero\n- `antagonist` - Main villain\n- `supporting` - Supporting character\n- `minor` - Background/minor character\n\n## Relationships Summary\n\n1. **User -> Comic**: One-to-Many (author can have many comics)\n2. **Comic -> Page**: One-to-Many (comic has many pages)\n3. **Page -> ContentBlock**: One-to-Many (page has many content blocks)\n4. **Comic <-> Genre**: Many-to-Many (comic can have multiple genres)\n5. **Comic <-> Tag**: Many-to-Many (comic can have multiple tags)\n6. **Comic <-> Character**: Many-to-Many (comic can have multiple characters)\n7. **Character -> CharacterAppearance**: One-to-Many (character appears in many pages)\n8. **Page -> CharacterAppearance**: One-to-Many (page has many character appearances)\n9. **User -> APIKey**: One-to-Many (user can have many API keys)\n10. **APIKey -> APIUsageLog**: One-to-Many (API key usage history)\nEOF\necho \"Database schema documentation created successfully\""}, {"cmd": "echo \"========================================\" && echo \"DATABASE MODELS IMPLEMENTATION COMPLETE\" && echo \"========================================\" && echo \"\" && echo \"Files Created:\" && ls -lh /opt/AiComic/app/*.py /opt/AiComic/*.txt /opt/AiComic/*.md 2>/dev/null | grep -v \"^d\" && echo \"\" && echo \"Model Summary:\" && cd /opt/AiComic && python3 << 'PYEOF'\nfrom app.models import (\n    Comic, Page, ContentBlock, Character, CharacterAppearance,\n    Genre, Tag, User, APIKey, APIUsageLog, GenerationJob,\n    ComicTemplate, ImageAsset, ComicStatus, PageStatus, CharacterType\n)\n\nmodels_info = [\n    (\"Comic\", Comic, \"Main comic entity with AI generation support\"),\n    (\"Page\", Page, \"Individual comic pages with generation status\"),\n    (\"ContentBlock\", ContentBlock, \"Text/panels within pages\"),\n    (\"Character\", Character, \"Comic characters with visual prompts\"),\n    (\"CharacterAppearan