',\n    name: 'American Comic',\n    description: 'Bold lines and bright colors',\n    thumbnail: '/styles/american-comic.png'\n  },\n  {\n    id: 'pixel-art',\n    name: 'Pixel Art',\n    description: 'Retro 8-bit gaming style',\n    thumbnail: '/styles/pixel-art.png'\n  },\n  {\n    id: 'watercolor',\n    name: 'Watercolor',\n    description: 'Soft artistic watercolor effect',\n    thumbnail: '/styles/watercolor.png'\n  },\n  {\n    id: 'noir',\n    name: 'Film Noir',\n    description: 'Dark cinematic style with dramatic shadows',\n    thumbnail: '/styles/noir.png'\n  }\n];\n\n// Maximum story length\nexport const MAX_STORY_LENGTH = 500;\nEOF\necho \"types/index.ts created\""}, {"cmd": "cat > /opt/AiComic/apps/frontend/src/store/useAppStore.ts << 'EOF'\nimport { create } from 'zustand';\nimport { GeneratedImage, COMIC_STYLES, MAX_STORY_LENGTH } from '../types';\n\ninterface AppState {\n  // Story input\n  story: string;\n  setStory: (story: string) => void;\n  clearStory: () => void;\n  isStoryValid: () => boolean;\n  \n  // Style selection\n  selectedStyle: string;\n  setSelectedStyle: (style: string) => void;\n  getSelectedStyleObject: () => typeof COMIC_STYLES[0] | undefined;\n  \n  // Generation state\n  isGenerating: boolean;\n  setIsGenerating: (generating: boolean) => void;\n  generationProgress: number;\n  setGenerationProgress: (progress: number) => void;\n  \n  // Generated images\n  generatedImages: GeneratedImage[];\n  setGeneratedImages: (images: GeneratedImage[]) => void;\n  addGeneratedImages: (images: GeneratedImage[]) => void;\n  clearGeneratedImages: () => void;\n  \n  // Generation ID for tracking\n  generationId: string | null;\n  setGenerationId: (id: string | null) => void;\n  \n  // UI state\n  error: string | null;\n  setError: (error: string | null) => void;\n  clearError: () => void;\n  \n  // Toast notifications\n  toasts: Toast[];\n  addToast: (toast: Omit<Toast, 'id'>) => void;\n  removeToast: (id: string) => void;\n  \n  // Modal state\n  selectedImage: GeneratedImage | null;\n  setSelectedImage: (image: GeneratedImage | null) => void;\n  \n  // Reset all state\n  reset: () => void;\n}\n\ninterface Toast {\n  id: string;\n  type: 'success' | 'error' | 'info' | 'warning';\n  message: string;\n  duration?: number;\n}\n\nconst initialState = {\n  story: '',\n  selectedStyle: COMIC_STYLES[0].id,\n  isGenerating: false,\n  generationProgress: 0,\n  generatedImages: [],\n  generationId: null,\n  error: null,\n  toasts: [],\n  selectedImage: null,\n};\n\nexport const useAppStore = create<AppState>((set, get) => ({\n  ...initialState,\n  \n  // Story input\n  setStory: (story: string) => {\n    if (story.length <= MAX_STORY_LENGTH) {\n      set({ story });\n    }\n  },\n  \n  clearStory: () => set({ story: '' }),\n  \n  isStoryValid: () => {\n    const { story } = get();\n    return story.trim().length >= 10;\n  },\n  \n  // Style selection\n  setSelectedStyle: (style: string) => set({ selectedStyle: style }),\n  \n  getSelectedStyleObject: () => {\n    const { selectedStyle } = get();\n    return COMIC_STYLES.find(s => s.id === selectedStyle);\n  },\n  \n  // Generation state\n  setIsGenerating: (generating: boolean) => set({ isGenerating: generating }),\n  \n  setGenerationProgress: (progress: number) => set({ generationProgress: progress }),\n  \n  // Generated images\n  setGeneratedImages: (images: GeneratedImage[]) => set({ generatedImages: images }),\n  \n  addGeneratedImages: (images: GeneratedImage[]) => set((state) => ({\n    generatedImages: [...state.generatedImages, ...images]\n  })),\n  \n  clearGeneratedImages: () => set({ generatedImages: [], generationId: null }),\n  \n  // Generation ID\n  setGenerationId: (id: string | null) => set({ generationId: id }),\n  \n  // UI state\n  setError: (error: string | null) => set({ error }),\n  \n  clearError: () => set({ error: null }),\n  \n  // Toast notifications\n  addToast: (toast: Omit<Toast, 'id'>) => {\n    const id = `toast-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;\n    const newToast = { ...toast, id };\n    set((state) => ({ toasts: [...state.toasts, newToast] }));\n    \n    // Auto-remove after duration\n    const duration = toast.duration || 5000;\n    setTimeout(() => {\n      get().removeToast(id);\n    }, duration);\n  },\n  \n  removeToast: (id: string) => set((state) => ({\n    toasts: state.toasts.filter(t => t.id !== id)\n  })),\n  \n  // Modal state\n  setSelectedImage: (image: GeneratedImage | null) => set({ selectedImage: image }),\n  \n  // Reset all state\n  reset: () => set(initialState),\n}));\n\nexport default useAppStore;\nEOF\necho \"store/useAppStore.ts created\""}, {"cmd": "cat > /opt/AiComic/apps/frontend/src/api/comicApi.ts << 'EOF'\nimport axios, { AxiosError, AxiosRequestConfig } from 'axios';\nimport { GenerationRequest, GenerationResponse, ApiError, GeneratedImage } from '../types';\n\n// Create axios instance with base configuration\nconst apiClient = axios.create({\n  baseURL: import.meta.env.VITE_API_URL || 'http://localhost:3001/api',\n  timeout: 120000, // 2 minutes for image generation\n  headers: {\n    'Content-Type': 'application/json',\n  },\n});\n\n// Request interceptor for logging\napiClient.interceptors.request.use(\n  (config) => {\n    console.log(`[API] ${config.method?.toUpperCase()} ${config.url}`);\n    return config;\n  },\n  (error) => {\n    console.error('[API] Request error:', error);\n    return Promise.reject(error);\n  }\n);\n\n// Response interceptor for error handling\napiClient.interceptors.response.use(\n  (response) => {\n    console.log(`[API] Response received from ${response.config.url}`);\n    return response;\n  },\n  (error: AxiosError<ApiError>) => {\n    console.error('[API] Response error:', error.message);\n    \n    if (error.response) {\n      // Server responded with error status\n      const errorData = error.response.data;\n      const apiError: ApiError = {\n        message: errorData?.message || 'An error occurred',\n        code: errorData?.code || 'UNKNOWN_ERROR',\n        details: errorData?.details,\n      };\n      return Promise.reject(apiError);\n    } else if (error.request) {\n      // Request made but no response received\n      const apiError: ApiError = {\n        message: 'Network error. Please check your connection.',\n        code: 'NETWORK_ERROR',\n      };\n      return Promise.reject(apiError);\n    } else {\n      // Error in request setup\n      const apiError: ApiError = {\n        message: error.message || 'Request failed',\n        code: 'REQUEST_ERROR',\n      };\n      return Promise.reject(apiError);\n    }\n  }\n);\n\n// Generate comic images from story\nexport const generateComic = async (\n  request: GenerationRequest,\n  onProgress?: (progress: number) => void\n): Promise<GenerationResponse> => {\n  const config: AxiosRequestConfig = {\n    onUploadProgress: (progressEvent) => {\n      if (progressEvent.total && onProgress) {\n        const progress = Math.round((progressEvent.loaded * 100) / progressEvent.total);\n        onProgress(progress * 0.3); // 30% for upload\n      }\n    },\n  };\n\n  try {\n    const response = await apiClient.post<GenerationResponse>('/generate', request, config);\n    \n    if (onProgress) {\n      onProgress(100);\n    }\n    \n    return response.data;\n  } catch (error) {\n    throw error as ApiError;\n  }\n};\n\n// Get generation status/images by ID\nexport const getGenerationStatus = async (id: string): Promise<GenerationResponse> => {\n  try {\n    const response = await apiClient.get<GenerationResponse>(`/images/${id}`);\n    return response.data;\n  } catch (error) {\n    throw error as ApiError;\n  }\n};\n\n// Get user's generation history\nexport const getGenerationHistory = async (\n  page: number = 1,\n  limit: number = 20\n): Promise<{ generations: GenerationResponse[]; total: number }> => {\n  try {\n    const response = await apiClient.get<{ generations: GenerationResponse[]; total: number }>(\n      '/history',\n      { params: { page, limit } }\n    );\n    return response.data;\n  } catch (error) {\n    throw error as ApiError;\n  }\n};\n\n// Delete a generation\nexport const deleteGeneration = async (id: string): Promise<void> => {\n  try {\n    await apiClient.delete(`/images/${id}`);\n  } catch (error) {\n    throw error as ApiError;\n  }\n};\n\n// Download image\nexport const downloadImage = async (url: string, filename: string): Promise<void> => {\n  try {\n    const response = await axios.get(url, { responseType: 'blob' });\n    const blob = new Blob([response.data], { type: response.headers['content-type'] });\n    const downloadUrl = window.URL.createObjectURL(blob);\n    const link = document.createElement('a');\n    link.href = downloadUrl;\n    link.download = filename;\n    document.body.appendChild(link);\n    link.click();\n    document.body.removeChild(link);\n    window.URL.revokeObjectURL(downloadUrl);\n  } catch (error) {\n    console.error('Download failed:', error);\n    throw new Error('Failed to download image');\n  }\n};\n\n// Share image (opens share dialog or copies to clipboard)\nexport const shareImage = async (image: GeneratedImage): Promise<boolean> => {\n  const shareData = {\n    title: 'AiComic - Generated Image',\n    text: `Check out this comic I created with AiComic using ${image.style} style!`,\n    url: image.url,\n  };\n\n  if (navigator.share && navigator.canShare && navigator.canShare(shareData)) {\n    try {\n      await navigator.share(shareData);\n      return true;\n    } catch (error) {\n      if ((error as Error).name !== 'AbortError') {\n        console.error('Share failed:', error);\n        return false;\n      }\n    }\n  }\n\n  // Fallback: copy to clipboard\n  try {\n    await navigator.clipboard.writeText(image.url);\n    return true;\n  } catch (error) {\n    console.error('Copy to clipboard failed:', error);\n    return false;\n  }\n};\n\n// Mock API for development (when backend is not available)\nexport const mockGenerateComic = async (\n  request: GenerationRequest,\n  onProgress?: (progress: number) => void\n): Promise<GenerationResponse> => {\n  // Simulate progress\n  const progressSteps = [10, 20, 30, 50, 70, 90, 100];\n  for (const progress of progressSteps) {\n    await new Promise(resolve => setTimeout(resolve, 500));\n    onProgress?.(progress);\n  }\n\n  // Generate mock images\n  const mockImages: GeneratedImage[] = [\n    {\n      id: `img-${Date.now()}-1`,\n      url: `https://picsum.photos/seed/${Date.now()}/512/512`,\n      prompt: request.story,\n      style: request.style,\n      createdAt: new Date().toISOString(),\n    },\n    {\n      id: `img-${Date.now()}-2`,\n      url: `https://picsum.photos/seed/${Date.now() + 1}/512/512`,\n      prompt: request.story,\n      style: request.style,\n      createdAt: new Date().toISOString(),\n    },\n    {\n      id: `img-${Date.now()}-3`,\n      url: `https://picsum.photos/seed/${Date.now() + 2}/512/512`,\n      prompt: request.story,\n      style: request.style,\n      createdAt: new Date().toISOString(),\n    },\n    {\n      id: `img-${Date.now()}-4`,\n      url: `https://picsum.photos/seed/${Date.now() + 3}/512/512`,\n      prompt: request.story,\n      style: request.style,\n      createdAt: new Date().toISOString(),\n    },\n  ];\n\n  return {\n    images: mockImages,\n    id: `gen-${Date.now()}`,\n    status: 'completed',\n  };\n};\n\nexport default apiClient;\nEOF\necho \"api/comicApi.ts created\""}, {"cmd": "cat > /opt/AiComic/apps/frontend/src/components/Layout/Header.tsx << 'EOF'\nimport React from 'react';\n\nconst Header: React.FC = () => {\n  return (\n    <header className=\"header\">\n      <div className=\"header-content\">\n        <div className=\"logo\">\n          <svg \n            className=\"logo-icon\" \n            viewBox=\"0 0 24 24\" \n            fill=\"none\" \n            stroke=\"currentColor\" \n            strokeWidth=\"2\"\n          >\n            <rect x=\"3\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\" />\n            <rect x=\"14\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\" />\n            <rect x=\"3\" y=\"14\" width=\"7\" height=\"7\" rx=\"1\" />\n            <rect x=\"14\" y=\"14\" width=\"7\" height=\"7\" rx=\"1\" />\n          </svg>\n          <span className=\"logo-text\">AiComic</span>\n        </div>\n        <nav className=\"nav\">\n          <a href=\"#create\" className=\"nav-link active\">Create</a>\n          <a href=\"#gallery\" className=\"nav-link\">Gallery</a>\n          <a href=\"#about\" className=\"nav-link\">About</a>\n        </nav>\n      </div>\n    </header>\n  );\n};\n\nexport default Header;\nEOF\necho \"Header.tsx created\""}, {"cmd": "cat > /opt/AiComic/apps/frontend/src/components/Layout/Footer.tsx << 'EOF'\nimport React from 'react';\n\nconst Footer: React.FC = () => {\n  const currentYear = new Date().getFullYear();\n  \n  return (\n    <footer className=\"footer\">\n      <div className=\"footer-content\">\n        <div className=\"footer-info\">\n          <p>&copy; {currentYear} AiComic. Turn your stories into comics.</p>\n        </div>\n        <div className=\"footer-links\">\n          <a href=\"#privacy\" className=\"footer-link\">Privacy</a>\n          <a href=\"#terms\" className=\"footer-link\">Terms</a>\n          <a href=\"#support\" className=\"footer-link\">Support</a>\n        </div>\n      </div>\n    </footer>\n  );\n};\n\nexport default Footer;\nEOF\necho \"Footer.tsx created\""}, {"cmd": "cat > /opt/AiComic/apps/frontend/src/components/Layout/index.ts << 'EOF'\nexport { default as Header } from './Header';\nexport { default as Footer } from './Footer';\nEOF\n\ncat > /opt/AiComic/apps/frontend/src/components/Input/StoryInput.tsx << 'EOF'\nimport React from 'react';\nimport { useAppStore } from '../../store/useAppStore';\nimport { MAX_STORY_LENGTH } from '../../types';\n\nconst StoryInput: React.FC = () => {\n  const { story, setStory, clearStory } = useAppStore();\n  const characterCount = story.length;\n  const isNearLimit = characterCount >= MAX_STORY_LENGTH * 0.9;\n  const isOverLimit = characterCount > MAX_STORY_LENGTH;\n\n  return (\n    <div className=\"story-input-container\">\n      <label htmlFor=\"story-input\" className=\"input-label\">\n        Enter Your Story\n      </label>\n      <div className=\"textarea-wrapper\">\n        <textarea\n          id=\"story-input\"\n          className={`story-textarea ${isOverLimit ? 'error' : ''}`}\n          value={story}\n          onChange={(e) => setStory(e.target.value)}\n          placeholder=\"Once upon a time in a land far, far away... Describe your story here and watch it come to life as a comic!\"\n          rows={6}\n          maxLength={MAX_STORY_LENGTH + 50}\n          disabled={useAppStore.getState().isGenerating}\n        />\n        <button\n          type=\"button\"\n          className=\"clear-button\"\n          onClick={clearStory}\n          disabled={!story || useAppStore.getState().isGenerating}\n          aria-label=\"Clear story\"\n        >\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\">\n            <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\" />\n            <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\" />\n          </svg>\n        </button>\n      </div>\n      <div className=\"character-count\">\n        <span className={`count ${isNearLimit ? 'warning' : ''} ${isOverLimit ? 'error' : ''}`}>\n          {characterCount}\n        </span>\n        <span className=\"separator\">/</span>\n        <span className=\"limit\">{MAX_STORY_LENGTH}</span>\n      </div>\n    </div>\n  );\n};\n\nexport default StoryInput;\nEOF\necho \"StoryInput.tsx created\""}, {"cmd": "cat > /opt/AiComic/apps/frontend/src/components/Input/StyleSelector.tsx << 'EOF'\nimport React from 'react';\nimport { useAppStore } from '../../store/useAppStore';\nimport { COMIC_STYLES } from '../../types';\n\nconst StyleSelector: React.FC = () => {\n  const { selectedStyle, setSelectedStyle } = useAppStore();\n\n  const getStyleThumbnail = (styleId: string): string => {\n    // Generate gradient thumbnails based on style\n    const gradients: Record<string, string> = {\n      'anime': 'linear-gradient(135deg, #ff6b9d 0%, #c44569 50%, #6c5ce7 100%)',\n      'manga': 'linear-gradient(135deg, #ffffff 0%, #f8f8f8 50%, #2d3436 100%)',\n      'american-comic': 'linear-gradient(135deg, #fdcb6e 0%, #e17055 50%, #0984e3 100%)',\n      'pixel-art': 'linear-gradient(135deg, #00b894 0%, #00cec9 50%, #6c5ce7 100%)',\n      'watercolor': 'linear-gradient(135deg, #a29bfe 0%, #74b9ff 50%, #81ecec 100%)',\n      'noir': 'linear-gradient(135deg, #2d3436 0%, #636e72 50%, #b2bec3 100%)',\n    };\n    return gradients[styleId] || 'linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%)';\n  };\n\n  return (\n    <div className=\"style-selector-container\">\n      <label className=\"input-label\">Choose Comic Style</label>\n      <div className=\"style-grid\">\n        {COMIC_STYLES.map((style) => (\n          <button\n            key={style.id}\n            type=\"button\"\n            className={`style-card ${selectedStyle === style.id ? 'selected' : ''}`}\n            onClick={() => setSelectedStyle(style.id)}\n            disabled={useAppStore.getState().isGenerating}\n          >\n            <div \n              className=\"style-thumbnail\"\n              style={{ background: getStyleThumbnail(style.id) }}\n            >\n              <div className=\"style-icon\">\n                {style.id === 'anime' && (\n                  <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                    <path d=\"M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z\" />\n                  </svg>\n                )}\n                {style.id === 'manga' && (\n                  <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                    <path d=\"M19 3H5C3.89 3 3 3.89 3 5V19C3 20.1 3.89 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.89 20.1 3 19 3ZM9 17H7V10H9V17ZM13 17H11V7H13V17ZM17 17H15V13H17V17Z\" />\n                  </svg>\n                )}\n                {style.id === 'american-comic' && (\n                  <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                    <path d=\"M21 5V19H3V5H21M21 3H3C1.9 3 1 3.9 1 5V19C1 20.1 1.9 21 3 21H21C22.1 21 23 20.1 23 19V5C23 3.9 22.1 3 21 3Z\" />\n                  </svg>\n                )}\n                {style.id === 'pixel-art' && (\n                  <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                    <path d=\"M3 3H5V5H3V3M7 3H9V5H7V3M11 3H13V5H11V3M15 3H17V5H15V3M19 3H21V5H19V3M3 7H5V9H3V7M7 7H9V9H7V7M11 7H13V9H11V7M15 7H17V9H15V7M19 7H21V9H19V7M3 11H5V13H3V11M7 11H9V13H7V11M11 11H13V13H11V11M15 11H17V13H15V11M19 11H21V13H19V11M3 15H5V17H3V15M7 15H9V17H7V15M11 15H13V17H11V15M15 15H17V17H15V15M19 15H21V17H19V15M3 19H5V21H3V19M7 19H9V21H7V19M11 19H13V21H11V19M15 19H17V21H15V19M19 19H21V21H19V19Z\" />\n                  </svg>\n                )}\n                {style.id === 'watercolor' && (\n                  <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                    <path d=\"M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM12 20C7.58 20 4 16.42 4 12C4 7.58 7.58 4 12 4C16.42 4 20 7.58 20 12C20 16.42 16.42 20 12 20Z\" />\n                  </svg>\n                )}\n                {style.id === 'noir' && (\n                  <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                    <path d=\"M12 2L2 7L12 12L22 7L12 2ZM12 4.5L18.5 7.5L12 10.5L5.5 7.5L12 4.5ZM2 17L12 22L22 17L12 12L2 17ZM12 14.5L5.5 11.5L12 8.5L18.5 11.5L12 14.5Z\" />\n                  </svg>\n                )}\n              </div>\n            </div>\n            <div className=\"style-info\">\n              <span className=\"style-name\">{style.name}</span>\n              <span className=\"style-description\">{style.description}</span>\n            </div>\n            <div className=\"selected-indicator\">\n              <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                <path d=\"M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z\" />\n              </svg>\n            </div>\n          </button>\n        ))}\n      </div>\n    </div>\n  );\n};\n\nexport default StyleSelector;\nEOF\necho \"StyleSelector.tsx created\""}, {"cmd": "cat > /opt/AiComic/apps/frontend/src/components/Input/index.ts << 'EOF'\nexport { default as StoryInput } from './StoryInput';\nexport { default as StyleSelector } from './StyleSelector';\nEOF\n\ncat > /opt/AiComic/apps/frontend/src/components/Display/ImageCard.tsx << 'EOF'\nimport React from 'react';\nimport { GeneratedImage } from '../../types';\nimport { useAppStore } from '../../store/useAppStore';\nimport { downloadImage, shareImage } from '../../api/comicApi';\n\ninterface ImageCardProps {\n  image: GeneratedImage;\n  index: number;\n}\n\nconst ImageCard: React.FC<ImageCardProps> = ({ image, index }) => {\n  const { setSelectedImage, addToast } = useAppStore();\n  const [isLoading, setIsLoading] = React.useState(false);\n\n  const handleDownload = async (e: React.MouseEvent) => {\n    e.stopPropagation();\n    setIsLoading(true);\n    try {\n      const filename = `aicomic-${image.style}-${index + 1}.png`;\n      await downloadImage(image.url, filename);\n      addToast({\n        type: 'success',\n        message: 'Image downloaded successfully!',\n      });\n    } catch (error) {\n      addToast({\n        type: 'error',\n        message: 'Failed to download image',\n      });\n    } finally {\n      setIsLoading(false);\n    }\n  };\n\n  const handleShare = async (e: React.MouseEvent) => {\n    e.stopPropagation();\n    setIsLoading(true);\n    try {\n      const shared = await shareImage(image);\n      if (shared) {\n        addToast({\n          type: 'success',\n          message: 'Link copied to clipboard!',\n        });\n      }\n    } catch (error) {\n      addToast({\n        type: 'error',\n        message: 'Failed to share image',\n      });\n    } finally {\n      setIsLoading(false);\n    }\n  };\n\n  const handleCardClick = () => {\n    setSelectedImage(image);\n  };\n\n  return (\n    <div className=\"image-card\" onClick={handleCardClick}>\n      <div className=\"image-wrapper\">\n        <img\n          src={image.url}\n          alt={`Generated comic ${index + 1}`}\n          loading=\"lazy\"\n          className=\"image\"\n        />\n        <div className=\"image-overlay\">\n          <div className=\"image-actions\">\n            <button\n              className=\"action-button\"\n              onClick={handleDownload}\n              disabled={isLoading}\n              aria-label=\"Download image\"\n            >\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\">\n                <path d=\"M21 15V19C21 20.1 20.1 21 19 21H5C3.9 21 3 20.1 3 19V15\" />\n                <polyline points=\"7 10 12 15 17 10\" />\n                <line x1=\"12\" y1=\"15\" x2=\"12\" y2=\"3\" />\n              </svg>\n            </button>\n            <button\n              className=\"action-button\"\n              onClick={handleShare}\n              disabled={isLoading}\n              aria-label=\"Share image\"\n            >\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\">\n                <circle cx=\"18\" cy=\"5\" r=\"3\" />\n                <circle cx=\"6\" cy=\"12\" r=\"3\" />\n                <circle cx=\"18\" cy=\"19\" r=\"3\" />\n                <line x1=\"8.59\" y1=\"13.51\" x2=\"15.42\" y2=\"17.49\" />\n                <line x1=\"15.41\" y1=\"6.51\" x2=\"8.59\" y2=\"10.49\" />\n              </svg>\n            </button>\n          </div>\n        </div>\n      </div>\n      <div className=\"image-meta\">\n        <span className=\"image-style\">{image.style}</span>\n        <span className=\"image-index\">#{index + 1}</span>\n      </div>\n    </div>\n  );\n};\n\nexport default ImageCard;\nEOF\necho \"ImageCard.tsx created\""}, {"cmd": "cat > /opt/AiComic/apps/frontend/src/components/Display/ImageGrid.tsx << 'EOF'\nimport React from 'react';\nimport { useAppStore } from '../../store/useAppStore';\nimport ImageCard from './ImageCard';\n\nconst ImageGrid: React.FC = () => {\n  const { generatedImages, clearGeneratedImages, isGenerating } = useAppStore();\n\n  if (generatedImages.length === 0 && !isGenerating) {\n    return null;\n  }\n\n  return (\n    <section className=\"image-grid-section\" id=\"gallery\">\n      <div className=\"section-header\">\n        <h2 className=\"section-title\">Generated Comics</h2>\n        {generatedImages.length > 0 && (\n          <button\n            className=\"clear-all-button\"\n            onClick={clearGeneratedImages}\n            disabled={isGenerating}\n          >\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\">\n              <polyline points=\"3 6 5 6 21 6\" />\n              <path d=\"M19 6V20C19 21.1 18.1 22 17 22H7C5.9 22 5 21.1 5 20V6M8 6V4C8 2.9 8.9 2 10 2H14C15.1 2 16 2.9 16 4V6\" />\n            </svg>\n            Clear All\n          </button>\n        )}\n      </div>\n      <div className=\"image-grid\">\n        {generatedImages.map((image, index) => (\n          <ImageCard key={image.id} image={image} index={index} />\n        ))}\n      </div>\n    </section>\n  );\n};\n\nexport default ImageGrid;\nEOF\necho \"ImageGrid.tsx created\""}, {"cmd": "cat > /opt/AiComic/apps/frontend/src/components/Display/index.ts << 'EOF'\nexport { default as ImageCard } from './ImageCard';\nexport { default as ImageGrid } from './ImageGrid';\nEOF\n\ncat > /opt/AiComic/apps/frontend/src/components/Feedback/LoadingSpinner.tsx << 'EOF'\nimport React from 'react';\nimport { useAppStore } from '../../store/useAppStore';\n\nconst LoadingSpinner: React.FC = () => {\n  const { generationProgress, selectedStyle } = useAppStore();\n\n  return (\n    <div className=\"loading-spinner-container\">\n      <div className=\"spinner-wrapper\">\n        <div className=\"spinner\">\n          <svg className=\"spinner-svg\" viewBox=\"0 0 100 100\">\n            <circle\n              className=\"spinner-track\"\n              cx=\"50\"\n              cy=\"50\"\n              r=\"45\"\n              fill=\"none\"\n              strokeWidth=\"8\"\n            />\n            <circle\n              className=\"spinner-progress\"\n              cx=\"50\"\n              cy=\"50\"\n              r=\"45\"\n              fill=\"none\"\n              strokeWidth=\"8\"\n              strokeDasharray=\"283\"\n              strokeDashoffset={283 - (283 * generationProgress) / 100}\n            />\n          </svg>\n          <div className=\"spinner-text\">\n            <span className=\"progress-value\">{Math.round(generationProgress)}%</span>\n            <span className=\"progress-label\">Generating...</span>\n          </div>\n        </div>\n        <div className=\"generation-info\">\n          <span className=\"style-badge\">{selectedStyle}</span>\n          <span className=\"style-text\">style</span>\n        </div>\n      </div>\n      <p className=\"loading-hint\">Creating your comic masterpiece...</p>\n    </div>\n  );\n};\n\nexport default LoadingSpinner;\nEOF\necho \"LoadingSpinner.tsx created\""}, {"cmd": "cat > /opt/AiComic/apps/frontend/src/components/Feedback/Toast.tsx << 'EOF'\nimport React from 'react';\nimport { useAppStore } from '../../store/useAppStore';\n\nconst Toast: React.FC = () => {\n  const { toasts, removeToast } = useAppStore();\n\n  if (toasts.length === 0) {\n    return null;\n  }\n\n  const getToastIcon = (type: string) => {\n    switch (type) {\n      case 'success':\n        return (\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\">\n            <path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\" />\n            <polyline points=\"22 4 12 14.01 9 11.01\" />\n          </svg>\n        );\n      case 'error':\n        return (\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\">\n            <circle cx=\"12\" cy=\"12\" r=\"10\" />\n            <line x1=\"15\" y1=\"9\" x2=\"9\" y2=\"15\" />\n            <line x1=\"9\" y1=\"9\" x2=\"15\" y2=\"15\" />\n          </svg>\n        );\n      case 'warning':\n        return (\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\">\n            <path d=\"M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z\" />\n            <line x1=\"12\" y1=\"9\" x2=\"12\" y2=\"13\" />\n            <line x1=\"12\" y1=\"17\" x2=\"12.01\" y2=\"17\" />\n          </svg>\n        );\n      default:\n        return (\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\">\n            <circle cx=\"12\" cy=\"12\" r=\"10\" />\n            <line x1=\"12\" y1=\"16\" x2=\"12\" y2=\"12\" />\n            <line x1=\"12\" y1=\"8\" x2=\"12.01\" y2=\"8\" />\n          </svg>\n        );\n    }\n  };\n\n  return (\n    <div className=\"toast-container\">\n      {toasts.map((toast) => (\n        <div key={toast.id} className={`toast toast-${toast.type}`}>\n          <div className=\"toast-icon\">{getToastIcon(toast.type)}</div>\n          <p className=\"toast-message\">{toast.message}</p>\n          <button\n            className=\"toast-close\"\n            onClick={() => removeToast(toast.id)}\n            aria-label=\"Dismiss\"\n          >\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\">\n              <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\" />\n              <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\" />\n            </svg>\n          </button>\n        </div>\n      ))}\n    </div>\n  );\n};\n\nexport default Toast;\nEOF\necho \"Toast.tsx created\""}, {"cmd": "cat > /opt/AiComic/apps/frontend/src/components/Feedback/ImagePreview.tsx << 'EOF'\nimport React from 'react';\nimport { useAppStore } from '../../store/useAppStore';\nimport { downloadImage, shareImage } from '../../api/comicApi';\n\nconst ImagePreview: React.FC = () => {\n  const { selectedImage, setSelectedImage, addToast } = useAppStore();\n  const [isLoading, setIsLoading] = React.useState(false);\n\n  if (!selectedImage) {\n    return null;\n  }\n\n  const handleBackdropClick = (e: React.MouseEvent) => {\n    if (e.target === e.currentTarget) {\n      setSelectedImage(null);\n    }\n  };\n\n  const handleDownload = async () => {\n    setIsLoading(true);\n    try {\n      const filename = `aicomic-${selectedImage.style}-full.png`;\n      await downloadImage(selectedImage.url, filename);\n      addToast({\n        type: 'success',\n        message: 'Image downloaded successfully!',\n      });\n    } catch (error) {\n      addToast({\n        type: 'error',\n        message: 'Failed to download image',\n      });\n    } finally {\n      setIsLoading(false);\n    }\n  };\n\n  const handleShare = async () => {\n    setIsLoading(true);\n    try {\n      const shared = await shareImage(selectedImage);\n      if (shared) {\n        addToast({\n          type: 'success',\n          message: 'Link copied to clipboard!',\n        });\n      }\n    } catch (error) {\n      addToast({\n        type: 'error',\n        message: 'Failed to share image',\n      });\n    } finally {\n      setIsLoading(false);\n    }\n  };\n\n  const handleKeyDown = (e: React.KeyboardEvent) => {\n    if (e.key === 'Escape') {\n      setSelectedImage(null);\n    }\n  };\n\n  return (\n    <div \n      className=\"modal-backdrop\"\n      onClick={handleBackdropClick}\n      onKeyDown={handleKeyDown}\n      role=\"dialog\"\n      aria-modal=\"true\"\n    >\n      <div className=\"modal-content\">\n        <button\n          className=\"modal-close\"\n          onClick={() => setSelectedImage(null)}\n          aria-label=\"Close modal\"\n        >\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\">\n            <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\" />\n            <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\" />\n          </svg>\n        </button>\n        <div className=\"modal-image-container\">\n          <img\n            src={selectedImage.url}\n            alt=\"Full size comic\"\n            className=\"modal-image\"\n          />\n        </div>\n        <div className=\"modal-info\">\n          <div className=\"modal-meta\">\n            <span className=\"modal-style\">{selectedImage.style}</span>\n            <span className=\"modal-date\">\n              {new Date(selectedImage.createdAt).toLocaleDateString()}\n            </span>\n          </div>\n          <div className=\"modal-actions\">\n            <button\n              className=\"modal-button primary\"\n              onClick={handleDownload}\n              disabled={isLoading}\n            >\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\">\n                <path d=\"M21 15V19C21 20.1 20.1 21 19 21H5C3.9 21 3 20.1 3 19V15\" />\n                <polyline points=\"7 10 12 15 17 10\" />\n                <line x1=\"12\" y1=\"15\" x2=\"12\" y2=\"3\" />\n              </svg>\n              Download\n            </button>\n            <button\n              className=\"modal-button secondary\"\n              onClick={handleShare}\n              disabled={isLoading}\n            >\n              <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\">\n                <circle cx=\"18\" cy=\"5\" r=\"3\" />\n                <circle cx=\"6\" cy=\"12\" r=\"3\" />\n                <circle cx=\"18\" cy=\"19\" r=\"3\" />\n                <line x1=\"8.59\" y1=\"13.51\" x2=\"15.42\" y2=\"17.49\" />\n                <line x1=\"15.41\" y1=\"6.51\" x2=\"8.59\" y2=\"10.49\" />\n              </svg>\n              Share\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n};\n\nexport default ImagePreview;\nEOF\necho \"ImagePreview.tsx created\""}, {"cmd": "cat > /opt/AiComic/apps/frontend/src/components/Feedback/index.ts << 'EOF'\nexport { default as LoadingSpinner } from './LoadingSpinner';\nexport { default as Toast } from './Toast';\nexport { default as ImagePreview } from './ImagePreview';\nEOF\n\ncat > /opt/AiComic/apps/frontend/src/components/Input/SubmitButton.tsx << 'EOF'\nimport React from 'react';\nimport { useAppStore } from '../../store/useAppStore';\nimport { mockGenerateComic } from '../../api/comicApi';\n\nconst SubmitButton: React.FC = () => {\n  const {\n    story,\n    selectedStyle,\n    isGenerating,\n    setIsGenerating,\n    setGeneratedImages,\n    setGenerationProgress,\n    setError,\n    addToast,\n    isStoryValid,\n  } = useAppStore();\n\n  const isDisabled = !isStoryValid() || isGenerating;\n\n  const handleGenerate = async () => {\n    if (!isStoryValid()) {\n      addToast({\n        type: 'warning',\n        message: 'Please enter a story with at least 10 characters',\n      });\n      return;\n    }\n\n    setIsGenerating(true);\n    setGenerationProgress(0);\n    setError(null);\n\n    try {\n      // Try real API first, fall back to mock if not available\n      let response;\n      try {\n        const { generateComic } = await import('../../api/comicApi');\n        response = await generateComic(\n          { story, style: selectedStyle },\n          setGenerationProgress\n        );\n      } catch (apiError) {\n        // Use mock API for development\n        console.log('Using mock API for development');\n        response = await mockGenerateComic(\n          { story, style: selectedStyle },\n          setGenerationProgress\n        );\n      }\n\n      setGeneratedImages(response.images);\n      addToast({\n        type: 'success',\n        message: `Generated ${response.images.length} comic images!`,\n      });\n\n      // Scroll to gallery\n      setTimeout(() => {\n        document.getElementById('gallery')?.scrollIntoView({ \n          behavior: 'smooth' \n        });\n      }, 300);\n    } catch (error: any) {\n      const errorMessage = error?.message || 'Failed to generate comics';\n      setError(errorMessage);\n      addToast({\n        type: 'error',\n        message: errorMessage,\n      });\n    } finally {\n      setIsGenerating(false);\n    }\n  };\n\n  return (\n    <div className=\"submit-container\">\n      <button\n        className={`generate-button ${isGenerating ? 'loading' : ''}`}\n        onClick={handleGenerate}\n        disabled={isDisabled}\n      >\n        {isGenerating ? (\n          <>\n            <span className=\"button-spinner\"></span>\n            Generating...\n          </>\n        ) : (\n          <>\n            <svg className=\"button-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2\">\n              <polygon points=\"13 2 3 14 12 14 11 22 21 10 12 10 13 2\" />\n            </svg>\n            Generate Comics\n          </>\n        )}\n      </button>\n      <p className=\"submit-hint\">\n        {isStoryValid() \n          ? `Ready to create ${selectedStyle} style comics!` \n          : 'Enter at least 10 characters to generate comics'}\n      </p>\n    </div>\n  );\n};\n\nexport default SubmitButton;\nEOF\necho \"SubmitButton.tsx created\""}, {"cmd": "cat > /opt/AiComic/apps/frontend/src/components/Input/index.ts << 'EOF'\nexport { default as StoryInput } from './StoryInput';\nexport { default as StyleSelector } from './StyleSelector';\nexport { default as SubmitButton } from './SubmitButton';\nEOF\necho \"Input index updated\""}, {"cmd": "cat > /opt/AiComic/apps/frontend/src/styles/index.css << 'EOF'\n/* AiComic Styles - Based on PROJECT_SPEC.md */\n\n/* CSS Variables - Color Palette */\n:root {\n  --color-primary: #6366f1;\n  --color-primary-hover: #4f46e5;\n  --color-secondary: #ec4899;\n  --color-accent: #f59e0b;\n  --color-background: #fafafa;\n  --color-surface: #ffffff;\n  --color-text: #1f2937;\n  --color-text-secondary: #6b7280;\n  --color-border: #e5e7eb;\n  --color-error: #ef4444;\n  --color-success: #10b981;\n  --color-warning: #f59e0b;\n  \n  /* Spacing */\n  --spacing-xs: 4px;\n  --spacing-sm: 8px;\n  --spacing-md: 16px;\n  --spacing-lg: 24px;\n  --spacing-xl: 32px;\n  --spacing-2xl: 48px;\n  \n  /* Border Radius */\n  --radius-sm: 6px;\n  --radius-md: 8px;\n  --radius-lg: 12px;\n  --radius-xl: 16px;\n  \n  /* Shadows */\n  --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);\n  --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);\n  --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);\n  --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);\n  \n  /* Transitions */\n  --transition-fast: 150ms ease-in-out;\n  --transition-normal: 200ms ease-in-out;\n  --transition-slow: 300ms ease-in-out;\n  \n  /* Font */\n  --font-family: \"Inter\", \"Noto Sans SC\", system-ui, -apple-system, sans-serif;\n}\n\n/* Reset & Base */\n*, *::before, *::after {\n  box-sizing: border-box;\n  margin: 0;\n  padding: 0;\n}\n\nhtml {\n  font-size: 16px;\n  scroll-behavior: smooth;\n}\n\nbody {\n  font-family: var(--font-family);\n  background-color: var(--color-background);\n  color: var(--color-text);\n  line-height: 1.6;\n  min-height: 100vh;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}\n\n/* App Container */\n#root {\n  min-height: 100vh;\n  display: flex;\n  flex-direction: column;\n}\n\n.app {\n  display: flex;\n  flex-direction: column;\n  min-height: 100vh;\n}\n\n/* Header */\n.header {\n  background: var(--color-surface);\n  border-bottom: 1px solid var(--color-border);\n  padding: var(--spacing-md) var(--spacing-lg);\n  position: sticky;\n  top: 0;\n  z-index: 100;\n}\n\n.header-content {\n  max-width: 1200px;\n  margin: 0 auto;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.logo {\n  display: flex;\n  align-items: center;\n  gap: var(--spacing-sm);\n  text-decoration: none;\n  color: var(--color-primary);\n}\n\n.logo-icon {\n  width: 32px;\n  height: 32px;\n}\n\n.logo-text {\n  font-size: 1.5rem;\n  font-weight: 700;\n  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n}\n\n.nav {\n  display: flex;\n  gap: var(--spacing-lg);\n}\n\n.nav-link {\n  color: var(--color-text-secondary);\n  text-decoration: none;\n  font-weight: 500;\n  padding: var(--spacing-sm) var(--spacing-md);\n  border-radius: var(--radius-md);\n  transition: var(--transition-fast);\n}\n\n.nav-link:hover, .nav-link.active {\n  color: var(--color-primary);\n  background: rgba(99, 102, 241, 0.1);\n}\n\n/* Main Content */\n.main-content {\n  flex: 1;\n  padding: var(--spacing-2xl) var(--spacing-lg);\n  max-width: 1200px;\n  margin: 0 auto;\n  width: 100%;\n}\n\n/* Hero Section */\n.hero {\n  text-align: center;\n  margin-bottom: var(--spacing-2xl);\n}\n\n.hero-title {\n  font-size: 2.5rem;\n  font-weight: 800;\n  margin-bottom: var(--spacing-md);\n  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n}\n\n.hero-subtitle {\n  font-size: 1.125rem;\n  color: var(--color-text-secondary);\n  max-width: 600px;\n  margin: 0 auto;\n}\n\n/* Create Section */\n.create-section {\n  display: grid;\n  gap: var(--spacing-xl);\n}\n\n/* Input Components */\n.story-input-container,\n.style-selector-container {\n  background: var(--color-surface);\n  border-radius: var(--radius-lg);\n  padding: var(--spacing-lg);\n  box-shadow: var(--shadow-md);\n}\n\n.input-label {\n  display: block;\n  font-size: 1rem;\n  font-weight: 600;\n  color: var(--color-text);\n  margin-bottom: var(--spacing-md);\n}\n\n.textarea-wrapper {\n  position: relative;\n}\n\n.story-textarea {\n  width: 100%;\n  padding: var(--spacing-md);\n  padding-right: 48px;\n  font-family: var(--font-family);\n  font-size: 1rem;\n  line-height: 1.6;\n  border: 2px solid var(--color-border);\n  border-radius: var(--radius-md);\n  resize: vertical;\n  min-height: 150px;\n  transition: var(--transition-fast);\n}\n\n.story-textarea:focus {\n  outline: none;\n  border-color: var(--color-primary);\n  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);\n}\n\n.story-textarea.error {\n  border-color: var(--color-error);\n}\n\n.story-textarea:disabled {\n  background: var(--color-background);\n  cursor: not-allowed;\n}\n\n.clear-button {\n  position: absolute;\n  top: var(--spacing-sm);\n  right: var(--spacing-sm);\n  width: 32px;\n  height: 32px;\n  border: none;\n  background: var(--color-background);\n  border-radius: var(--radius-sm);\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: var(--color-text-secondary);\n  transition: var(--transition-fast);\n}\n\n.clear-button:hover:not(:disabled) {\n  background: var(--color-error);\n  color: white;\n}\n\n.clear-button:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n.clear-button svg {\n  width: 16px;\n  height: 16px;\n}\n\n.character-count {\n  display: flex;\n  justify-content: flex-end;\n  margin-top: var(--spacing-sm);\n  font-size: 0.875rem;\n  gap: 2px;\n}\n\n.character-count .count {\n  font-weight: 600;\n  color: var(--color-text);\n}\n\n.character-count .count.warning {\n  color: var(--color-warning);\n}\n\n.character-count .count.error {\n  color: var(--color-error);\n}\n\n.character-count .separator,\n.character-count .limit {\n  color: var(--color-text-secondary);\n}\n\n/* Style Selector */\n.style-grid {\n  display: grid;\n  grid-template-columns: repea