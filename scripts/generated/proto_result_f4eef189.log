ated project: {project}\")\n    \n    # Test 3: Create characters\n    print(\"\\nTest 3: Create Characters\")\n    hero = Character(\n        project_id=project.id,\n        name='Hero',\n        description='The main protagonist',\n        personality='Brave and kind'\n    )\n    villain = Character(\n        project_id=project.id,\n        name='Villain',\n        description='The antagonist',\n        personality='Evil and cunning'\n    )\n    db.session.add_all([hero, villain])\n    db.session.commit()\n    print(f\"  Created characters: {hero.name}, {villain.name}\")\n    \n    # Test 4: Create frames\n    print(\"\\nTest 4: Create Frames\")\n    frame1 = Frame(\n        project_id=project.id,\n        sequence_order=1,\n        prompt='Hero standing on a hill',\n        status='completed'\n    )\n    frame2 = Frame(\n        project_id=project.id,\n        sequence_order=2,\n        prompt='Villain appears',\n        status='generating'\n    )\n    db.session.add_all([frame1, frame2])\n    db.session.commit()\n    print(f\"  Created frames: {frame1.sequence_order}, {frame2.sequence_order}\")\n    \n    # Test 5: Create dialogues\n    print(\"\\nTest 5: Create Dialogues\")\n    dialogue1 = Dialogue(\n        frame_id=frame1.id,\n        character_id=hero.id,\n        text='I will protect this land!',\n        position=1\n    )\n    dialogue2 = Dialogue(\n        frame_id=frame2.id,\n        character_id=villain.id,\n        text='Your time is up!',\n        position=1\n    )\n    db.session.add_all([dialogue1, dialogue2])\n    db.session.commit()\n    print(f\"  Created dialogues: {dialogue1.text[:20]}..., {dialogue2.text[:20]}...\")\n    \n    # Test 6: Create subscription\n    print(\"\\nTest 6: Create Subscription\")\n    subscription = Subscription(\n        user_id=user.id,\n        plan='premium',\n        status='active',\n        start_date=datetime.utcnow(),\n        end_date=datetime.utcnow() + timedelta(days=30)\n    )\n    db.session.add(subscripti