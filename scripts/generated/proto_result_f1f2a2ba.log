│          set({ loading: true, error: null });                                │
│          try {                                                               │
│            const response = await axios.post<ApiResponse<User & { token:     │
│  string }>>(                                                                 │
│              '/api/auth/login',                                              │
│              credentials                                                     │
│            );                                                                │
│            const { token, ...user } = response.data.data as User & { token:  │
│  string };                                                                   │
│            localStorage.setItem('token', token);                             │
