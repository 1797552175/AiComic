│  }                                                                           │
│                                                                              │
│  export const useAuthStore = create<AuthState>()(                            │
│    devtools(                                                                 │
│      (set, get) => ({                                                        │
│        user: null,                                                           │
│        isAuthenticated: false,                                               │
│        loading: false,                                                       │
│        error: null,                                                          │
│        token: localStorage.getItem('token'),                                 │
│                                                                              │
