│  ### `/opt/AiComic/src/stores/HistoryStore.ts`                               │
│                                                                              │
│  ```typescript                                                               │
│  import { create } from 'zustand';                                           │
│  import { devtools } from 'zustand/middleware';                              │
│  import axios from 'axios';                                                  │
│  import { Comic, Generation, ApiResponse } from '../types/types';            │
│                                                                              │
│  type HistoryItem = Comic | Generation;                                      │
│                                                                              │
│  interface HistoryState {                                                    │
│    items: HistoryItem[];                                                     │
│    loading: boolean;                                                         │
│    error: string | null;                                                     │
│    page: number;                                                             │
│    totalPages: number;                                                       │
│    hasMore: boolean;                                                         │
│                                                                              │
│    // Actions                                                                │
│    fetchHistory: () => Promise<void>;                                        │
│    fetchHistoryPage: (page: number) => Promise<void>;                        │
│    addToHistory: (item: HistoryItem) => void;                                │
│    clearHistory: () => void;                                                 │
│    loadMore: () => Promise<void>;                                            │
│    removeFromHistory: (id: string) => void;                                  │
│    setPage: (page: number) => void;                                          │
│  }                                                                           │
│                                                                              │
│  export const useHistoryStore = create<HistoryState>()(                      │
│    devtools(                                                                 │
│      (set, get) => ({                                                        │
│        items: [],                                                            │
│        loading: false,                                                       │
│        error: null,                                                          │
│        page: 1,                                                              │
│        totalPages: 1,                                                        │
│        hasMore: false,                                                       │
│                                                                              │
│        fetchHistory: async () => {                                           │
│          set({ loading: true, error: null });                                │
│          try {                                                               │
│            const response = await axios.get<ApiResponse<HistoryItem[]>>(     │
│              '/api/history'                                                  │
│            );                                                                │
│            set({                                                             │
│              items: response.data.data,                                      │
│              totalPages: response.data.pagination?.totalPages ?? 1,          │
│              hasMore:                                                        │
│                (response.data.pagination?.currentPage ?? 1) <                │
│                (response.data.pagination?.totalPages ?? 1),                  │
│              loading: false,                                                 │
│            });                                                               │
│          } catch (error) {                                                   │
│            set({                                                             │
│              error:                                                          │
│                error instanceof Error                                        │
│                  ? error.message                                             │
│                  : 'Failed to fetch history',                                │
│              loading: false,                                                 │
│            });                                                               │
│          }                                                                   │
│        },                                                                    │
│                                                                              │
│        fetchHistoryPage: async (page: number) => {                           │
│          set({ loading: true, error: null });                                │
│          try {                                                               │
│            const response = await axios.get<ApiResponse<HistoryItem[]>>(     │
│              `/api/history?page=${page}`                                     │
│            );                                                                │
│            const newItems =                                                  │
│              page === 1                                                      │
│                ? response.data.data                                          │
│                : [...get().items, ...response.data.data];                    │
│            set({                                                             │
│              items: newItems,                                                │
│              page,                                                           │
│              totalPages: response.data.pagination?.totalPages ?? 1,          │
│              hasMore:                                                        │
│                (response.data.pagination?.currentPage ?? page) <             │
│                (response.data.pagination?.totalPages ?? 1),                  │
│              loading: false,                                                 │
│            });                                                               │
│          } catch (error) {                                                   │
│            set({                                                             │
│              error:                                                          │
│                error instanceof Error                                        │
│                  ? error.message                                             │
│                  : 'Failed to fetch history',                                │
│              loading: false,                                                 │
│            });                                                               │
│          }                                                                   │
│        },                                                                    │
│                                                                              │
│        addToHistory: (item: HistoryItem) =>                                  │
│          set((state) => ({ items: [item, ...state.items] })),                │
│                                                                              │
│        clearHistory: () =>                                                   │
│          set({ items: [], page: 1, totalPages: 1, hasMore: false }),         │
│                                                                              │
│        loadMore: async () => {                                               │
│          const { page, hasMore, loading, fetchHistoryPage } = get();         │
│          if (!hasMore || loading) return;                                    │
│          await fetchHistoryPage(page + 1);                                   │
│        },                                                                    │
│                                                                              │
│        removeFromHistory: (id: string) =>                                    │
│          set((state) => ({                                                   │
│            items: state.items.filter((item) => item.id !== id),              │
│          })),                                                                │
│                                                                              │
│        setPage: (page: number) => set({ page }),                             │
│      }),                                                                     │
│      { name: 'HistoryStore' }                                                │
│    )                                                                         │
│  );                                                                          │
│  ```                                                                         │
