│          } catch (error) {                                                   │
│            set({                                                             │
│              error: error instanceof Error ? error.message : 'Login          │
│  failed',                                                                    │
│              loading: false,                                                 │
│            });                                                               │
│          }                                                                   │
│        },                                                                    │
│                                                                              │
