t({ loading: true, error: null });\n        try {\n          const { page, filters } = get();\n          const response = await axios.get<ApiResponse<Comic[]>>('/api/comics', {\n            params: {\n              page,\n              genre: filters.genre || undefined,\n              style: filters.style || undefined,\n              sortBy: filters.sortBy,\n            },\n          });\n          set({\n            comics: response.data.data,\n            totalPages: response.data.pagination?.totalPages ?? 1,\n            loading: false,\n          });\n        } catch (error) {\n          set({\n            error: error instanceof Error ? error.message : 'Failed to fetch comics',\n            loading: false,\n          });\n        }\n      },\n\n      fetchComicById: async (id: string) => {\n        set({ loading: true, error: null });\n        try {\n          const response = await axios.get<ApiResponse<Comic>>(`/api/comics/${id}`);\n          set({ currentComic: response.data.data, loading: false });\n        } catch (error) {\n          set({\n            error: error instanceof Error ? error.message : 'Failed to fetch comic',\n            loading: false,\n          });\n        }\n      },\n\n      searchComics: async (query: string) => {\n        set({ searchQuery: query, page: 1 });\n        if (!query.trim()) {\n          get().fetchComics();\n          return;\n        }\n        set({ loading: true, error: null });\n        try {\n          const response = await axios.get<ApiResponse<Comic[]>>(\n            `/api/comics/search?q=${encodeURIComponent(query)}`\n          );\n          set({\n            comics: response.data.data,\n            totalPages: response.data.pagination?.totalPages ?? 1,\n            loading: false,\n          });\n        } catch (error) {\n          set({\n            error: error instanceof Error ? error.message : 'Search failed',\n            loading: false,\n          });\n        }\n      },\n\n      setPage: (page: number) => set({ page }),\n\n      setFilters: (filters: Partial<ComicFilters>) =>\n        set((state) => ({\n          filters: { ...state.filters, ...filters },\n          page: 1,\n        })),\n\n      clearError: () => set({ error: null }),\n    }),\n    { name: 'ComicStore' }\n  )\n);\nENDOFFILE\necho \"ComicStore.ts written\""}, {"cmd": "cat > /opt/AiComic/src/stores/GenerationStore.ts << 'ENDOFFILE'\nimport { create } from 'zustand';\nimport { devtools } from 'zustand/middleware';\nimport axios from 'axios';\nimport { Generation, ApiResponse } from '../types/types';\n\ninterface GenerationStatus {\n  status: 'idle' | 'generating' | 'completed' | 'failed';\n  progress: number;\n}\n\ninterface GenerationState extends GenerationStatus {\n  generations: Generation[];\n  currentGeneration: Generation | null;\n  loading: boolean;\n  error: string | null;\n\n  // Actions\n  generateComic: (params: GenerateParams) => Promise<void>;\n  fetchGenerations: () => Promise<void>;\n  fetchGenerationById: (id: string) => Promise<void>;\n  cancelGeneration: () => void;\n  clearError: () => void;\n  resetStatus: () => void;\n}\n\nexport interface GenerateParams {\n  prompt: string;\n  style?: string;\n  pages?: number;\n  genre?: string;\n}\n\nexport const useGenerationStore = create<GenerationState>()(\n  devtools(\n    (set, get) => ({\n      generations: [],\n      currentGeneration: null,\n      loading: false,\n      error: null,\n      progress: 0,\n      status: 'idle',\n\n      generateComic: async (params: GenerateParams) => {\n        set({ status: 'generating', progress: 0, error: null });\n        try {\n          const response = await axios.post<ApiResponse<Generation>>(\n            '/api/generate',\n            params\n          );\n          const newGeneration = response.data.data;\n          set((state) => ({\n            currentGeneration: newGeneration,\n            generations: [newGeneration, ...state.generations],\n            status: 'completed',\n            progress: 100,\n          }));\n        } catch (error) {\n          set({\n            error: error instanceof Error ? error.message : 'Generation failed',\n            status: 'failed',\n          });\n        }\n      },\n\n      fetchGenerations: async () => {\n        set({ loading: true, error: null });\n        try {\n          const response = await axios.get<ApiResponse<Generation[]>>(\n            '/api/generations'\n          );\n          set({ generations: response.data.data, loading: false });\n        } catch (error) {\n          set({\n            error:\n              error instanceof Error\n                ? error.message\n                : 'Failed to fetch generations',\n            loading: false,\n          });\n        }\n      },\n\n      fetchGenerationById: async (id: string) => {\n        set({ loading: true, error: null });\n        try {\n          const response = await axios.get<ApiResponse<Generation>>(\n            `/api/generations/${id}`\n          );\n          set({ currentGeneration: response.data.data, loading: false });\n        } catch (error) {\n          set({\n            error:\n              error instanceof Error\n                ? error.message\n                : 'Failed to fetch generation',\n            loading: false,\n          });\n        }\n      },\n\n      cancelGeneration: () => {\n        set({ status: 'idle', progress: 0 });\n      },\n\n      clearError: () => set({ error: null }),\n\n      resetStatus: () => set({ status: 'idle', progress: 0 }),\n    }),\n    { name: 'GenerationStore' }\n  )\n);\nENDOFFILE\necho \"GenerationStore.ts written\""}, {"cmd": "cat > /opt/AiComic/src/stores/UIStore.ts << 'ENDOFFILE'\nimport { create } from 'zustand';\nimport { devtools } from 'zustand/middleware';\n\ninterface UIState {\n  sidebarOpen: boolean;\n  modalOpen: boolean;\n  activeModal: string | null;\n  searchQuery: string;\n  activeView: 'grid' | 'list';\n\n  // Global loading overlay\n  globalLoading: boolean;\n  loadingMessage: string;\n\n  // Actions\n  toggleSidebar: () => void;\n  openModal: (modalId: string) => void;\n  closeModal: () => void;\n  setSearchQuery: (query: string) => void;\n  setActiveView: (view: 'grid' | 'list') => void;\n  setGlobalLoading: (loading: boolean, message?: string) => void;\n  resetUI: () => void;\n}\n\nexport const useUIStore = create<UIState>()(\n  devtools(\n    (set) => ({\n      sidebarOpen: true,\n      modalOpen: false,\n      activeModal: null,\n      searchQuery: '',\n      activeView: 'grid',\n      globalLoading: false,\n      loadingMessage: '',\n\n      toggleSidebar: () =>\n        set((state) => ({ sidebarOpen: !state.sidebarOpen })),\n\n      openModal: (modalId: string) =>\n        set({ modalOpen: true, activeModal: modalId }),\n\n      closeModal: () => set({ modalOpen: false, activeModal: null }),\n\n      setSearchQuery: (query: string) => set({ searchQuery: query }),\n\n      setActiveView: (view: 'grid' | 'list') => set({ activeView: view }),\n\n      setGlobalLoading: (loading: boolean, message?: string) =>\n        set({ globalLoading: loading, loadingMessage: message || '' }),\n\n      resetUI: () =>\n        set({\n          sidebarOpen: true,\n          modalOpen: false,\n          activeModal: null,\n          searchQuery: '',\n          globalLoading: false,\n          loadingMessage: '',\n        }),\n    }),\n    { name: 'UIStore' }\n  )\n);\nENDOFFILE\necho \"UIStore.ts written\""}, {"cmd": "cat > /opt/AiComic/src/stores/ThemeStore.ts << 'ENDOFFILE'\nimport { create } from 'zustand';\nimport { persist } from 'zustand/middleware';\nimport { devtools } from 'zustand/middleware';\n\ninterface ThemeState {\n  theme: 'light' | 'dark';\n  toggleTheme: () => void;\n}\n\nexport const useThemeStore = create<ThemeState>()(\n  devtools(\n    persist(\n      (set) => ({\n        theme: 'light' as const,\n        toggleTheme: () =>\n          set((state) => ({\n            theme: state.theme === 'light' ? 'dark' : 'light',\n          })),\n      }),\n      { name: 'theme-storage' }\n    ),\n    { name: 'ThemeStore' }\n  )\n);\nENDOFFILE\necho \"ThemeStore.ts written\""}, {"cmd": "cat > /opt/AiComic/src/stores/ToastStore.ts << 'ENDOFFILE'\nimport { create } from 'zustand';\nimport { devtools } from 'zustand/middleware';\n\nexport interface ToastItem {\n  id: string;\n  message: string;\n  type: 'success' | 'error' | 'warning' | 'info';\n  duration: number;\n}\n\ninterface ToastState {\n  toasts: ToastItem[];\n\n  // Actions\n  addToast: (toast: Omit<ToastItem, 'id'>) => void;\n  removeToast: (id: string) => void;\n  clearToasts: () => void;\n}\n\nexport const useToastStore = create<ToastState>()(\n  devtools(\n    (set, get) => ({\n      toasts: [],\n\n      addToast: (toast) => {\n        const id = Math.random().toString(36).substring(2, 9);\n        set((state) => ({ toasts: [...state.toasts, { ...toast, id }] }));\n\n        // Auto-remove after duration\n        setTimeout(() => {\n          const current = get().toasts.find((t) => t.id === id);\n          if (current) {\n            get().removeToast(id);\n          }\n        }, toast.duration || 3000);\n      },\n\n      removeToast: (id: string) =>\n        set((state) => ({ toasts: state.toasts.filter((t) => t.id !== id) })),\n\n      clearToasts: () => set({ toasts: [] }),\n    }),\n    { name: 'ToastStore' }\n  )\n);\nENDOFFILE\necho \"ToastStore.ts written\""}, {"cmd": "cat > /opt/AiComic/src/stores/AuthStore.ts << 'ENDOFFILE'\nimport { create } from 'zustand';\nimport { devtools } from 'zustand/middleware';\nimport axios from 'axios';\nimport { User, LoginCredentials, RegisterData, ApiResponse } from '../types/types';\n\ninterface AuthState {\n  user: User | null;\n  isAuthenticated: boolean;\n  loading: boolean;\n  error: string | null;\n  token: string | null;\n\n  // Actions\n  login: (credentials: LoginCredentials) => Promise<void>;\n  logout: () => void;\n  register: (data: RegisterData) => Promise<void>;\n  checkAuth: () => Promise<void>;\n  updateProfile: (data: Partial<User>) => Promise<void>;\n}\n\nexport const useAuthStore = create<AuthState>()(\n  devtools(\n    (set, get) => ({\n      user: null,\n      isAuthenticated: false,\n      loading: false,\n      error: null,\n      token: localStorage.getItem('token'),\n\n      login: async (credentials: LoginCredentials) => {\n        set({ loading: true, error: null });\n        try {\n          const response = await axios.post<ApiResponse<User & { token: string }>>(\n            '/api/auth/login',\n            credentials\n          );\n          const { token, ...user } = response.data.data as User & { token: string };\n          localStorage.setItem('token', token);\n          set({ user, isAuthenticated: true, token, loading: false });\n        } catch (error) {\n          set({\n            error:\n              error instanceof Error ? error.message : 'Login failed',\n            loading: false,\n          });\n        }\n      },\n\n      logout: () => {\n        localStorage.removeItem('token');\n        set({ user: null, isAuthenticated: false, token: null });\n        window.location.href = '/login';\n      },\n\n      register: async (data: RegisterData) => {\n        set({ loading: true, error: null });\n        try {\n          const response = await axios.post<ApiResponse<User & { token: string }>>(\n            '/api/auth/register',\n            data\n          );\n          const { token, ...user } = response.data.data as User & { token: string };\n          localStorage.setItem('token', token);\n          set({ user, isAuthenticated: true, token, loading: false });\n        } catch (error) {\n          set({\n            error:\n              error instanceof Error ? error.message : 'Registration failed',\n            loading: false,\n          });\n        }\n      },\n\n      checkAuth: async () => {\n        const token = localStorage.getItem('token');\n        if (!token) {\n          set({ isAuthenticated: false, user: null });\n          return;\n        }\n        set({ loading: true });\n        try {\n          const response = await axios.get<ApiResponse<User>>('/api/auth/me');\n          set({\n            user: response.data.data,\n            isAuthenticated: true,\n            token,\n            loading: false,\n          });\n        } catch {\n          localStorage.removeItem('token');\n          set({ user: null, isAuthenticated: false, token: null, loading: false });\n        }\n      },\n\n      updateProfile: async (data: Partial<User>) => {\n        set({ loading: true, error: null });\n        try {\n          const response = await axios.patch<ApiResponse<User>>(\n            '/api/auth/profile',\n            data\n          );\n          set({ user: response.data.data, loading: false });\n        } catch (error) {\n          set({\n            error:\n              error instanceof Error\n                ? error.message\n                : 'Profile update failed',\n            loading: false,\n          });\n        }\n      },\n    }),\n    { name: 'AuthStore' }\n  )\n);\nENDOFFILE\necho \"AuthStore.ts written\""}, {"cmd": "cat > /opt/AiComic/src/stores/HistoryStore.ts << 'ENDOFFILE'\nimport { create } from 'zustand';\nimport { devtools } from 'zustand/middleware';\nimport axios from 'axios';\nimport { Comic, Generation, ApiResponse } from '../types/types';\n\ntype HistoryItem = Comic | Generation;\n\ninterface HistoryState {\n  items: HistoryItem[];\n  loading: boolean;\n  error: string | null;\n  page: number;\n  totalPages: number;\n  hasMore: boolean;\n\n  // Actions\n  fetchHistory: () => Promise<void>;\n  fetchHistoryPage: (page: number) => Promise<void>;\n  addToHistory: (item: HistoryItem) => void;\n  clearHistory: () => void;\n  loadMore: () => Promise<void>;\n  removeFromHistory: (id: string) => void;\n  setPage: (page: number) => void;\n}\n\nexport const useHistoryStore = create<HistoryState>()(\n  devtools(\n    (set, get) => ({\n      items: [],\n      loading: false,\n      error: null,\n      page: 1,\n      totalPages: 1,\n      hasMore: false,\n\n      fetchHistory: async () => {\n        set({ loading: true, error: null });\n        try {\n          const response = await axios.get<ApiResponse<HistoryItem[]>>(\n            '/api/history'\n          );\n          set({\n            items: response.data.data,\n            totalPages: response.data.pagination?.totalPages ?? 1,\n            hasMore:\n              (response.data.pagination?.currentPage ?? 1) <\n              (response.data.pagination?.totalPages ?? 1),\n            loading: false,\n          });\n        } catch (error) {\n          set({\n            error:\n              error instanceof Error\n                ? error.message\n                : 'Failed to fetch history',\n            loading: false,\n          });\n        }\n      },\n\n      fetchHistoryPage: async (page: number) => {\n        set({ loading: true, error: null });\n        try {\n          const response = await axios.get<ApiResponse<HistoryItem[]>>(\n            `/api/history?page=${page}`\n          );\n          const newItems =\n            page === 1\n              ? response.data.data\n              : [...get().items, ...response.data.data];\n          set({\n            items: newItems,\n            page,\n            totalPages: response.data.pagination?.totalPages ?? 1,\n            hasMore:\n              (response.data.pagination?.currentPage ?? page) <\n              (response.data.pagination?.totalPages ?? 1),\n            loading: false,\n          });\n        } catch (error) {\n          set({\n            error:\n              error instanceof Error\n                ? error.message\n                : 'Failed to fetch history',\n            loading: false,\n          });\n        }\n      },\n\n      addToHistory: (item: HistoryItem) =>\n        set((state) => ({ items: [item, ...state.items] })),\n\n      clearHistory: () =>\n        set({ items: [], page: 1, totalPages: 1, hasMore: false }),\n\n      loadMore: async () => {\n        const { page, hasMore, loading, fetchHistoryPage } = get();\n        if (!hasMore || loading) return;\n        await fetchHistoryPage(page + 1);\n      },\n\n      removeFromHistory: (id: string) =>\n        set((state) => ({\n          items: state.items.filter((item) => item.id !== id),\n        })),\n\n      setPage: (page: number) => set({ page }),\n    }),\n    { name: 'HistoryStore' }\n  )\n);\nENDOFFILE\necho \"HistoryStore.ts written\""}, {"cmd": "cat > /opt/AiComic/src/stores/hooks.ts << 'ENDOFFILE'\n// Typed store hooks for Zustand stores\n// These provide a consistent interface for accessing stores across the app\n\nexport { useComicStore } from './ComicStore';\nexport { useGenerationStore } from './GenerationStore';\nexport { useUIStore } from './UIStore';\nexport { useThemeStore } from './ThemeStore';\nexport { useToastStore } from './ToastStore';\nexport { useAuthStore } from './AuthStore';\nexport { useHistoryStore } from './HistoryStore';\nENDOFFILE\necho \"hooks.ts written\""}, {"cmd": "cat > /opt/AiComic/src/stores/index.ts << 'ENDOFFILE'\n// Central export for all Zustand stores\n\nexport { useComicStore } from './ComicStore';\nexport { useGenerationStore } from './GenerationStore';\nexport { useUIStore } from './UIStore';\nexport { useThemeStore } from './ThemeStore';\nexport { useToastStore } from './ToastStore';\nexport { useAuthStore } from './AuthStore';\nexport { useHistoryStore } from './HistoryStore';\n\n// Re-export hooks for convenience\nexport * from './hooks';\n\n// Re-export types\nexport type {\n  ComicFilters,\n  ComicState,\n} from './ComicStore';\nexport type {\n  GenerationState,\n  GenerateParams,\n} from './GenerationStore';\nexport type { UIState } from './UIStore';\nexport type { ThemeState } from './ThemeStore';\nexport type { ToastItem, ToastState } from './ToastStore';\nexport type { AuthState } from './AuthStore';\nexport type { HistoryState } from './HistoryStore';\nENDOFFILE\necho \"index.ts written\""}, {"cmd": "cat > /opt/AiComic/src/lib/api.ts << 'ENDOFFILE'\nimport axios from 'axios';\nimport { Comic, Generation, User, ApiResponse } from '../types/types';\n\n// =============================================================================\n// Axios client setup\n// =============================================================================\n\nconst api = axios.create({\n  baseURL: import.meta.env.VITE_API_URL || 'http://localhost:3001/api',\n  timeout: 30000,\n  headers: {\n    'Content-Type': 'application/json',\n  },\n});\n\n// Request interceptor: attach auth token\napi.interceptors.request.use(\n  (config) => {\n    const token = localStorage.getItem('token');\n    if (token) {\n      config.headers.Authorization = `Bearer ${token}`;\n    }\n    return config;\n  },\n  (error) => Promise.reject(error)\n);\n\n// Response interceptor: handle 401 globally\napi.interceptors.response.use(\n  (response) => response,\n  (error) => {\n    if (error.response?.status === 401) {\n      localStorage.removeItem('token');\n      window.location.href = '/login';\n    }\n    return Promise.reject(error);\n  }\n);\n\n// =============================================================================\n// Comic API\n// =============================================================================\n\nexport interface FetchComicsParams {\n  page?: number;\n  genre?: string;\n  style?: string;\n  sortBy?: string;\n}\n\nexport const fetchComics = async (\n  params?: FetchComicsParams\n): Promise<Comic[]> => {\n  const response = await api.get<ApiResponse<Comic[]>>('/comics', { params });\n  return response.data.data;\n};\n\nexport const fetchComicById = async (id: string): Promise<Comic> => {\n  const response = await api.get<ApiResponse<Comic>>(`/comics/${id}`);\n  return response.data.data;\n};\n\nexport const searchComics = async (query: string): Promise<Comic[]> => {\n  const response = aw