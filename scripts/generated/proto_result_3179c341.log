│  ### components/ComicList.tsx                                                │
│  ```tsx                                                                      │
│  import { useState, useEffect, useCallback } from 'react';                   │
│  import { ComicCard } from './ComicCard';                                    │
│  import './ComicList.css';                                                   │
│                                                                              │
│  interface Comic {                                                           │
│    id: string;                                                               │
│    image_url: string;                                                        │
│    prompt: string;                                                           │
│    status: string;                                                           │
│    created_at?: string;                                                      │
│  }                                                                           │
│                                                                              │
│  interface ComicListProps {                                                  │
│    refreshTrigger?: number;                                                  │
│    newComic?: Comic | null;                                                  │
│  }                                                                           │
│                                                                              │
│  export function ComicList({ refreshTrigger = 0, newComic }:                 │
│  ComicListProps) {                                                           │
│    const [comics, setComics] = useState<Comic[]>([]);                        │
│    const [loading, setLoading] = useState(true);                             │
│    const [error, setError] = useState<string | null>(null);                  │
│                                                                              │
│    const fetchComics = useCallback(async () => {                             │
│      setLoading(true);                                                       │
│      setError(null);                                                         │
│                                                                              │
│      try {                                                                   │
│        const response = await fetch('/api/comics');                          │
│        if (!response.ok) {                                                   │
│          throw new Error('获取漫画列表失败');                                │
│        }                                                                     │
│        const data = await response.json();                                   │
│        setComics(data);                                                      │
│      } catch (err) {                                                         │
│        setError(err instanceof Error ? err.message : '发生未知错误');        │
│      } finally {                                                             │
│        setLoading(false);                                                    │
│      }                                                                       │
│    }, []);                                                                   │
│                                                                              │
│    useEffect(() => {                                                         │
│      fetchComics();                                                          │
│    }, [fetchComics, refreshTrigger]);                                        │
│                                                                              │
│    useEffect(() => {                                                         │
│      if (newComic) {                                                         │
│        setComics((prev) => [newComic, ...prev]);                             │
│      }                                                                       │
│    }, [newComic]);                                                           │
│                                                                              │
│    const handleDelete = async (id: string) => {                              │
│      if (!window.confirm('确定要删除这个漫画吗？')) {                        │
│        return;                                                               │
│      }                                                                       │
│                                                                              │
│      try {                                                                   │
│        const response = await fetch(`/api/comics/${id}`, {                   │
│          method: 'DELETE',                                                   │
│        });                                                                   │
│                                                                              │
│        if (!response.ok) {                                                   │
│          throw new Error('删除失败');                                        │
│        }                                                                     │
│                                                                              │
│        setComics((prev) => prev.filter((comic) => comic.id !== id));         │
│      } catch (err) {                                                         │
│        alert(err instanceof Error ? err.message : '删除失败');               │
│      }                                                                       │
│    };                                                                        │
│                                                                              │
│    if (loading) {                                                            │
│      return (                                                                │
│        <div className="comic-list-loading">                                  │
│          <div className="loading-spinner-large"></div>                       │
│          <p>加载漫画中...</p>                                                │
│        </div>                                                                │
│      );                                                                      │
│    }                                                                         │
│                                                                              │
│    if (error) {                                                              │
│      return (                                                                │
│        <div className="comic-list-error">                                    │
│          <span className="error-icon">⚠️</span>                              │
│          <p>{error}</p>                                                      │
│          <button onClick={fetchComics} className="retry-btn">                │
│            重试                                                              │
│          </button>                                                           │
│        </div>                                                                │
│      );                                                                      │
│    }                                                                         │
│                                                                              │
│    if (comics.length === 0) {                                                │
│      return (                                                                │
│        <div className="comic-list-empty">                                    │
│          <span className="empty-icon">🎨</span>                              │
│          <h3>还没有漫画</h3>                                                 │
│          <p>开始创作你的第一幅AI漫画吧！</p>                                 │
│        </div>                                                                │
│      );                                                                      │
│    }                                                                         │
│                                                                              │
│    return (                                                                  │
│      <div className="comic-list">                                            │
│        <div className="comic-list-header">                                   │
│          <h3>📸 我的作品</h3>                                                │
│          <span className="comic-count">{comics.length} 幅漫画</span>         │
│        </div>                                                                │
│        <div className="comic-grid">                                          │
│          {comics.map((comic) => (                                            │
│            <ComicCard key={comic.id} comic={comic} onDelete={handleDelete}   │
│  />                                                                          │
│          ))}                                                                 │
│        </div>                                                                │
│      </div>                                                                  │
│    );                                                                        │
│  }                                                                           │
│                                                                              │
│  export default ComicList;                                                   │
│  ```                                                                         │
