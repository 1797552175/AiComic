│  ### components/ComicGenerator.tsx                                           │
│  ```tsx                                                                      │
│  import { useState } from 'react';                                           │
│  import './ComicGenerator.css';                                              │
│                                                                              │
│  interface ComicGeneratorProps {                                             │
│    onComicCreated?: (comic: Comic) => void;                                  │
│  }                                                                           │
│                                                                              │
│  interface Comic {                                                           │
│    id: string;                                                               │
│    image_url: string;                                                        │
│    prompt: string;                                                           │
│    status: string;                                                           │
│  }                                                                           │
│                                                                              │
│  export function ComicGenerator({ onComicCreated }: ComicGeneratorProps) {   │
│    const [prompt, setPrompt] = useState('');                                 │
│    const [loading, setLoading] = useState(false);                            │
│    const [error, setError] = useState<string | null>(null);                  │
│                                                                              │
│    const handleSubmit = async (e: React.FormEvent) => {                      │
│      e.preventDefault();                                                     │
│      if (!prompt.trim()) {                                                   │
│        setError('请输入漫画描述');                                           │
│        return;                                                               │
│      }                                                                       │
│                                                                              │
│      setLoading(true);                                                       │
│      setError(null);                                                         │
│                                                                              │
│      try {                                                                   │
│        const response = await fetch('/api/comics', {                         │
│          method: 'POST',                                                     │
│          headers: {                                                          │
│            'Content-Type': 'application/json',                               │
│          },                                                                  │
│          body: JSON.stringify({ prompt: prompt.trim() }),                    │
│        });                                                                   │
│                                                                              │
│        if (!response.ok) {                                                   │
│          throw new Error('生成失败，请重试');                                │
│        }                                                                     │
│                                                                              │
│        const comic: Comic = await response.json();                           │
│        setPrompt('');                                                        │
│        onComicCreated?.(comic);                                              │
│      } catch (err) {                                                         │
│        setError(err instanceof Error ? err.message : '发生未知错误');        │
│      } finally {                                                             │
│        setLoading(false);                                                    │
│      }                                                                       │
│    };                                                                        │
│                                                                              │
│    return (                                                                  │
│      <div className="comic-generator">                                       │
│        <div className="generator-header">                                    │
│          <h2>🎨 生成你的漫画</h2>                                            │
│          <p>输入描述，AI将为你创作独特的漫画作品</p>                         │
│        </div>                                                                │
│                                                                              │
│        <form onSubmit={handleSubmit} className="generator-form">             │
│          <div className="input-group">                                       │
│            <textarea                                                         │
│              className="prompt-input"                                        │
│              value={prompt}                                                  │
│              onChange={(e) => setPrompt(e.target.value)}                     │
│              placeholder="描述你想要生成的漫画场景...\n例如：一只可爱的熊猫  │
│  在竹林里练习功夫"                                                           │
│              rows={4}                                                        │
│              disabled={loading}                                              │
│            />                                                                │
│          </div>                                                              │
│                                                                              │
│          {error && (                                                         │
│            <div className="error-message">                                   │
│              ⚠️ {error}                                                      │
│            </div>                                                            │
│          )}                                                                  │
│                                                                              │
│          <button                                                             │
│            type="submit"                                                     │
│            className={`generate-btn ${loading ? 'loading' : ''}`}            │
│            disabled={loading}                                                │
│          >                                                                   │
│            {loading ? (                                                      │
│              <>                                                              │
│                <span className="spinner"></span>                             │
│                生成中...                                                     │
│              </>                                                             │
│            ) : (                                                             │
│              <>✨ 生成漫画</>                                                │
│            )}                                                                │
│          </button>                                                           │
│        </form>                                                               │
│                                                                              │
│        <div className="tips">                                                │
│          <h4>💡 小贴士</h4>                                                  │
│          <ul>                                                                │
│            <li>描述越详细，生成效果越好</li>                                 │
│            <li>可以指定角色、场景、动作、情绪</li>                           │
│            <li>支持中英文描述</li>                                           │
│          </ul>                                                               │
│        </div>                                                                │
│      </div>                                                                  │
│    );                                                                        │
│  }                                                                           │
│                                                                              │
│  export default ComicGenerator;                                              │
│  ```                                                                         │
