│    const [loading, setLoading] = useState(true);                             │
│    const [error, setError] = useState<string | null>(null);                  │
│    const [refreshTrigger, setRefreshTrigger] = useState(0);                  │
│    const [newComic, setNewComic] = useState<Comic | null>(null);             │
│                                                                              │
│    useEffect(() => {                                                         │
│      fetchComics();                                                          │
│    }, [refreshTrigger]);                                                     │
│                                                                              │
