│  ### components/ComicCard.tsx                                                │
│  ```tsx                                                                      │
│  import { useState } from 'react';                                           │
│  import './ComicCard.css';                                                   │
│                                                                              │
│  interface Comic {                                                           │
│    id: string;                                                               │
│    image_url: string;                                                        │
│    prompt: string;                                                           │
│    status: string;                                                           │
│  }                                                                           │
│                                                                              │
│  interface ComicCardProps {                                                  │
│    comic: Comic;                                                             │
│    onDelete?: (id: string) => void;                                          │
│  }                                                                           │
│                                                                              │
│  export function ComicCard({ comic, onDelete }: ComicCardProps) {            │
│    const [imageLoaded, setImageLoaded] = useState(false);                    │
│    const [imageError, setImageError] = useState(false);                      │
│                                                                              │
│    const handleDelete = () => {                                              │
│      if (onDelete) {                                                         │
│        onDelete(comic.id);                                                   │
│      }                                                                       │
│    };                                                                        │
│                                                                              │
│    return (                                                                  │
│      <div className="comic-card">                                            │
│        <div className="comic-image-container">                               │
│          {!imageLoaded && !imageError && (                                   │
│            <div className="image-placeholder">                               │
│              <span className="loading-spinner"></span>                       │
│              <p>加载中...</p>                                                │
│            </div>                                                            │
│          )}                                                                  │
│          {imageError ? (                                                     │
│            <div className="image-error">                                     │
│              <span className="error-icon">⚠️</span>                          │
│              <p>图片加载失败</p>                                             │
│            </div>                                                            │
│          ) : (                                                               │
│            <img                                                              │
│              src={comic.image_url}                                           │
│              alt={comic.prompt}                                              │
│              className={`comic-image ${imageLoaded ? 'loaded' : ''}`}        │
│              onLoad={() => setImageLoaded(true)}                             │
│              onError={() => setImageError(true)}                             │
│            />                                                                │
│          )}                                                                  │
│          <div className="comic-status">                                      │
│            {comic.status === 'completed' ? (                                 │
│              <span className="status-completed">✓ 已完成</span>              │
│            ) : comic.status === 'processing' ? (                             │
│              <span className="status-processing">⏳ 处理中</span>            │
│            ) : (                                                             │
│              <span className="status-pending">📝 待处理</span>               │
│            )}                                                                │
│          </div>                                                              │
│        </div>                                                                │
│                                                                              │
│        <div className="comic-content">                                       │
│          <div className="comic-prompt">                                      │
│            <span className="prompt-label">📝 描述</span>                     │
│            <p className="prompt-text">{comic.prompt}</p>                     │
│          </div>                                                              │
│                                                                              │
│          <div className="comic-footer">                                      │
│            <span className="comic-id">ID: {comic.id.slice(0, 8)}...</span>   │
│            <div className="comic-actions">                                   │
│              <button                                                         │
│                className="action-btn download-btn"                           │
│                onClick={() => window.open(comic.image_url, '_blank')}        │
│                title="下载图片"                                              │
│              >                                                               │
│                ⬇️ 下载                                                       │
│              </button>                                                       │
│              <button                                                         │
│                className="action-btn share-btn"                              │
│                onClick={() => {                                              │
│                  navigator.clipboard.writeText(comic.image_url);             │
│                }}                                                            │
│                title="复制链接"                                              │
│              >                                                               │
│                🔗 分享                                                       │
│              </button>                                                       │
│              {onDelete && (                                                  │
│                <button                                                       │
│                  className="action-btn delete-btn"                           │
│                  onClick={handleDelete}                                      │
│                  title="删除"                                                │
│                >                                                             │
│                  🗑️ 删除                                                     │
│                </button>                                                     │
│              )}                                                              │
│            </div>                                                            │
│          </div>                                                              │
│        </div>                                                                │
│      </div>                                                                  │
│    );                                                                        │
│  }                                                                           │
│                                                                              │
│  export default ComicCard;                                                   │
│  ```                                                                         │
