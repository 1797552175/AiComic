on\nfrom .project import Project, ProjectScene, ProjectCharacter\nfrom .script import Script, ScriptLine\nfrom .video import Video, VideoFrame, VideoAudio\nfrom .user import User, UserProject\n\n__all__ = [\n    # Database utilities\n    \"Base\",\n    \"get_db\",\n    \"init_db\",\n    \"SessionLocal\",\n    # User models\n    \"User\",\n    \"UserProject\",\n    # Project models\n    \"Project\",\n    \"ProjectScene\",\n    \"ProjectCharacter\",\n    # Character models\n    \"Character\",\n    \"CharacterAppearance\",\n    \"CharacterExpression\",\n    # Script models\n    \"Script\",\n    \"ScriptLine\",\n    # Video models\n    \"Video\",\n    \"VideoFrame\",\n    \"VideoAudio\",\n]\nEOF"}, {"cmd": "ls -la /opt/AiComic/apps/backend/models/"}, {"cmd": "cd /opt/AiComic && python3 << 'EOF'\nfrom apps.backend.models import (\n    Base, init_db, SessionLocal,\n    User, UserProject,\n    Project, ProjectScene, ProjectCharacter,\n    Character, CharacterAppearance, CharacterExpression,\n    Script, ScriptLine,\n    Video, VideoFrame, VideoAudio\n)\nfrom datetime import datetime\n\n# Create a test session\ndb = SessionLocal()\n\n# Test creating a user\nuser = User(\n    username=\"testuser\",\n    email=\"test@example.com\",\n    hashed_password=\"hashedpassword\",\n    full_name=\"Test User\"\n)\ndb.add(user)\ndb.commit()\ndb.refresh(user)\nprint(f\"Created User: {user.id} - {user.username}\")\n\n# Test creating a project\nproject = Project(\n    name=\"Test Comic\",\n    description=\"A test comic project\",\n    user_id=user.id\n)\ndb.add(project)\ndb.commit()\ndb.refresh(project)\nprint(f\"Created Project: {project.id} - {project.name}\")\n\n# Test creating a character\ncharacter = Character(\n    name=\"Hero\",\n    description=\"The main hero of the story\",\n    voice_config={\"voice_id\": \"voice_001\"},\n    personality={\"trait\": \"brave\"}\n)\ndb.add(character)\ndb.commit()\ndb.refresh(character)\nprint(f\"Created Character: {character.id} - {character.name