.commit()\n    db.refresh(scene)\n    print(f\"u2713 ProjectScene: id={scene.id}, order={scene.scene_order}\")\n\n    # Test Script\n    script = Script(\n        project_id=project.id,\n        title=\"Episode 1\",\n        content=\"Script content\"\n    )\n    db.add(script)\n    db.commit()\n    db.refresh(script)\n    print(f\"u2713 Script: id={script.id}, title={script.title}\")\n\n    # Test ScriptLine\n    script_line = ScriptLine(\n        script_id=script.id,\n        line_order=1,\n        line_type=\"dialogue\",\n        speaker=\"Hero\",\n        content=\"Let's go!\",\n        emotion=\"happy\"\n    )\n    db.add(script_line)\n    db.commit()\n    print(f\"u2713 ScriptLine: id={script_line.id}, content={script_line.content}\")\n\n    # Test Video\n    video = Video(\n        project_id=project.id,\n        title=\"Test Video\",\n        status=\"pending\",\n        duration=30.0,\n        resolution=\"1920x1080\"\n    )\n    db.add(video)\n    db.commit()\n    db.refresh(video)\n    print(f\"u2713 Video: id={video.id}, title={video.title}\")\n\n    # Test VideoFrame\n    frame = VideoFrame(\n        video_id=video.id,\n        frame_order=1,\n        timestamp=0.0,\n        transition=\"fade\"\n    )\n    db.add(frame)\n    db.commit()\n    print(f\"u2713 VideoFrame: id={frame.id}, order={frame.frame_order}\")\n\n    # Test VideoAudio\n    audio = VideoAudio(\n        video_id=video.id,\n        audio_type=\"voiceover\",\n        start_time=0.0,\n        end_time=5.0,\n        volume=0.8\n    )\n    db.add(audio)\n    db.commit()\n    print(f\"u2713 VideoAudio: id={audio.id}, type={audio.audio_type}\")\n\n    # Query relationships\n    print(\"\\n--- Relationship Queries ---\")\n    user_projects = db.query(Project).filter(Project.user_id == user.id).all()\n    print(f\"User {user.id} has {len(user_projects)} project(s)\")\n    \n    scenes = db.query(ProjectScene).filter(ProjectScene.project_id == project.id).all()\n    print(f\"Project {project.id} h