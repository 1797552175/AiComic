'EOF'\nfrom sqlalchemy import create_engine\nfrom sqlalchemy.ext.declarative import declarative_base\nfrom sqlalchemy.orm import sessionmaker\n\nfrom apps.backend.config.config import settings\n\nengine = create_engine(settings.DATABASE_URL, pool_pre_ping=True)\nSessionLocal = sessionmaker(autocommit=False, autoflush=False, bind=engine)\nBase = declarative_base()\n\n\ndef get_db():\n    \"\"\"Dependency for getting database session\"\"\"\n    db = SessionLocal()\n    try:\n        yield db\n    finally:\n        db.close()\n        \n\ndef init_db():\n    \"\"\"Initialize database by creating all tables\"\"\"\n    Base.metadata.create_all(bind=engine)\nEOF"}, {"cmd": "cat > /opt/AiComic/apps/backend/models/user.py << 'ENDOFFILE'\nfrom datetime import datetime\nfrom sqlalchemy import (\n    Column, Integer, String, Text, Boolean, \n    ForeignKey, DateTime, JSON, Index\n)\nfrom sqlalchemy.orm import relationship\nfrom .database import Base\n\n\nclass User(Base):\n    \"\"\"User model for authentication and user management\"\"\"\n    __tablename__ = \"users\"\n    __table_args__ = (\n        Index('idx_user_username', 'username'),\n        Index('idx_user_email', 'email'),\n    )\n\n    id = Column(Integer, primary_key=True, index=True)\n    username = Column(String(100), unique=True, nullable=False, index=True)\n    email = Column(String(255), unique=True, nullable=False, index=True)\n    hashed_password = Column(String(255), nullable=False)\n    full_name = Column(String(200))\n    avatar_url = Column(String(500))\n    is_active = Column(Boolean, default=True)\n    is_superuser = Column(Boolean, default=False)\n    role = Column(String(50), default=\"user\")  # user, admin, creator\n    preferences = Column(JSON, default=dict)\n    created_at = Column(DateTime, default=datetime.utcnow)\n    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)\n    last_login = Column(DateTime)\n    \n    projects = relationship(\"Project\", back_populates=\"user\", cascade=\"all, delete-orphan\")\n    user_projects = relationship(\"UserProject\", back_populates=\"user\")\n\n\nclass UserProject(Base):\n    \"\"\"User-Project association for project sharing\"\"\"\n    __tablename__ = \"user_projects\"\n    __table_args__ = (\n        Index('idx_user_project_user_id', 'user_id'),\n        Index('idx_user_project_project_id', 'project_id'),\n    )\n\n    id = Column(Integer, primary_key=True, index=True)\n    user_id = Column(Integer, ForeignKey(\"users.id\"), nullable=False)\n    project_id = Column(Integer, ForeignKey(\"projects.id\"), nullable=False)\n    role = Column(String(50), default=\"editor\")  # owner, editor, viewer\n    shared_at = Column(DateTime, default=datetime.utcnow)\n    \n    user = relationship(\"User\", back_populates=\"user_projects\")\n    project = relationship(\"Project\")\nENDOFFILE"}, {"cmd": "cat > /opt/AiComic/apps/backend/models/character.py << 'ENDOFFILE'\nfrom datetime import datetime\nfrom sqlalchemy import (\n    Column, Integer, String, Text, Float, Boolean, \n    ForeignKey, DateTime, JSON, Index\n)\nfrom sqlalchemy.orm import relationship\nfrom .database import Base\n\n\nclass Character(Base):\n    \"\"\"Character model for comic/video characters\"\"\"\n    __tablename__ = \"characters\"\n    __table_args__ = (\n        Index('idx_character_name', 'name'),\n    )\n\n    id = Column(Integer, primary_key=True, index=True)\n    name = Column(String(100), nullable=False)\n    description = Column(Text)\n    base_image_url = Column(String(500))\n    voice_config = Column(JSON, default=dict)\n    personality = Column(JSON, default=dict)\n    created_at = Column(DateTime, default=datetime.utcnow)\n    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)\n    \n    appearances = relationship(\"CharacterAppearance\", back_populates=\"character\", cascade=\"all, delete-orphan\")\n    expressions = relationship(\"CharacterExpression\", back_populates=\"character\", cascade=\"all, delete-orphan\")\n    project_characters = relationship(\"ProjectCharacter\", back_populates=\"character\")\n\n\nclass CharacterAppearance(Base):\n    \"\"\"Character appearance variations (outfits, costumes)\"\"\"\n    __tablename__ = \"character_appearances\"\n    __table_args__ = (\n        Index('idx_character_appearance_type', 'appearance_type'),\n        Index('idx_character_appearance_character_id', 'character_id'),\n    )\n\n    id = Column(Integer, primary_key=True, index=True)\n    character_id = Column(Integer, ForeignKey(\"characters.id\"), nullable=False)\n    appearance_type = Column(String(50))  # casual, formal, angry, sad, etc.\n    image_url = Column(String(500))\n    description = Column(Text)\n    is_default = Column(Boolean, default=False)\n    created_at = Column(DateTime, default=datetime.utcnow)\n    \n    character = relationship(\"Character\", back_populates=\"appearances\")\n\n\nclass CharacterExpression(Base):\n    \"\"\"Character facial expressions\"\"\"\n    __tablename__ = \"character_expressions\"\n    __table_args__ = (\n        Index('idx_character_expression_type', 'expression_type'),\n        Index('idx_character_expression_character_id', 'character_id'),\n    )\n\n    id = Column(Integer, primary_key=True, index=True)\n    character_id = Column(Integer, ForeignKey(\"characters.id\"), nullable=False)\n    expression_type = Column(String(50))  # happy, sad, angry, surprised, etc.\n    image_url = Column(String(500))\n    intensity = Column(Float, default=1.0)  # 0.0 to 1.0\n    created_at = Column(DateTime, default=datetime.utcnow)\n    \n    character = relationship(\"Character\", back_populates=\"expressions\")\nENDOFFILE"}, {"cmd": "cat > /opt/AiComic/apps/backend/models/project.py << 'ENDOFFILE'\nfrom datetime import datetime\nfrom sqlalchemy import (\n    Column, Integer, String, Text, Float, Boolean, \n    ForeignKey, DateTime, JSON, Index\n)\nfrom sqlalchemy.orm import relationship\nfrom .database import Base\n\n\nclass Project(Base):\n    \"\"\"Project model for comic/video projects\"\"\"\n    __tablename__ = \"projects\"\n    __table_args__ = (\n        Index('idx_project_user_id', 'user_id'),\n        Index('idx_project_status', 'status'),\n    )\n\n    id = Column(Integer, primary_key=True, index=True)\n    name = Column(String(200), nullable=False)\n    description = Column(Text)\n    user_id = Column(Integer, ForeignKey(\"users.id\"), nullable=False)\n    status = Column(String(50), default=\"draft\")  # draft, processing, completed, failed\n    settings = Column(JSON, default=dict)\n    thumbnail_url = Column(String(500))\n    created_at = Column(DateTime, default=datetime.utcnow)\n    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)\n    \n    user = relationship(\"User\", back_populates=\"projects\")\n    scenes = relationship(\"ProjectScene\", back_populates=\"project\", cascade=\"all, delete-orphan\")\n    project_characters = relationship(\"ProjectCharacter\", back_populates=\"project\", cascade=\"all, delete-orphan\")\n\n\nclass ProjectScene(Base):\n    \"\"\"Project scene for organizing comic panels\"\"\"\n    __tablename__ = \"project_scenes\"\n    __table_args__ = (\n        Index('idx_project_scene_project_id', 'project_id'),\n    )\n\n    id = Column(Integer, primary_key=True, index=True)\n    project_id = Column(Integer, ForeignKey(\"projects.id\"), nullable=False)\n    scene_order = Column(Integer, default=0)\n    background_url = Column(String(500))\n    dialogue = Column(Text)\n    narration = Column(Text)\n    duration = Column(Float, default=3.0)  # seconds\n    camera_config = Column(JSON, default=dict)\n    created_at = Column(DateTime, default=datetime.utcnow)\n    \n    project = relationship(\"Project\", back_populates=\"scenes\")\n\n\nclass ProjectCharacter(Base):\n    \"\"\"Project-Character association for character positioning in projects\"\"\"\n    __tablename__ = \"project_characters\"\n    __table_args__ = (\n        Index('idx_project_character_project_id', 'project_id'),\n        Index('idx_project_character_character_id', 'character_id'),\n    )\n\n    id = Column(Integer, primary_key=True, index=True)\n    project_id = Column(Integer, ForeignKey(\"projects.id\"), nullable=False)\n    character_id = Column(Integer, ForeignKey(\"characters.id\"), nullable=False)\n    position_x = Column(Float, default=0.0)\n    position_y = Column(Float, default=0.0)\n    scale = Column(Float, default=1.0)\n    layer_order = Column(Integer, default=0)\n    created_at = Column(DateTime, default=datetime.utcnow)\n    \n    project = relationship(\"Project\", back_populates=\"project_characters\")\n    character = relationship(\"Character\", back_populates=\"project_characters\")\nENDOFFILE"}, {"cmd": "cat > /opt/AiComic/apps/backend/models/script.py << 'ENDOFFILE'\nfrom datetime import datetime\nfrom sqlalchemy import (\n    Column, Integer, String, Text, Float, Boolean, \n    ForeignKey, DateTime, JSON, Index\n)\nfrom sqlalchemy.orm import relationship\nfrom .database import Base\n\n\nclass Script(Base):\n    \"\"\"Script model for comic/video scripts\"\"\"\n    __tablename__ = \"scripts\"\n    __table_args__ = (\n        Index('idx_script_project_id', 'project_id'),\n    )\n\n    id = Column(Integer, primary_key=True, index=True)\n    project_id = Column(Integer, ForeignKey(\"projects.id\"), nullable=False)\n    content = Column(Text)\n    title = Column(String(200))\n    version = Column(Integer, default=1)\n    metadata = Column(JSON, default=dict)\n    created_at = Column(DateTime, default=datetime.utcnow)\n    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)\n    \n    lines = relationship(\"ScriptLine\", back_populates=\"script\", cascade=\"all, delete-orphan\")\n\n\nclass ScriptLine(Base):\n    \"\"\"Script line for dialogue, narration, and actions\"\"\"\n    __tablename__ = \"script_lines\"\n    __table_args__ = (\n        Index('idx_script_line_script_id', 'script_id'),\n        Index('idx_script_line_order', 'line_order'),\n    )\n\n    id = Column(Integer, primary_key=True, index=True)\n    script_id = Column(Integer, ForeignKey(\"scripts.id\"), nullable=False)\n    line_order = Column(Integer, default=0)\n    line_type = Column(String(50))  # dialogue, narration, action, scene_header\n    speaker = Column(String(100))\n    content = Column(Text)\n    emotion = Column(String(50))\n    timing = Column(Float)  # in seconds\n    metadata = Column(JSON, default=dict)\n    created_at = Column(DateTime, default=datetime.utcnow)\n    \n    script = relationship(\"Script\", back_populates=\"lines\")\nENDOFFILE"}, {"cmd": "cat > /opt/AiComic/apps/backend/models/video.py << 'ENDOFFILE'\nfrom datetime import datetime\nfrom sqlalchemy import (\n    Column, Integer, String, Text, Float, Boolean, \n    ForeignKey, DateTime, JSON, Index\n)\nfrom sqlalchemy.orm import relationship\nfrom .database import Base\n\n\nclass Video(Base):\n    \"\"\"Video model for generated video output\"\"\"\n    __tablename__ = \"videos\"\n    __table_args__ = (\n        Index('idx_video_project_id', 'project_id'),\n        Index('idx_video_status', 'status'),\n    )\n\n    id = Column(Integer, primary_key=True, index=True)\n    project_id = Column(Integer, ForeignKey(\"projects.id\"), nullable=False)\n    title = Column(String(200))\n    status = Column(String(50), default=\"pending\")  # pending, processing, completed, failed\n    output_url = Column(String(500))\n    duration = Column(Float)\n    resolution = Column(String(20))  # e.g., \"1920x1080\"\n    format = Column(String(10))  # mp4, webm, etc.\n    metadata = Column(JSON, default=dict)\n    created_at = Column(DateTime, default=datetime.utcnow)\n    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)\n    \n    frames = relationship(\"VideoFrame\", back_populates=\"video\", cascade=\"all, delete-orphan\")\n    audios = relationship(\"VideoAudio\", back_populates=\"video\", cascade=\"all, delete-orphan\")\n\n\nclass VideoFrame(Base):\n    \"\"\"Video frame for individual frames in video\"\"\"\n    __tablename__ = \"video_frames\"\n    __table_args__ = (\n        Index('idx_video_frame_video_id', 'video_id'),\n    )\n\n    id = Column(Integer, primary_key=True, index=True)\n    video_id = Column(Integer, ForeignKey(\"videos.id\"), nullable=False)\n    frame_order = Column(Integer, default=0)\n    image_url = Column(String(500))\n    timestamp = Column(Float)\n    transition = Column(String(50))  # fade, slide, dissolve, etc.\n    effects = Column(JSON, default=dict)\n    created_at = Column(DateTime, default=datetime.utcnow)\n    \n    video = relationship(\"Video\", back_populates=\"frames\")\n\n\nclass VideoAudio(Base):\n    \"\"\"Video audio for voiceover, music, and sound effects\"\"\"\n    __tablename__ = \"video_audios\"\n    __table_args__ = (\n        Index('idx_video_audio_video_id', 'video_id'),\n    )\n\n    id = Column(Integer, primary_key=True, index=True)\n    video_id = Column(Integer, ForeignKey(\"videos.id\"), nullable=False)\n    audio_type = Column(String(50))  # voiceover, music, sfx\n    file_url = Column(String(500))\n    start_time = Column(Float)\n    end_time = Column(Float)\n    volume = Column(Float, default=1.0)\n    created_at = Column(DateTime, default=datetime.utcnow)\n    \n    video = relationship(\"Video\", back_populates=\"audios\")\nENDOFFILE"}, {"cmd": "cat > /opt/AiComic/apps/backend/models/__init__.py << 'ENDOFFILE'\n\"\"\"\nDatabase models for AI Comic Backend\n\nThis module contains all SQLAlchemy ORM models for the application.\nModels are organized by domain:\n- User: User authentication and authorization\n- Project: Comic/video project management\n- Character: Character definitions and appearances\n- Script: Script and dialogue management\n- Video: Generated video output management\n\"\"\"\n\nfrom .database import Base, get_db, init_db, SessionLocal\nfrom .schemas 