│  ### src/components/PanelCard.tsx                                            │
│  ```tsx                                                                      │
│  import React, { useState } from 'react';                                    │
│  import { ComicPanel, TextOverlay } from '../types';                         │
│  import './PanelCard.css';                                                   │
│                                                                              │
│  interface PanelCardProps {                                                  │
│    panel: ComicPanel;                                                        │
│    index: number;                                                            │
│    onAddText: (text: string) => void;                                        │
│  }                                                                           │
│                                                                              │
│  const PanelCard: React.FC<PanelCardProps> = ({ panel, index, onAddText })   │
│  => {                                                                        │
│    const [showTextInput, setShowTextInput] = useState(false);                │
│    const [textValue, setTextValue] = useState('');                           │
│                                                                              │
│    const handleAddText = () => {                                             │
│      if (textValue.trim()) {                                                 │
│        onAddText(textValue);                                                 │
│        setTextValue('');                                                     │
│        setShowTextInput(false);                                              │
│      }                                                                       │
│    };                                                                        │
│                                                                              │
│    return (                                                                  │
│      <div className="panel-card">                                            │
│        <div className="panel-header">                                        │
│          <span className="panel-number">Panel {index + 1}</span>             │
│          <div className="panel-actions">                                     │
│            <button className="panel-action-btn" title="Edit">✏️</button>     │
│            <button className="panel-action-btn" title="Delete">🗑️</button>   │
│          </div>                                                              │
│        </div>                                                                │
│        <div className="panel-image-container">                               │
│          <img                                                                │
│            src={panel.imageUrl}                                              │
│            alt={`Comic panel ${index + 1}`}                                  │
│            className="panel-image"                                           │
│          />                                                                  │
│          {panel.textOverlays.map((overlay) => (                              │
│            <div                                                              │
│              key={overlay.id}                                                │
│              className="text-overlay speech-bubble"                          │
│              style={{ left: `${overlay.x}%`, top: `${overlay.y}%` }}         │
│            >                                                                 │
│              {overlay.text}                                                  │
│            </div>                                                            │
│          ))}                                                                 │
│          {panel.caption && (                                                 │
│            <div className="panel-caption">{panel.caption}</div>              │
│          )}                                                                  │
│        </div>                                                                │
│        <div className="panel-footer">                                        │
│          {showTextInput ? (                                                  │
│            <div className="text-input-container">                            │
│              <input                                                          │
│                type="text"                                                   │
