│  ```tsx                                                                      │
│  import React, { useState } from 'react';                                    │
│  import Header from './components/Header';                                   │
│  import PromptInput from './components/PromptInput';                         │
│  import ComicCanvas from './components/ComicCanvas';                         │
│  import ExportModal from './components/ExportModal';                         │
│  import Toast from './components/Toast';                                     │
│  import { ComicPanel } from './types';                                       │
│                                                                              │
│  const App: React.FC = () => {                                               │
│    const [panels, setPanels] = useState<ComicPanel[]>([]);                   │
│    const [isGenerating, setIsGenerating] = useState(false);                  │
│    const [showExport, setShowExport] = useState(false);                      │
│    const [toast, setToast] = useState<{ message: string; type: 'success' |   │
│  'error' } | null>(null);                                                    │
│                                                                              │
│    const handleGenerate = async (prompt: string) => {                        │
│      setIsGenerating(true);                                                  │
│      setToast({ message: 'Generating comic panels...', type: 'success' });   │
│                                                                              │
│      // Simulate AI generation                                               │
│      setTimeout(() => {                                                      │
│        const newPanels: ComicPanel[] = [                                     │
│          { id: '1', imageUrl: 'https://picsum.photos/400/300?random=1',      │
│  textOverlays: [], caption: 'Panel 1' },                                     │
│          { id: '2', imageUrl: 'https://picsum.photos/400/300?random=2',      │
│  textOverlays: [], caption: 'Panel 2' },                                     │
│          { id: '3', imageUrl: 'https://picsum.photos/400/300?random=3',      │
│  textOverlays: [], caption: 'Panel 3' },                                     │
│          { id: '4', imageUrl: 'https://picsum.photos/400/300?random=4',      │
│  textOverlays: [], caption: 'Panel 4' },                                     │
│        ];                                                                    │
│        setPanels(newPanels);                                                 │
│        setIsGenerating(false);                                               │
│        setToast({ message: 'Comic generated successfully!', type: 'success'  │
│  });                                                                         │
│      }, 2000);                                                               │
│    };                                                                        │
│                                                                              │
│    const handleAddTextOverlay = (panelId: string, text: string) => {         │
│      setPanels(panels.map(panel =>                                           │
│        panel.id === panelId                                                  │
│          ? { ...panel, textOverlays: [...panel.textOverlays, { id:           │
│  Date.now().toString(), text, x: 50, y: 50 }] }                              │
│          : panel                                                             │
│      ));                                                                     │
│      setToast({ message: 'Text added to panel', type: 'success' });          │
│    };                                                                        │
│                                                                              │
│    const handleExport = (format: string) => {                                │
│      setToast({ message: `Exporting as ${format}...`, type: 'success' });    │
│      setShowExport(false);                                                   │
│    };                                                                        │
│                                                                              │
│    const showToast = (message: string, type: 'success' | 'error') => {       │
│      setToast({ message, type });                                            │
│    };                                                                        │
│                                                                              │
│    return (                                                                  │
│      <div className="app">                                                   │
│        <Header onExport={() => setShowExport(true)} />                       │
│        <main className="main-content">                                       │
│          <PromptInput onGenerate={handleGenerate}                            │
│  isGenerating={isGenerating} />                                              │
│          <ComicCanvas                                                        │
│            panels={panels}                                                   │
│            onAddTextOverlay={handleAddTextOverlay}                           │
│            showToast={showToast}                                             │
│          />                                                                  │
│        </main>                                                               │
│        {showExport && (                                                      │
│          <ExportModal                                                        │
│            onClose={() => setShowExport(false)}                              │
│            onExport={handleExport}                                           │
│          />                                                                  │
│        )}                                                                    │
│        {toast && (                                                           │
│          <Toast                                                              │
│            message={toast.message}                                           │
│            type={toast.type}                                                 │
│            onClose={() => setToast(null)}                                    │
│          />                                                                  │
│        )}                                                                    │
│      </div>                                                                  │
│    );                                                                        │
│  };                                                                          │
│                                                                              │
│  export default App;                                                         │
│  ```                                                                         │
