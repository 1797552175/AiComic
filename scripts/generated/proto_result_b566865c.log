│          # 获取两个音轨的时长                                                │
│          voice_duration =                                                    │
│  self._get_audio_duration(voice_track_url.replace("file://", ""))            │
│          bgm_duration =                                                      │
│  self._get_audio_duration(bgm_track_url.replace("file://", ""))              │
│                                                                              │
│          # 如果BGM比语音短，循环BGM                                          │
│          if bgm_duration < voice_duration:                                   │
