│                  "-t", str(voice_duration),                                  │
│                  "-c", "copy",                                               │
│                  looped_bgm                                                  │
│              ], capture_output=True)                                         │
│              bgm_track_url = f"file://{looped_bgm}"                          │
│                                                                              │
│          # 混合                                                              │
│          cmd = [                                                             │
│              "ffmpeg", "-y",                                                 │
│              "-i", voice_track_url.replace("file://", ""),                   │
│              "-i", bgm_track_url.replace("file://", ""),                     │
│              "-filter_complex",                                              │
│              f"[0:a]volume={voice_volume}[voice];[1:a]volume={bgm_volume}[b  │
│  gm];[voice][bgm]amix=inputs=2:duration=longest",                            │
│              "-q:a", "0",                                                    │
│              output_path                                                     │
│          ]                                                                   │
│                                                                              │
│          subprocess.run(cmd, capture_output=True)                            │
│          return f"file://{output_path}"                                      │
