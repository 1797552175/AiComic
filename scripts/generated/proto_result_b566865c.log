│                      # 收集角色                                              │
│                      for char in scene_data.get("characters", []):           │
│                          if char["name"] not in characters:                  │
│                              characters[char["name"]] = char                 │
│              except Exception as e:                                          │
│                  warnings.append(f"解析场景失败: {str(e)}")                  │
│                                                                              │
│          return {                                                            │
