│  使用 React Context 管理会员订阅状态：                                       │
│                                                                              │
│  ```typescript                                                               │
│  // contexts/SubscriptionContext.tsx                                         │
│  import React, { createContext, useContext, useReducer } from 'react';       │
│                                                                              │
│  interface SubscriptionState {                                               │
│    currentPlan: 'free' | 'basic' | 'pro' | 'team';                           │
│    billingCycle: 'monthly' | 'yearly';                                       │
│    expiresAt: string | null;                                                 │
│    remainingQuota: number;                                                   │
│    dailyUsage: number;                                                       │
│    isTrial: boolean;                                                         │
│    isLoading: boolean;                                                       │
│  }                                                                           │
│                                                                              │
│  type SubscriptionAction =                                                   │
│    | { type: 'SET_PLAN'; payload: SubscriptionState['currentPlan'] }         │
│    | { type: 'SET_BILLING_CYCLE'; payload:                                   │
│  SubscriptionState['billingCycle'] }                                         │
│    | { type: 'SET_EXPIRES_AT'; payload: string | null }                      │
│    | { type: 'SET_QUOTA'; payload: number }                                  │
│    | { type: 'SET_DAILY_USAGE'; payload: number }                            │
│    | { type: 'SET_IS_TRIAL'; payload: boolean }                              │
│    | { type: 'SET_LOADING'; payload: boolean }                               │
│    | { type: 'RESET' };                                                      │
│                                                                              │
│  const initialState: SubscriptionState = {                                   │
│    currentPlan: 'free',                                                      │
│    billingCycle: 'monthly',                                                  │
│    expiresAt: null,                                                          │
│    remainingQuota: 5,                                                        │
│    dailyUsage: 0,                                                            │
│    isTrial: false,                                                           │
│    isLoading: false,                                                         │
│  };                                                                          │
│                                                                              │
│  function subscriptionReducer(state: SubscriptionState, action:              │
│  SubscriptionAction): SubscriptionState {                                    │
│    switch (action.type) {                                                    │
│      case 'SET_PLAN':                                                        │
│        return { ...state, currentPlan: action.payload };                     │
│      case 'SET_BILLING_CYCLE':                                               │
│        return { ...state, billingCycle: action.payload };                    │
│      case 'SET_EXPIRES_AT':                                                  │
│        return { ...state, expiresAt: action.payload };                       │
│      case 'SET_QUOTA':                                                       │
│        return { ...state, remainingQuota: action.payload };                  │
│      case 'SET_DAILY_USAGE':                                                 │
│        return { ...state, dailyUsage: action.payload };                      │
│      case 'SET_IS_TRIAL':                                                    │
│        return { ...state, isTrial: action.payload };                         │
│      case 'SET_LOADING':                                                     │
│        return { ...state, isLoading: action.payload };                       │
│      case 'RESET':                                                           │
│        return initialState;                                                  │
│      default:                                                                │
│        return state;                                                         │
│    }                                                                         │
│  }                                                                           │
│                                                                              │
│  interface SubscriptionContextType {                                         │
│    state: SubscriptionState;                                                 │
│    dispatch: React.Dispatch<SubscriptionAction>;                             │
│    selectPlan: (plan: SubscriptionState['currentPlan']) => void;             │
│    selectBillingCycle: (cycle: SubscriptionState['billingCycle']) => void;   │
│    subscribe: (plan: SubscriptionState['currentPlan'], cycle:                │
│  SubscriptionState['billingCycle']) => Promise<void>;                        │
│    cancelSubscription: () => Promise<void>;                                  │
│    upgradePlan: (plan: SubscriptionState['currentPlan']) => Promise<void>;   │
│  }                                                                           │
│                                                                              │
│  const SubscriptionContext = createContext<SubscriptionContextType |         │
│  undefined>(undefined);                                                      │
│                                                                              │
│  export function SubscriptionProvider({ children }: { children:              │
│  React.ReactNode }) {                                                        │
│    const [state, dispatch] = useReducer(subscriptionReducer, initialState);  │
│                                                                              │
│    const selectPlan = (plan: SubscriptionState['currentPlan']) => {          │
│      dispatch({ type: 'SET_PLAN', payload: plan });                          │
│    };                                                                        │
│                                                                              │
│    const selectBillingCycle = (cycle: SubscriptionState['billingCycle']) =>  │
│  {                                                                           │
│      dispatch({ type: 'SET_BILLING_CYCLE', payload: cycle });                │
│    };                                                                        │
│                                                                              │
│    const subscribe = async (plan: SubscriptionState['currentPlan'], cycle:   │
│  SubscriptionState['billingCycle']) => {                                     │
│      dispatch({ type: 'SET_LOADING', payload: true });                       │
│      try {                                                                   │
│        // API call to create subscription                                    │
│        await new Promise(resolve => setTimeout(resolve, 1000));              │
│        dispatch({ type: 'SET_PLAN', payload: plan });                        │
│        dispatch({ type: 'SET_BILLING_CYCLE', payload: cycle });              │
│        dispatch({ type: 'SET_EXPIRES_AT', payload: new Date(Date.now() + 30  │
│  * 24 * 60 * 60 * 1000).toISOString() });                                    │
│      } finally {                                                             │
│        dispatch({ type: 'SET_LOADING', payload: false });                    │
│      }                                                                       │
│    };                                                                        │
│                                                                              │
│    const cancelSubscription = async () => {                                  │
│      dispatch({ type: 'SET_LOADING', payload: true });                       │
│      try {                                                                   │
│        // API call to cancel subscription                                    │
│        await new Promise(resolve => setTimeout(resolve, 1000));              │
│        dispatch({ type: 'SET_PLAN', payload: 'free' });                      │
│      } finally {                                                             │
│        dispatch({ type: 'SET_LOADING', payload: false });                    │
│      }                                                                       │
│    };                                                                        │
│                                                                              │
│    const upgradePlan = async (plan: SubscriptionState['currentPlan']) => {   │
│      dispatch({ type: 'SET_LOADING', payload: true });                       │
│      try {                                                                   │
│        // API call to upgrade plan                                           │
│        await new Promise(resolve => setTimeout(resolve, 1000));              │
│        dispatch({ type: 'SET_PLAN', payload: plan });                        │
│      } finally {                                                             │
│        dispatch({ type: 'SET_LOADING', payload: false });                    │
│      }                                                                       │
│    };                                                                        │
│                                                                              │
│    return (                                                                  │
│      <SubscriptionContext.Provider value={{                                  │
│        state,                                                                │
│        dispatch,                                                             │
│        selectPlan,                                                           │
│        selectBillingCycle,                                                   │
│        subscribe,                                                            │
│        cancelSubscription,                                                   │
│        upgradePlan,                                                          │
│      }}>                                                                     │
│        {children}                                                            │
│      </SubscriptionContext.Provider>                                         │
│    );                                                                        │
│  }                                                                           │
│                                                                              │
│  export function useSubscription() {                                         │
│    const context = useContext(SubscriptionContext);                          │
│    if (context === undefined) {                                              │
│      throw new Error('useSubscription must be used within a                  │
│  SubscriptionProvider');                                                     │
│    }                                                                         │
│    return context;                                                           │
│  }                                                                           │
│  ```                                                                         │
